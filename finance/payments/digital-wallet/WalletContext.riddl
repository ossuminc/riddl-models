// Digital Wallet - Wallet Context
context WalletContext is {
  include "types.riddl"
  include "Wallet.riddl"
  // Repository for wallet persistence
  repository WalletRepository is {
    schema WalletData is relational
      of wallets as type Wallet
        index on field Wallet.walletId
        index on field Wallet.userId

    handler WalletPersistence is {
      on command Wallet.CreateWallet is {
        tell event Wallet.WalletCreated to entity
          WalletContext.Wallet
      }
      on command Wallet.AddPaymentMethod is {
        tell event Wallet.PaymentMethodAdded to entity
          WalletContext.Wallet
      }
      on command Wallet.RemovePaymentMethod is {
        tell event Wallet.PaymentMethodRemoved to entity
          WalletContext.Wallet
      }
      on command Wallet.SetDefaultMethod is {
        tell event Wallet.DefaultMethodSet to entity
          WalletContext.Wallet
      }
      on command Wallet.TopUpBalance is {
        tell event Wallet.BalanceToppedUp to entity
          WalletContext.Wallet
      }
      on command Wallet.MakePayment is {
        tell event Wallet.PaymentMade to entity
          WalletContext.Wallet
      }
      on command Wallet.TransferFunds is {
        tell event Wallet.FundsTransferred to entity
          WalletContext.Wallet
      }
      on command Wallet.ReceiveFunds is {
        tell event Wallet.FundsReceived to entity
          WalletContext.Wallet
      }
      on command Wallet.WithdrawFunds is {
        tell event Wallet.FundsWithdrawn to entity
          WalletContext.Wallet
      }
      on command Wallet.SuspendWallet is {
        tell event Wallet.WalletSuspended to entity
          WalletContext.Wallet
      }
      on command Wallet.ReactivateWallet is {
        tell event Wallet.WalletReactivated to entity
          WalletContext.Wallet
      }
      on command Wallet.CloseWallet is {
        tell event Wallet.WalletClosed to entity
          WalletContext.Wallet
      }
    } with {
      briefly "Persists wallet commands"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Wallet data persistence"
    described as {
      | The WalletRepository provides persistent storage for
      | wallet accounts, transactions, and payment methods.
    }
  }
  // Projector for wallet analytics
  projector WalletAnalytics is {
    updates repository WalletContext.WalletRepository
    record WalletStats is  {
      totalWallets: Natural with {
        briefly "Wallets"
        described as {
          |Total wallets.
        }
      }
      activeWallets: Natural with {
        briefly "Active"
        described as {
          |Active wallets.
        }
      }
      totalBalance: Decimal(18,2) with {
        briefly "Balance"
        described as {
          |Total platform balance.
        }
      }
      dailyTransactions: Natural with {
        briefly "Daily"
        described as {
          |Daily transactions.
        }
      }
      dailyVolume: Decimal(15,2) with {
        briefly "Volume"
        described as {
          |Daily transaction volume.
        }
      }
      avgTransactionSize: Decimal(10,2) with {
        briefly "Avg size"
        described as {
          |Average transaction.
        }
      }
    } with {
      briefly "Wallet statistics"
      described as {
        |Platform wallet metrics.
      }
    }
    handler AnalyticsHandler is {
      on event Wallet.WalletCreated is {
        tell event Wallet.WalletCreated to repository
          WalletContext.WalletRepository
      }
      on event Wallet.PaymentMade is {
        tell event Wallet.PaymentMade to repository
          WalletContext.WalletRepository
      }
      on event Wallet.FundsTransferred is {
        tell event Wallet.FundsTransferred to repository
          WalletContext.WalletRepository
      }
      on event Wallet.BalanceToppedUp is {
        tell event Wallet.BalanceToppedUp to repository
          WalletContext.WalletRepository
      }
    } with {
      briefly "Maintains wallet analytics"
      described as {
        |Projects events into analytics views.
      }
    }
  } with {
    briefly "Wallet analytics projections"
    described as {
      |Maintains wallet platform analytics data.
    }
  }
  source WalletEventSource is {
    outlet WalletEvents is type WalletEvent
    handler WalletEventEmitter is {
      on init is {
        tell command InitializeWallet to entity
          WalletContext.Wallet
      }
      on other is { ??? }
      on event Wallet.WalletCreated is {
        send event Wallet.WalletCreated to outlet WalletEvents
      }
      on event Wallet.PaymentMade is {
        send event Wallet.PaymentMade to outlet WalletEvents
      }
      on event Wallet.FundsTransferred is {
        send event Wallet.FundsTransferred to outlet WalletEvents
      }
      on event Wallet.WalletSuspended is {
        send event Wallet.WalletSuspended to outlet WalletEvents
      }
      on event Wallet.WalletClosed is {
        send event Wallet.WalletClosed to outlet WalletEvents
      }
    } with {
      briefly "Wallet event emitter"
      described as {
        |Emits wallet lifecycle events into the streaming
        |topology.
      }
    }
  } with {
    briefly "Wallet event source"
    described as {
      |Publishes wallet entity events for streaming.
    }
  }
  sink WalletEventSink is {
    inlet IncomingWalletEvents is type WalletEvent
    handler WalletEventReceiver is {
      on init is { ??? }
      on other is { ??? }
      on event Wallet.WalletCreated is {
        tell event Wallet.WalletCreated to repository
          WalletContext.WalletRepository
      }
      on event Wallet.WalletClosed is {
        tell event Wallet.WalletClosed to repository
          WalletContext.WalletRepository
      }
    } with {
      briefly "Wallet event receiver"
      described as {
        |Receives wallet events and persists them.
      }
    }
  } with {
    briefly "Wallet event sink"
    described as {
      |Receives wallet events from the streaming topology.
    }
  }
  connector WalletEventPipeline is {
    from outlet WalletContext.WalletEventSource.WalletEvents
      to inlet WalletContext.WalletEventSink.IncomingWalletEvents
  } with {
    briefly "Wallet event pipeline"
    described as {
      |Wires wallet events from source to sink.
    }
  }
} with {
  briefly "Bounded context for digital wallets"
  described as {
    | The WalletContext is the bounded context for digital
    | wallet management, payments, and P2P transfers.
  }
}
