// Merchant Acquiring - Merchant Context
context MerchantContext is {
  include "types.riddl"
  include "Merchant.riddl"
  // Repository for merchant persistence
  repository MerchantRepository is {
    schema MerchantData is relational
      of merchants as type Merchant
        index on field Merchant.merchantId
        index on field Merchant.business.legalName

    handler MerchantPersistence is {
      on command Merchant.SubmitApplication is {
        tell event Merchant.ApplicationSubmitted to entity
          MerchantContext.Merchant
      }
      on command Merchant.ApproveApplication is {
        tell event Merchant.ApplicationApproved to entity
          MerchantContext.Merchant
      }
      on command Merchant.DeclineApplication is {
        tell event Merchant.ApplicationDeclined to entity
          MerchantContext.Merchant
      }
      on command Merchant.ActivateMerchant is {
        tell event Merchant.MerchantActivated to entity
          MerchantContext.Merchant
      }
      on command Merchant.UpdatePricing is {
        tell event Merchant.PricingUpdated to entity
          MerchantContext.Merchant
      }
      on command Merchant.SuspendMerchant is {
        tell event Merchant.MerchantSuspended to entity
          MerchantContext.Merchant
      }
      on command Merchant.ReactivateMerchant is {
        tell event Merchant.MerchantReactivated to entity
          MerchantContext.Merchant
      }
      on command Merchant.TerminateMerchant is {
        tell event Merchant.MerchantTerminated to entity
          MerchantContext.Merchant
      }
    } with {
      briefly "Persists merchant commands"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Merchant data persistence"
    described as {
      | The MerchantRepository provides persistent storage for
      | merchant accounts and underwriting data.
    }
  }
  // Projector for merchant analytics
  projector MerchantAnalytics is {
    updates repository MerchantContext.MerchantRepository
    record MerchantStats is  {
      totalApplications: Natural with {
        briefly "Applications"
        described as {
          |Total applications.
        }
      }
      approvalRate: Decimal(5,4) with {
        briefly "Approval rate"
        described as {
          |Approval rate.
        }
      }
      activeMerchants: Natural with {
        briefly "Active"
        described as {
          |Active merchants.
        }
      }
      avgMonthlyVolume: Decimal(15,2) with {
        briefly "Avg volume"
        described as {
          |Average monthly volume.
        }
      }
      avgRiskScore: Decimal(5,4) with {
        briefly "Avg risk"
        described as {
          |Average risk level.
        }
      }
      chargebackRate: Decimal(5,4) with {
        briefly "Chargeback rate"
        described as {
          |Portfolio chargeback rate.
        }
      }
    } with {
      briefly "Merchant statistics"
      described as {
        |Merchant portfolio metrics.
      }
    }
    handler AnalyticsHandler is {
      on event Merchant.ApplicationSubmitted is {
        tell event Merchant.ApplicationSubmitted to repository
          MerchantContext.MerchantRepository
      }
      on event Merchant.ApplicationApproved is {
        tell event Merchant.ApplicationApproved to repository
          MerchantContext.MerchantRepository
      }
      on event Merchant.MerchantActivated is {
        tell event Merchant.MerchantActivated to repository
          MerchantContext.MerchantRepository
      }
      on event Merchant.MerchantTerminated is {
        tell event Merchant.MerchantTerminated to repository
          MerchantContext.MerchantRepository
      }
    } with {
      briefly "Maintains merchant analytics"
      described as {
        |Projects events into analytics views.
      }
    }
  } with {
    briefly "Merchant analytics projections"
    described as {
      |Maintains merchant portfolio analytics data.
    }
  }
  source MerchantEventSource is {
    outlet MerchantEvents is type MerchantEvent
    handler MerchantEventEmitter is {
      on init is {
        tell command InitializeMerchant to entity
          MerchantContext.Merchant
      }
      on other is { ??? }
      on event Merchant.ApplicationSubmitted is {
        send event Merchant.ApplicationSubmitted to outlet MerchantEvents
      }
      on event Merchant.MerchantActivated is {
        send event Merchant.MerchantActivated to outlet MerchantEvents
      }
      on event Merchant.MerchantSuspended is {
        send event Merchant.MerchantSuspended to outlet MerchantEvents
      }
      on event Merchant.MerchantTerminated is {
        send event Merchant.MerchantTerminated to outlet MerchantEvents
      }
    } with {
      briefly "Merchant event emitter"
      described as {
        |Emits merchant lifecycle events into the streaming
        |topology.
      }
    }
  } with {
    briefly "Merchant event source"
    described as {
      |Publishes merchant entity events for streaming.
    }
  }
  sink MerchantEventSink is {
    inlet IncomingMerchantEvents is type MerchantEvent
    handler MerchantEventReceiver is {
      on init is { ??? }
      on other is { ??? }
      on event Merchant.ApplicationSubmitted is {
        tell event Merchant.ApplicationSubmitted to repository
          MerchantContext.MerchantRepository
      }
      on event Merchant.MerchantTerminated is {
        tell event Merchant.MerchantTerminated to repository
          MerchantContext.MerchantRepository
      }
    } with {
      briefly "Merchant event receiver"
      described as {
        |Receives merchant events and persists them.
      }
    }
  } with {
    briefly "Merchant event sink"
    described as {
      |Receives merchant events from the streaming topology.
    }
  }
  connector MerchantEventPipeline is {
    from outlet MerchantContext.MerchantEventSource.MerchantEvents
      to inlet MerchantContext.MerchantEventSink.IncomingMerchantEvents
  } with {
    briefly "Merchant event pipeline"
    described as {
      |Wires merchant events from source to sink.
    }
  }
} with {
  briefly "Bounded context for merchant acquiring"
  described as {
    | The MerchantContext is the bounded context for merchant
    | onboarding, underwriting, and account management.
  }
}
