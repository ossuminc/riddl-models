// Fund Transfer - Transfer Context
context TransferContext is {
  include "types.riddl"
  include "Transfer.riddl"
  // Repository for transfer persistence
  repository TransferRepository is {
    schema TransferData is relational
      of transfers as type Transfer
        index on field Transfer.transferId
        index on field Transfer.info.sourceAccountId

    handler TransferPersistence is {
      on command Transfer.SubmitTransfer is {
        tell event Transfer.TransferSubmitted to entity
          TransferContext.Transfer
      }
      on command Transfer.ValidateTransfer is {
        tell event Transfer.TransferValidated to entity
          TransferContext.Transfer
      }
      on command Transfer.ApplyFees is {
        tell event Transfer.FeesApplied to entity
          TransferContext.Transfer
      }
      on command Transfer.ApplyExchangeRate is {
        tell event Transfer.ExchangeRateApplied to entity
          TransferContext.Transfer
      }
      on command Transfer.RouteTransfer is {
        tell event Transfer.TransferRouted to entity
          TransferContext.Transfer
      }
      on command Transfer.ProcessTransfer is {
        tell event Transfer.TransferProcessed to entity
          TransferContext.Transfer
      }
      on command Transfer.CompleteTransfer is {
        tell event Transfer.TransferCompleted to entity
          TransferContext.Transfer
      }
      on command Transfer.ReturnTransfer is {
        tell event Transfer.TransferReturned to entity
          TransferContext.Transfer
      }
      on command Transfer.CancelTransfer is {
        tell event Transfer.TransferCancelled to entity
          TransferContext.Transfer
      }
    } with {
      briefly "Persists transfer commands"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Transfer data persistence"
    described as {
      | The TransferRepository provides persistent storage for
      | fund transfers and payment tracking.
    }
  }
  // Projector for transfer analytics
  projector TransferAnalytics is {
    updates repository TransferContext.TransferRepository
    record TransferStats is  {
      transferType: TransferType with {
        briefly "Type"
        described as {
          |Transfer type.
        }
      }
      totalTransfers: Natural with {
        briefly "Transfers"
        described as {
          |Total transfers.
        }
      }
      totalVolume: Decimal(20,2) with {
        briefly "Volume"
        described as {
          |Total volume.
        }
      }
      avgAmount: Decimal(15,2) with {
        briefly "Average"
        described as {
          |Average amount.
        }
      }
      successRate: Decimal(5,4) with {
        briefly "Success"
        described as {
          |Success rate.
        }
      }
      avgProcessingTime: Duration with {
        briefly "Processing"
        described as {
          |Avg processing time.
        }
      }
    } with {
      briefly "Transfer statistics"
      described as {
        |Fund transfer metrics.
      }
    }
    handler AnalyticsHandler is {
      on event Transfer.TransferSubmitted is {
        tell event Transfer.TransferSubmitted to repository
          TransferContext.TransferRepository
      }
      on event Transfer.TransferCompleted is {
        tell event Transfer.TransferCompleted to repository
          TransferContext.TransferRepository
      }
      on event Transfer.TransferReturned is {
        tell event Transfer.TransferReturned to repository
          TransferContext.TransferRepository
      }
    } with {
      briefly "Maintains transfer analytics"
      described as {
        |Projects events into analytics views.
      }
    }
  } with {
    briefly "Transfer analytics projections"
    described as {
      |Maintains fund transfer analytics data.
    }
  }
  source TransferEventSource is {
    outlet TransferEvents is type TransferEvent
    handler TransferEventEmitter is {
      on init is {
        tell command InitializeTransfer to entity
          TransferContext.Transfer
      }
      on other is { ??? }
      on event Transfer.TransferSubmitted is {
        send event Transfer.TransferSubmitted to outlet TransferEvents
      }
      on event Transfer.TransferCompleted is {
        send event Transfer.TransferCompleted to outlet TransferEvents
      }
      on event Transfer.TransferReturned is {
        send event Transfer.TransferReturned to outlet TransferEvents
      }
      on event Transfer.TransferCancelled is {
        send event Transfer.TransferCancelled to outlet TransferEvents
      }
    } with {
      briefly "Transfer event emitter"
      described as {
        |Emits transfer lifecycle events into the streaming
        |topology.
      }
    }
  } with {
    briefly "Transfer event source"
    described as {
      |Publishes transfer entity events for streaming.
    }
  }
  sink TransferEventSink is {
    inlet IncomingTransferEvents is type TransferEvent
    handler TransferEventReceiver is {
      on init is { ??? }
      on other is { ??? }
      on event Transfer.TransferSubmitted is {
        tell event Transfer.TransferSubmitted to repository
          TransferContext.TransferRepository
      }
      on event Transfer.TransferCompleted is {
        tell event Transfer.TransferCompleted to repository
          TransferContext.TransferRepository
      }
    } with {
      briefly "Transfer event receiver"
      described as {
        |Receives transfer events and persists them.
      }
    }
  } with {
    briefly "Transfer event sink"
    described as {
      |Receives transfer events from the streaming topology.
    }
  }
  connector TransferEventPipeline is {
    from outlet TransferContext.TransferEventSource.TransferEvents
      to inlet TransferContext.TransferEventSink.IncomingTransferEvents
  } with {
    briefly "Transfer event pipeline"
    described as {
      |Wires transfer events from source to sink.
    }
  }
} with {
  briefly "Bounded context for transfers"
  described as {
    | The TransferContext is the bounded context for fund
    | transfers, payment routing, and settlement.
  }
}
