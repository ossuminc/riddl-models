// Credit Decisioning - Decision Context
context DecisionContext is {
  include "types.riddl"
  include "Decision.riddl"
  // Repository for decision persistence
  repository DecisionRepository is {
    schema DecisionData is relational
      of decisions as type Decision
        index on field Decision.decisionId
        index on field Decision.applicationId

    handler DecisionPersistence is {
      on command Decision.EvaluateApplication is {
        tell event Decision.ApplicationEvaluationStarted to entity
          DecisionContext.Decision
      }
      on command Decision.AddBureauData is {
        tell event Decision.BureauDataAdded to entity
          DecisionContext.Decision
      }
      on command Decision.CalculateScore is {
        tell event Decision.ScoreCalculated to entity
          DecisionContext.Decision
      }
      on command Decision.ApplyPolicy is {
        tell event Decision.PolicyApplied to entity
          DecisionContext.Decision
      }
      on command Decision.RenderDecision is {
        tell event Decision.DecisionRendered to entity
          DecisionContext.Decision
      }
      on command Decision.ReferToUnderwriter is {
        tell event Decision.ReferredToUnderwriter to entity
          DecisionContext.Decision
      }
      on command Decision.ApproveManually is {
        tell event Decision.ManuallyApproved to entity
          DecisionContext.Decision
      }
      on command Decision.DeclineManually is {
        tell event Decision.ManuallyDeclined to entity
          DecisionContext.Decision
      }
      on command Decision.OverrideDecision is {
        tell event Decision.DecisionOverridden to entity
          DecisionContext.Decision
      }
    } with {
      briefly "Persists decision commands"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Decision data persistence"
    described as {
      | The DecisionRepository provides persistent storage for
      | credit decisions and evaluation data.
    }
  }
  // Projector for decision analytics
  projector DecisionAnalytics is {
    updates repository DecisionContext.DecisionRepository
    record DecisionStats is  {
      totalApplications: Natural with {
        briefly "Total"
        described as {
          |Total applications.
        }
      }
      autoApprovalRate: Decimal(5,4) with {
        briefly "Auto approval"
        described as {
          |Auto-approval rate.
        }
      }
      manualReviewRate: Decimal(5,4) with {
        briefly "Manual review"
        described as {
          |Manual review rate.
        }
      }
      overallApprovalRate: Decimal(5,4) with {
        briefly "Approval"
        described as {
          |Overall approval rate.
        }
      }
      avgDecisionTime: Duration with {
        briefly "Avg time"
        described as {
          |Average decision time.
        }
      }
      avgApprovedAmount: Decimal(12,2) with {
        briefly "Avg amount"
        described as {
          |Average approved amount.
        }
      }
    } with {
      briefly "Decision statistics"
      described as {
        |Credit decisioning metrics.
      }
    }
    handler AnalyticsHandler is {
      on event Decision.ApplicationEvaluationStarted is {
        tell event Decision.ApplicationEvaluationStarted to repository
          DecisionContext.DecisionRepository
      }
      on event Decision.DecisionRendered is {
        tell event Decision.DecisionRendered to repository
          DecisionContext.DecisionRepository
      }
      on event Decision.ManuallyApproved is {
        tell event Decision.ManuallyApproved to repository
          DecisionContext.DecisionRepository
      }
      on event Decision.ManuallyDeclined is {
        tell event Decision.ManuallyDeclined to repository
          DecisionContext.DecisionRepository
      }
    } with {
      briefly "Maintains decision analytics"
      described as {
        |Projects events into analytics views.
      }
    }
  } with {
    briefly "Decision analytics projections"
    described as {
      |Maintains credit decisioning analytics data.
    }
  }
  source DecisionEventSource is {
    outlet DecisionEvents is type DecisionEvent
    handler DecisionEventEmitter is {
      on init is {
        tell command InitializeDecision to entity
          DecisionContext.Decision
      }
      on other is { ??? }
      on event Decision.ApplicationEvaluationStarted is {
        send event Decision.ApplicationEvaluationStarted to outlet DecisionEvents
      }
      on event Decision.DecisionRendered is {
        send event Decision.DecisionRendered to outlet DecisionEvents
      }
      on event Decision.ManuallyApproved is {
        send event Decision.ManuallyApproved to outlet DecisionEvents
      }
      on event Decision.ManuallyDeclined is {
        send event Decision.ManuallyDeclined to outlet DecisionEvents
      }
      on event Decision.DecisionOverridden is {
        send event Decision.DecisionOverridden to outlet DecisionEvents
      }
    } with {
      briefly "Decision event emitter"
      described as {
        |Emits decision lifecycle events into the streaming
        |topology.
      }
    }
  } with {
    briefly "Decision event source"
    described as {
      |Publishes decision entity events for streaming.
    }
  }
  sink DecisionEventSink is {
    inlet IncomingDecisionEvents is type DecisionEvent
    handler DecisionEventReceiver is {
      on init is { ??? }
      on other is { ??? }
      on event Decision.ApplicationEvaluationStarted is {
        tell event Decision.ApplicationEvaluationStarted to repository
          DecisionContext.DecisionRepository
      }
      on event Decision.DecisionRendered is {
        tell event Decision.DecisionRendered to repository
          DecisionContext.DecisionRepository
      }
    } with {
      briefly "Decision event receiver"
      described as {
        |Receives decision events and persists them.
      }
    }
  } with {
    briefly "Decision event sink"
    described as {
      |Receives decision events from the streaming topology.
    }
  }
  connector DecisionEventPipeline is {
    from outlet DecisionContext.DecisionEventSource.DecisionEvents
      to inlet DecisionContext.DecisionEventSink.IncomingDecisionEvents
  } with {
    briefly "Decision event pipeline"
    described as {
      |Wires decision events from source to sink.
    }
  }
} with {
  briefly "Bounded context for credit decisioning"
  described as {
    | The DecisionContext is the bounded context for credit
    | evaluation, scoring, and approval decisions.
  }
}
