// Order Management - Order Context
context OrderContext is {
  include "types.riddl"
  include "TradingOrder.riddl"
  // Repository for order persistence
  repository OrderRepository is {
    schema OrderData is relational
      of orders as type TradingOrder
        index on field TradingOrder.orderId
        index on field TradingOrder.details.accountId

    handler OrderPersistence is {
      on command TradingOrder.PlaceOrder is {
        tell event TradingOrder.OrderPlaced to entity
          OrderContext.TradingOrder
      }
      on command TradingOrder.AcknowledgeOrder is {
        tell event TradingOrder.OrderAcknowledged to entity
          OrderContext.TradingOrder
      }
      on command TradingOrder.ReportExecution is {
        tell event TradingOrder.ExecutionReported to entity
          OrderContext.TradingOrder
      }
      on command TradingOrder.FillOrder is {
        tell event TradingOrder.OrderFilled to entity
          OrderContext.TradingOrder
      }
      on command TradingOrder.AmendOrder is {
        tell event TradingOrder.OrderAmended to entity
          OrderContext.TradingOrder
      }
      on command TradingOrder.CancelOrder is {
        tell event TradingOrder.OrderCanceled to entity
          OrderContext.TradingOrder
      }
      on command TradingOrder.RejectOrder is {
        tell event TradingOrder.OrderRejected to entity
          OrderContext.TradingOrder
      }
      on command TradingOrder.ExpireOrder is {
        tell event TradingOrder.OrderExpired to entity
          OrderContext.TradingOrder
      }
      on command TradingOrder.SuspendOrder is {
        tell event TradingOrder.OrderSuspended to entity
          OrderContext.TradingOrder
      }
      on command TradingOrder.ResumeOrder is {
        tell event TradingOrder.OrderResumed to entity
          OrderContext.TradingOrder
      }
    } with {
      briefly "Persists order commands"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Order data persistence"
    described as {
      | The OrderRepository provides persistent storage for
      | trading orders, executions, and status history.
    }
  }
  // Projector for trading analytics
  projector TradingAnalytics is {
    updates repository OrderContext.OrderRepository
    record TradingStats is  {
      totalOrders: Natural with {
        briefly "Orders"
        described as {
          |Total orders.
        }
      }
      totalVolume: Decimal(18,2) with {
        briefly "Volume"
        described as {
          |Total traded value.
        }
      }
      fillRate: Decimal(5,4) with {
        briefly "Fill rate"
        described as {
          |Order fill rate.
        }
      }
      avgFillTime: Duration with {
        briefly "Avg time"
        described as {
          |Average fill time.
        }
      }
      cancelRate: Decimal(5,4) with {
        briefly "Cancel rate"
        described as {
          |Cancellation rate.
        }
      }
      totalCommissions: Decimal(15,2) with {
        briefly "Commissions"
        described as {
          |Total commissions.
        }
      }
    } with {
      briefly "Trading statistics"
      described as {
        |Trading activity metrics.
      }
    }
    handler AnalyticsHandler is {
      on event TradingOrder.OrderPlaced is {
        tell event TradingOrder.OrderPlaced to repository
          OrderContext.OrderRepository
      }
      on event TradingOrder.ExecutionReported is {
        tell event TradingOrder.ExecutionReported to repository
          OrderContext.OrderRepository
      }
      on event TradingOrder.OrderFilled is {
        tell event TradingOrder.OrderFilled to repository
          OrderContext.OrderRepository
      }
      on event TradingOrder.OrderCanceled is {
        tell event TradingOrder.OrderCanceled to repository
          OrderContext.OrderRepository
      }
    } with {
      briefly "Maintains trading analytics"
      described as {
        |Projects events into analytics views.
      }
    }
  } with {
    briefly "Trading analytics projections"
    described as {
      |Maintains trading order analytics data.
    }
  }
  source OrderEventSource is {
    outlet OrderEvents is type TradingOrderEvent
    handler OrderEventEmitter is {
      on init is {
        tell command InitializeTradingOrder to entity
          OrderContext.TradingOrder
      }
      on other is { ??? }
      on event TradingOrder.OrderPlaced is {
        send event TradingOrder.OrderPlaced to outlet OrderEvents
      }
      on event TradingOrder.OrderFilled is {
        send event TradingOrder.OrderFilled to outlet OrderEvents
      }
      on event TradingOrder.OrderCanceled is {
        send event TradingOrder.OrderCanceled to outlet OrderEvents
      }
      on event TradingOrder.OrderExpired is {
        send event TradingOrder.OrderExpired to outlet OrderEvents
      }
    } with {
      briefly "Order event emitter"
      described as {
        |Emits trading order events into the streaming
        |topology.
      }
    }
  } with {
    briefly "Order event source"
    described as {
      |Publishes trading order events for streaming.
    }
  }
  sink OrderEventSink is {
    inlet IncomingOrderEvents is type TradingOrderEvent
    handler OrderEventReceiver is {
      on init is { ??? }
      on other is { ??? }
      on event TradingOrder.OrderPlaced is {
        tell event TradingOrder.OrderPlaced to repository
          OrderContext.OrderRepository
      }
      on event TradingOrder.OrderFilled is {
        tell event TradingOrder.OrderFilled to repository
          OrderContext.OrderRepository
      }
    } with {
      briefly "Order event receiver"
      described as {
        |Receives trading order events and persists them.
      }
    }
  } with {
    briefly "Order event sink"
    described as {
      |Receives trading order events from the streaming topology.
    }
  }
  connector OrderEventPipeline is {
    from outlet OrderContext.OrderEventSource.OrderEvents
      to inlet OrderContext.OrderEventSink.IncomingOrderEvents
  } with {
    briefly "Order event pipeline"
    described as {
      |Wires trading order events from source to sink.
    }
  }
} with {
  briefly "Bounded context for order management"
  described as {
    | The OrderContext is the bounded context for trading
    | order management, execution, and tracking.
  }
}
