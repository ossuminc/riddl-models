// CI/CD Pipeline - Pipeline Context
context PipelineContext is {
  include "types.riddl"
  include "Pipeline.riddl"
  // Repository for pipeline persistence
  repository PipelineRepository is {
    schema PipelineData is relational
      of pipelines as type Pipeline
        index on field Pipeline.pipelineId
        index on field Pipeline.config.repository

    handler PipelinePersistence is {
      on command Pipeline.CreatePipeline is {
        tell event Pipeline.PipelineCreated to entity PipelineContext.Pipeline
      }
      on command Pipeline.StartPipeline is {
        tell event Pipeline.PipelineStarted to entity PipelineContext.Pipeline
      }
      on command Pipeline.CompleteStage is {
        tell event Pipeline.StageCompleted to entity PipelineContext.Pipeline
      }
      on command Pipeline.StoreArtifact is {
        tell event Pipeline.ArtifactStored to entity PipelineContext.Pipeline
      }
      on command Pipeline.RequestApproval is {
        tell event Pipeline.ApprovalRequested to entity PipelineContext.Pipeline
      }
      on command Pipeline.ApproveDeployment is {
        tell event Pipeline.DeploymentApproved to entity PipelineContext.Pipeline
      }
      on command Pipeline.RejectDeployment is {
        tell event Pipeline.DeploymentRejected to entity PipelineContext.Pipeline
      }
      on command Pipeline.CancelPipeline is {
        tell event Pipeline.PipelineCancelled to entity PipelineContext.Pipeline
      }
      on command Pipeline.CompletePipeline is {
        tell event Pipeline.PipelineCompleted to entity PipelineContext.Pipeline
      }
    } with {
      briefly "Persists pipeline commands"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Pipeline data persistence"
    described as {
      | The PipelineRepository provides persistent storage for
      | pipelines, builds, and artifacts.
    }
  }
  // Projector for pipeline analytics
  projector PipelineAnalytics is {
    updates repository PipelineContext.PipelineRepository
    record PipelineStats is  {
      totalPipelines: Natural with {
        briefly "Total"
        described as {
          |Total pipelines.
        }
      }
      totalBuilds: Natural with {
        briefly "Builds"
        described as {
          |Total builds.
        }
      }
      successRate: Decimal(5,4) with {
        briefly "Success rate"
        described as {
          |Build success rate.
        }
      }
      averageDuration: Natural with {
        briefly "Avg duration"
        described as {
          |Average duration seconds.
        }
      }
      deploymentsToday: Natural with {
        briefly "Deployments"
        described as {
          |Deployments today.
        }
      }
    } with {
      briefly "Pipeline statistics"
      described as {
        |CI/CD pipeline metrics.
      }
    }
    handler AnalyticsHandler is {
      on event Pipeline.PipelineStarted is {
        tell event Pipeline.PipelineStarted to repository PipelineContext.PipelineRepository
      }
      on event Pipeline.PipelineCompleted is {
        tell event Pipeline.PipelineCompleted to repository PipelineContext.PipelineRepository
      }
      on event Pipeline.DeploymentApproved is {
        tell event Pipeline.DeploymentApproved to repository PipelineContext.PipelineRepository
      }
    } with {
      briefly "Maintains pipeline analytics"
      described as {
        |Projects events into analytics views.
      }
    }
  } with {
    briefly "Pipeline analytics projections"
    described as {
      |Maintains CI/CD pipeline analytics data.
    }
  }
  // Event streaming infrastructure
  type PipelineEvent is one of {
    PipelineContext.Pipeline.PipelineCreated,
    PipelineContext.Pipeline.PipelineStarted,
    PipelineContext.Pipeline.StageCompleted,
    PipelineContext.Pipeline.PipelineCompleted,
    PipelineContext.Pipeline.PipelineCancelled
  } with {
    briefly "Pipeline events"
    described as {
      |Union of all Pipeline events for streaming.
    }
  }
  source PipelineSource is {
    outlet PipelineEventOutlet is type PipelineEvent with {
      briefly "Event outlet"
      described as {
        |Outlet for Pipeline events.
      }
    }
    handler PipelineSourceHandler is {
      on init is {
        tell command Pipeline.InitializePipeline to entity PipelineContext.Pipeline
      }
      on event Pipeline.PipelineCreated is {
        send event Pipeline.PipelineCreated to outlet PipelineEventOutlet
      }
      on event Pipeline.PipelineStarted is {
        send event Pipeline.PipelineStarted to outlet PipelineEventOutlet
      }
      on event Pipeline.StageCompleted is {
        send event Pipeline.StageCompleted to outlet PipelineEventOutlet
      }
      on event Pipeline.PipelineCompleted is {
        send event Pipeline.PipelineCompleted to outlet PipelineEventOutlet
      }
      on event Pipeline.PipelineCancelled is {
        send event Pipeline.PipelineCancelled to outlet PipelineEventOutlet
      }
      on other is { ??? }
    } with {
      briefly "Source handler"
      described as {
        |Handles Pipeline events for streaming.
      }
    }
  } with {
    briefly "Pipeline event source"
    described as {
      |Publishes Pipeline events to the event stream.
    }
  }
  sink PipelineSink is {
    inlet PipelineEventInlet is type PipelineEvent with {
      briefly "Event inlet"
      described as {
        |Inlet for Pipeline events.
      }
    }
    handler PipelineSinkHandler is {
      on init is { ??? }
      on event Pipeline.PipelineCreated is {
        tell event Pipeline.PipelineCreated to repository PipelineContext.PipelineRepository
      }
      on event Pipeline.PipelineStarted is {
        tell event Pipeline.PipelineStarted to repository PipelineContext.PipelineRepository
      }
      on event Pipeline.StageCompleted is {
        tell event Pipeline.StageCompleted to repository PipelineContext.PipelineRepository
      }
      on event Pipeline.PipelineCompleted is {
        tell event Pipeline.PipelineCompleted to repository PipelineContext.PipelineRepository
      }
      on event Pipeline.PipelineCancelled is {
        tell event Pipeline.PipelineCancelled to repository PipelineContext.PipelineRepository
      }
      on other is { ??? }
    } with {
      briefly "Sink handler"
      described as {
        |Handles incoming Pipeline events for persistence.
      }
    }
  } with {
    briefly "Pipeline event sink"
    described as {
      |Receives Pipeline events for persistence.
    }
  }
  connector PipelineEventFlow is {
    from outlet PipelineContext.PipelineSource.PipelineEventOutlet to
      inlet PipelineContext.PipelineSink.PipelineEventInlet
  } with {
    briefly "Pipeline event connector"
    described as {
      |Wires Pipeline source to sink for event flow.
    }
  }
} with {
  briefly "Bounded context for CI/CD pipelines"
  described as {
    | The PipelineContext is the bounded context for
    | continuous integration and deployment automation.
  }
}
