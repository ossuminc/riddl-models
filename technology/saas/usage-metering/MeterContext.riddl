// Usage Metering - Meter Context
context MeterContext is {
  include "types.riddl"
  include "Meter.riddl"
  // Repository
  repository MeterRepository is {
    query FindMeterById is  {
      meterId: MeterId with {
        briefly "Meter"
        described as {
          |Meter identifier.
        }
      }
    } with {
      briefly "Find meter by ID"
      described as {
        |Retrieves meter by identifier.
      }
    }
    result MeterResult is  {
      meter: Meter.ActiveStateData with {
        briefly "Meter"
        described as {
          |Meter data.
        }
      }
    } with {
      briefly "Meter result"
      described as {
        |Returns meter data.
      }
    }
    query FindByCustomer is  {
      customerId: CustomerId with {
        briefly "Customer"
        described as {
          |Customer identifier.
        }
      }
    } with {
      briefly "Find by customer"
      described as {
        |Finds meters for customer.
      }
    }
    result MetersResult is  {
      meters: Meter.ActiveStateData+ with {
        briefly "Meters"
        described as {
          |Matching meters.
        }
      }
      totalCount: Natural with {
        briefly "Count"
        described as {
          |Total matches.
        }
      }
    } with {
      briefly "Meters result"
      described as {
        |Returns matching meters.
      }
    }
    query FindBySubscription is  {
      subscriptionId: SubscriptionId with {
        briefly "Subscription"
        described as {
          |Subscription identifier.
        }
      }
    } with {
      briefly "Find by subscription"
      described as {
        |Finds meters for subscription.
      }
    }
    query GetCurrentUsage is  {
      meterId: MeterId with {
        briefly "Meter"
        described as {
          |Meter identifier.
        }
      }
    } with {
      briefly "Get current usage"
      described as {
        |Gets current period usage.
      }
    }
    query GetUsageHistory is  {
      meterId: MeterId with {
        briefly "Meter"
        described as {
          |Meter identifier.
        }
      }
      periods: Natural with {
        briefly "Periods"
        described as {
          |Number of periods.
        }
      }
    } with {
      briefly "Get usage history"
      described as {
        |Gets historical usage.
      }
    }
    handler MeterRepositoryHandler is {
      on query FindMeterById is {
        tell result MeterResult to entity MeterContext.Meter
      }
      on query FindByCustomer is {
        tell result MetersResult to entity MeterContext.Meter
      }
      on query FindBySubscription is {
        tell result MetersResult to entity MeterContext.Meter
      }
      on query GetCurrentUsage is {
        tell result MeterResult to entity MeterContext.Meter
      }
      on query GetUsageHistory is {
        tell result MetersResult to entity MeterContext.Meter
      }
    } with {
      briefly "Handles repository queries"
      described as {
        |Processes meter queries.
      }
    }
  } with {
    briefly "Meter repository"
    described as {
      |Persistence for meter records.
    }
  }
  // Projector for usage analytics
  projector UsageAnalytics is {
    updates repository MeterContext.MeterRepository
    record AnalyticsData is  {
      totalEvents: Natural with {
        briefly "Events"
        described as {
          |Total events recorded.
        }
      }
      totalCustomers: Natural with {
        briefly "Customers"
        described as {
          |Total metered customers.
        }
      }
      usageByMetric: MetricUsage+ with {
        briefly "By metric"
        described as {
          |Usage by metric type.
        }
      }
      topCustomers: CustomerUsage+ with {
        briefly "Top customers"
        described as {
          |Highest usage customers.
        }
      }
      alertsTriggered: Natural with {
        briefly "Alerts"
        described as {
          |Alerts triggered today.
        }
      }
    } with {
      briefly "Analytics data"
      described as {
        |Usage analytics.
      }
    }
    record MetricUsage is  {
      metricType: MetricType with {
        briefly "Metric"
        described as {
          |Metric type.
        }
      }
      aggregatedTotalQuantity: Decimal(18,4) with {
        briefly "Total"
        described as {
          |Total usage.
        }
      }
      eventCount: Natural with {
        briefly "Events"
        described as {
          |Event count.
        }
      }
    } with {
      briefly "Metric usage"
      described as {
        |Usage for metric type.
      }
    }
    record CustomerUsage is  {
      customerId: CustomerId with {
        briefly "Customer"
        described as {
          |Customer ID.
        }
      }
      totalUsage: Decimal(14,4) with {
        briefly "Usage"
        described as {
          |Total usage.
        }
      }
      totalAmount: Decimal(12,2) with {
        briefly "Amount"
        described as {
          |Billable amount.
        }
      }
    } with {
      briefly "Customer usage"
      described as {
        |Usage for customer.
      }
    }
    handler AnalyticsHandler is {
      on event Meter.UsageEventRecorded is {
        tell event Meter.UsageEventRecorded to repository MeterContext.MeterRepository
      }
      on event Meter.UsageAggregated is {
        tell event Meter.UsageAggregated to repository MeterContext.MeterRepository
      }
      on event Meter.UsageAlertTriggered is {
        tell event Meter.UsageAlertTriggered to repository MeterContext.MeterRepository
      }
      on event Meter.BillingRecordGenerated is {
        tell event Meter.BillingRecordGenerated to repository MeterContext.MeterRepository
      }
    } with {
      briefly "Processes analytics events"
      described as {
        |Updates usage analytics.
      }
    }
  } with {
    briefly "Usage analytics"
    described as {
      |Projects usage metrics for reporting.
    }
  }
  // Event streaming infrastructure
  type MeterEvent is one of {
    MeterContext.Meter.MeterCreated,
    MeterContext.Meter.UsageEventRecorded,
    MeterContext.Meter.UsageAggregated,
    MeterContext.Meter.BillingRecordGenerated,
    MeterContext.Meter.MeterClosed
  } with {
    briefly "Meter events"
    described as {
      |Union of all Meter events for streaming.
    }
  }
  source MeterSource is {
    outlet MeterEventOutlet is type MeterEvent with {
      briefly "Event outlet"
      described as {
        |Outlet for Meter events.
      }
    }
    handler MeterSourceHandler is {
      on init is {
        tell command Meter.InitializeMeter to entity MeterContext.Meter
      }
      on event Meter.MeterCreated is {
        send event Meter.MeterCreated to outlet MeterEventOutlet
      }
      on event Meter.UsageEventRecorded is {
        send event Meter.UsageEventRecorded to outlet MeterEventOutlet
      }
      on event Meter.UsageAggregated is {
        send event Meter.UsageAggregated to outlet MeterEventOutlet
      }
      on event Meter.BillingRecordGenerated is {
        send event Meter.BillingRecordGenerated to outlet MeterEventOutlet
      }
      on event Meter.MeterClosed is {
        send event Meter.MeterClosed to outlet MeterEventOutlet
      }
      on other is { ??? }
    } with {
      briefly "Source handler"
      described as {
        |Handles Meter events for streaming.
      }
    }
  } with {
    briefly "Meter event source"
    described as {
      |Publishes Meter events to the event stream.
    }
  }
  sink MeterSink is {
    inlet MeterEventInlet is type MeterEvent with {
      briefly "Event inlet"
      described as {
        |Inlet for Meter events.
      }
    }
    handler MeterSinkHandler is {
      on init is { ??? }
      on event Meter.MeterCreated is {
        tell event Meter.MeterCreated to repository MeterContext.MeterRepository
      }
      on event Meter.UsageEventRecorded is {
        tell event Meter.UsageEventRecorded to repository MeterContext.MeterRepository
      }
      on event Meter.UsageAggregated is {
        tell event Meter.UsageAggregated to repository MeterContext.MeterRepository
      }
      on event Meter.BillingRecordGenerated is {
        tell event Meter.BillingRecordGenerated to repository MeterContext.MeterRepository
      }
      on event Meter.MeterClosed is {
        tell event Meter.MeterClosed to repository MeterContext.MeterRepository
      }
      on other is { ??? }
    } with {
      briefly "Sink handler"
      described as {
        |Handles incoming Meter events for persistence.
      }
    }
  } with {
    briefly "Meter event sink"
    described as {
      |Receives Meter events for persistence.
    }
  }
  connector MeterEventFlow is {
    from outlet MeterContext.MeterSource.MeterEventOutlet to
      inlet MeterContext.MeterSink.MeterEventInlet
  } with {
    briefly "Meter event connector"
    described as {
      |Wires Meter source to sink for event flow.
    }
  }
} with {
  briefly "Meter context"
  described as {
    | The Meter context manages usage metering
    | for SaaS applications.
  }
}
