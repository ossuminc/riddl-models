// Tenant Provisioning - Tenant Context
context TenantContext is {
  include "types.riddl"
  include "Tenant.riddl"
  // Repository for tenant persistence
  repository TenantRepository is {
    schema TenantData is relational
      of tenants as type Tenant
        index on field Tenant.tenantId
        index on field Tenant.organization.domain

    handler TenantPersistence is {
      on command Tenant.CreateTenant is {
        tell event Tenant.TenantCreated to entity TenantContext.Tenant
      }
      on command Tenant.ConfigureTenant is {
        tell event Tenant.TenantConfigured to entity TenantContext.Tenant
      }
      on command Tenant.ProvisionResource is {
        tell event Tenant.ResourceProvisioned to entity TenantContext.Tenant
      }
      on command Tenant.ScaleResource is {
        tell event Tenant.ResourceScaled to entity TenantContext.Tenant
      }
      on command Tenant.UpgradeTier is {
        tell event Tenant.TierUpgraded to entity TenantContext.Tenant
      }
      on command Tenant.SuspendTenant is {
        tell event Tenant.TenantSuspended to entity TenantContext.Tenant
      }
      on command Tenant.ReactivateTenant is {
        tell event Tenant.TenantReactivated to entity TenantContext.Tenant
      }
      on command Tenant.DecommissionTenant is {
        tell event Tenant.TenantDecommissioned to entity TenantContext.Tenant
      }
    } with {
      briefly "Persists tenant commands"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Tenant data persistence"
    described as {
      | The TenantRepository provides persistent storage for
      | tenants, configuration, and resources.
    }
  }
  // Projector for tenant analytics
  projector TenantAnalytics is {
    updates repository TenantContext.TenantRepository
    record TenantStats is  {
      totalTenants: Natural with {
        briefly "Total"
        described as {
          |Total tenants.
        }
      }
      activeTenants: Natural with {
        briefly "Active"
        described as {
          |Active tenants.
        }
      }
      tenantsByTier: String(1,100)+ with {
        briefly "By tier"
        described as {
          |Counts by tier.
        }
      }
      averageResourcesPerTenant: Decimal(5,2) with {
        briefly "Avg resources"
        described as {
          |Average resources.
        }
      }
      provisioningSuccessRate: Decimal(5,4) with {
        briefly "Success rate"
        described as {
          |Provisioning success.
        }
      }
    } with {
      briefly "Tenant statistics"
      described as {
        |Platform tenant metrics.
      }
    }
    handler AnalyticsHandler is {
      on event Tenant.TenantCreated is {
        tell event Tenant.TenantCreated to repository TenantContext.TenantRepository
      }
      on event Tenant.ResourceProvisioned is {
        tell event Tenant.ResourceProvisioned to repository TenantContext.TenantRepository
      }
      on event Tenant.TierUpgraded is {
        tell event Tenant.TierUpgraded to repository TenantContext.TenantRepository
      }
      on event Tenant.TenantDecommissioned is {
        tell event Tenant.TenantDecommissioned to repository TenantContext.TenantRepository
      }
    } with {
      briefly "Maintains tenant analytics"
      described as {
        |Projects events into analytics views.
      }
    }
  } with {
    briefly "Tenant analytics projections"
    described as {
      |Maintains platform tenant analytics data.
    }
  }
  // Event streaming infrastructure
  type TenantEvent is one of {
    TenantContext.Tenant.TenantCreated,
    TenantContext.Tenant.TenantConfigured,
    TenantContext.Tenant.ResourceProvisioned,
    TenantContext.Tenant.ResourceScaled,
    TenantContext.Tenant.TenantDecommissioned
  } with {
    briefly "Tenant events"
    described as {
      |Union of all Tenant events for streaming.
    }
  }
  source TenantSource is {
    outlet TenantEventOutlet is type TenantEvent with {
      briefly "Event outlet"
      described as {
        |Outlet for Tenant events.
      }
    }
    handler TenantSourceHandler is {
      on init is {
        tell command Tenant.InitializeTenant to entity TenantContext.Tenant
      }
      on event Tenant.TenantCreated is {
        send event Tenant.TenantCreated to outlet TenantEventOutlet
      }
      on event Tenant.TenantConfigured is {
        send event Tenant.TenantConfigured to outlet TenantEventOutlet
      }
      on event Tenant.ResourceProvisioned is {
        send event Tenant.ResourceProvisioned to outlet TenantEventOutlet
      }
      on event Tenant.ResourceScaled is {
        send event Tenant.ResourceScaled to outlet TenantEventOutlet
      }
      on event Tenant.TenantDecommissioned is {
        send event Tenant.TenantDecommissioned to outlet TenantEventOutlet
      }
      on other is { ??? }
    } with {
      briefly "Source handler"
      described as {
        |Handles Tenant events for streaming.
      }
    }
  } with {
    briefly "Tenant event source"
    described as {
      |Publishes Tenant events to the event stream.
    }
  }
  sink TenantSink is {
    inlet TenantEventInlet is type TenantEvent with {
      briefly "Event inlet"
      described as {
        |Inlet for Tenant events.
      }
    }
    handler TenantSinkHandler is {
      on init is { ??? }
      on event Tenant.TenantCreated is {
        tell event Tenant.TenantCreated to repository TenantContext.TenantRepository
      }
      on event Tenant.TenantConfigured is {
        tell event Tenant.TenantConfigured to repository TenantContext.TenantRepository
      }
      on event Tenant.ResourceProvisioned is {
        tell event Tenant.ResourceProvisioned to repository TenantContext.TenantRepository
      }
      on event Tenant.ResourceScaled is {
        tell event Tenant.ResourceScaled to repository TenantContext.TenantRepository
      }
      on event Tenant.TenantDecommissioned is {
        tell event Tenant.TenantDecommissioned to repository TenantContext.TenantRepository
      }
      on other is { ??? }
    } with {
      briefly "Sink handler"
      described as {
        |Handles incoming Tenant events for persistence.
      }
    }
  } with {
    briefly "Tenant event sink"
    described as {
      |Receives Tenant events for persistence.
    }
  }
  connector TenantEventFlow is {
    from outlet TenantContext.TenantSource.TenantEventOutlet to
      inlet TenantContext.TenantSink.TenantEventInlet
  } with {
    briefly "Tenant event connector"
    described as {
      |Wires Tenant source to sink for event flow.
    }
  }
} with {
  briefly "Bounded context for tenant provisioning"
  described as {
    | The TenantContext is the bounded context for
    | multi-tenant SaaS provisioning and management.
  }
}
