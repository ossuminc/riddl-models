// Multi-Tenant Management - Tenant Context
context TenantContext is {
  include "types.riddl"
  include "Tenant.riddl"
  repository TenantRepository is {
    schema TenantData is relational
      of tenants as type Tenant
        index on field Tenant.tenantId
        index on field Tenant.tenantInfo.subdomain
        index on field Tenant.status
        index on field Tenant.tenantInfo.tier

    handler TenantPersistence is {
      on command Tenant.ProvisionTenant is {
        tell event Tenant.TenantProvisioned to entity TenantContext.Tenant
      }
      on command Tenant.ActivateTenant is {
        tell event Tenant.TenantActivated to entity TenantContext.Tenant
      }
      on command Tenant.UpdateSettings is {
        tell event Tenant.SettingsUpdated to entity TenantContext.Tenant
      }
      on command Tenant.AddUser is {
        tell event Tenant.UserAdded to entity TenantContext.Tenant
      }
      on command Tenant.RecordUsage is {
        tell event Tenant.UsageRecorded to entity TenantContext.Tenant
      }
      on command Tenant.DeactivateTenant is {
        tell event Tenant.TenantDeactivated to entity TenantContext.Tenant
      }
    } with {
      briefly "Persists tenant commands"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Tenant data persistence"
    described as {
      |Persistent storage for tenants.
    }
  }
  projector PlatformAnalytics is {
    updates repository TenantContext.TenantRepository
    record PlatformMetrics is  {
      totalTenants: Natural with {
        briefly "Total"
        described as {
          |Total tenants.
        }
      }
      activeTenants: Natural with {
        briefly "Active"
        described as {
          |Active tenants.
        }
      }
      totalUsers: Natural with {
        briefly "Users"
        described as {
          |Total users.
        }
      }
      totalStorageGB: Decimal(15,2) with {
        briefly "Storage"
        described as {
          |Total storage.
        }
      }
      mrr: Decimal(15,2) with {
        briefly "MRR"
        described as {
          |Monthly recurring revenue.
        }
      }
    } with {
      briefly "Platform metrics"
      described as {
        |Platform-wide metrics.
      }
    }
    handler AnalyticsHandler is {
      on event Tenant.TenantProvisioned is {
        tell event Tenant.TenantProvisioned to repository TenantContext.TenantRepository
      }
      on event Tenant.UserAdded is {
        tell event Tenant.UserAdded to repository TenantContext.TenantRepository
      }
      on event Tenant.UsageRecorded is {
        tell event Tenant.UsageRecorded to repository TenantContext.TenantRepository
      }
      on event Tenant.TierChanged is {
        tell event Tenant.TierChanged to repository TenantContext.TenantRepository
      }
    } with {
      briefly "Maintains platform analytics"
      described as {
        |Projects events into analytics.
      }
    }
  } with {
    briefly "Platform analytics"
    described as {
      |Multi-tenant platform metrics.
    }
  }
  // Event streaming infrastructure
  type TenantEvent is one of {
    TenantContext.Tenant.TenantProvisioned,
    TenantContext.Tenant.TenantActivated,
    TenantContext.Tenant.SettingsUpdated,
    TenantContext.Tenant.UserAdded,
    TenantContext.Tenant.TenantDeactivated
  } with {
    briefly "Tenant events"
    described as {
      |Union of all Tenant events for streaming.
    }
  }
  source TenantSource is {
    outlet TenantEventOutlet is type TenantEvent with {
      briefly "Event outlet"
      described as {
        |Outlet for Tenant events.
      }
    }
    handler TenantSourceHandler is {
      on init is {
        tell command Tenant.InitializeTenant to entity TenantContext.Tenant
      }
      on event Tenant.TenantProvisioned is {
        send event Tenant.TenantProvisioned to outlet TenantEventOutlet
      }
      on event Tenant.TenantActivated is {
        send event Tenant.TenantActivated to outlet TenantEventOutlet
      }
      on event Tenant.SettingsUpdated is {
        send event Tenant.SettingsUpdated to outlet TenantEventOutlet
      }
      on event Tenant.UserAdded is {
        send event Tenant.UserAdded to outlet TenantEventOutlet
      }
      on event Tenant.TenantDeactivated is {
        send event Tenant.TenantDeactivated to outlet TenantEventOutlet
      }
      on other is { ??? }
    } with {
      briefly "Source handler"
      described as {
        |Handles Tenant events for streaming.
      }
    }
  } with {
    briefly "Tenant event source"
    described as {
      |Publishes Tenant events to the event stream.
    }
  }
  sink TenantSink is {
    inlet TenantEventInlet is type TenantEvent with {
      briefly "Event inlet"
      described as {
        |Inlet for Tenant events.
      }
    }
    handler TenantSinkHandler is {
      on init is { ??? }
      on event Tenant.TenantProvisioned is {
        tell event Tenant.TenantProvisioned to repository TenantContext.TenantRepository
      }
      on event Tenant.TenantActivated is {
        tell event Tenant.TenantActivated to repository TenantContext.TenantRepository
      }
      on event Tenant.SettingsUpdated is {
        tell event Tenant.SettingsUpdated to repository TenantContext.TenantRepository
      }
      on event Tenant.UserAdded is {
        tell event Tenant.UserAdded to repository TenantContext.TenantRepository
      }
      on event Tenant.TenantDeactivated is {
        tell event Tenant.TenantDeactivated to repository TenantContext.TenantRepository
      }
      on other is { ??? }
    } with {
      briefly "Sink handler"
      described as {
        |Handles incoming Tenant events for persistence.
      }
    }
  } with {
    briefly "Tenant event sink"
    described as {
      |Receives Tenant events for persistence.
    }
  }
  connector TenantEventFlow is {
    from outlet TenantContext.TenantSource.TenantEventOutlet to
      inlet TenantContext.TenantSink.TenantEventInlet
  } with {
    briefly "Tenant event connector"
    described as {
      |Wires Tenant source to sink for event flow.
    }
  }
} with {
  briefly "Bounded context for multi-tenant management"
  described as {
    |SaaS multi-tenancy context.
  }
}
