// Last Mile Delivery - Delivery Context
context DeliveryContext is {
  include "types.riddl"
  include "Delivery.riddl"
  repository DeliveryRepository is {
    schema DeliveryData is relational
      of deliveries as type Delivery
        index on field Delivery.packageInfo.trackingNumber
        index on field Delivery.status
        index on field Delivery.routeId
        index on field Delivery.address.postalCode

    handler DeliveryPersistence is {
      on command Delivery.CreateDelivery is {
        tell event Delivery.DeliveryCreated to entity DeliveryContext.Delivery
      }
      on command Delivery.AssignToRoute is {
        tell event Delivery.AssignedToRoute to entity DeliveryContext.Delivery
      }
      on command Delivery.MarkOutForDelivery is {
        tell event Delivery.MarkedOutForDelivery to entity DeliveryContext.Delivery
      }
      on command Delivery.UpdateETA is {
        tell event Delivery.ETAUpdated to entity DeliveryContext.Delivery
      }
      on command Delivery.AttemptDelivery is {
        tell event Delivery.DeliveryAttempted to entity DeliveryContext.Delivery
      }
      on command Delivery.CompleteDelivery is {
        tell event Delivery.DeliveryCompleted to entity DeliveryContext.Delivery
      }
      on command Delivery.FailDelivery is {
        tell event Delivery.DeliveryFailed to entity DeliveryContext.Delivery
      }
      on command Delivery.RescheduleDelivery is {
        tell event Delivery.DeliveryRescheduled to entity DeliveryContext.Delivery
      }
    } with {
      briefly "Persists delivery commands"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Delivery data persistence"
    described as {
      |Persistent storage for deliveries.
    }
  }
  projector DeliveryAnalytics is {
    updates repository DeliveryContext.DeliveryRepository
    record DailyMetrics is  {
      totalDeliveries: Natural with {
        briefly "Total"
        described as {
          |Total deliveries.
        }
      }
      completed: Natural with {
        briefly "Completed"
        described as {
          |Completed.
        }
      }
      failed: Natural with {
        briefly "Failed"
        described as {
          |Failed.
        }
      }
      onTimeRate: Decimal(5,2) with {
        briefly "On-time"
        described as {
          |On-time rate.
        }
      }
      averageAttemptsPerDelivery: Decimal(3,2) with {
        briefly "Attempts"
        described as {
          |Avg attempts.
        }
      }
      firstAttemptSuccessRate: Decimal(5,2) with {
        briefly "First attempt"
        described as {
          |First attempt success.
        }
      }
    } with {
      briefly "Daily metrics"
      described as {
        |Daily delivery metrics.
      }
    }
    handler AnalyticsHandler is {
      on event Delivery.DeliveryCreated is {
        tell event Delivery.DeliveryCreated to repository DeliveryContext.DeliveryRepository
      }
      on event Delivery.DeliveryCompleted is {
        tell event Delivery.DeliveryCompleted to repository DeliveryContext.DeliveryRepository
      }
      on event Delivery.DeliveryFailed is {
        tell event Delivery.DeliveryFailed to repository DeliveryContext.DeliveryRepository
      }
      on event Delivery.DeliveryAttempted is {
        tell event Delivery.DeliveryAttempted to repository DeliveryContext.DeliveryRepository
      }
    } with {
      briefly "Maintains delivery analytics"
      described as {
        |Projects events into metrics.
      }
    }
  } with {
    briefly "Delivery analytics"
    described as {
      |Delivery performance tracking.
    }
  }
  type DeliveryEvent is one of {
    DeliveryContext.Delivery.DeliveryCreated,
    DeliveryContext.Delivery.DeliveryCompleted,
    DeliveryContext.Delivery.DeliveryFailed
  } with {
    briefly "Delivery event union"
    described as {
      |Union of Delivery events for streaming.
    }
  }
  source DeliveryEventSource is {
    outlet DeliveryEvents is type DeliveryEvent
    handler DeliveryEventEmitter is {
      on init is { tell command Delivery.InitializeDelivery to entity DeliveryContext.Delivery }
      on other is { ??? }
      on event Delivery.DeliveryCreated is {
        send event Delivery.DeliveryCreated to outlet DeliveryEvents
      }
      on event Delivery.DeliveryCompleted is {
        send event Delivery.DeliveryCompleted to outlet DeliveryEvents
      }
      on event Delivery.DeliveryFailed is {
        send event Delivery.DeliveryFailed to outlet DeliveryEvents
      }
    } with {
      briefly "Event emitter"
      described as {
        |Emits Delivery events to the stream.
      }
    }
  } with {
    briefly "Delivery event source"
    described as {
      |Publishes Delivery events to the event stream.
    }
  }
  sink DeliveryEventSink is {
    inlet IncomingDeliveryEvents is type DeliveryEvent
    handler DeliveryEventReceiver is {
      on init is { ??? }
      on other is { ??? }
      on event Delivery.DeliveryCreated is {
        tell event Delivery.DeliveryCreated to repository DeliveryContext.DeliveryRepository
      }
      on event Delivery.DeliveryCompleted is {
        tell event Delivery.DeliveryCompleted to repository DeliveryContext.DeliveryRepository
      }
      on event Delivery.DeliveryFailed is {
        tell event Delivery.DeliveryFailed to repository DeliveryContext.DeliveryRepository
      }
    } with {
      briefly "Event receiver"
      described as {
        |Receives Delivery events for persistence.
      }
    }
  } with {
    briefly "Delivery event sink"
    described as {
      |Receives Delivery events from streaming.
    }
  }
  connector DeliveryEventPipeline is {
    from outlet DeliveryContext.DeliveryEventSource.DeliveryEvents to inlet DeliveryContext.DeliveryEventSink.IncomingDeliveryEvents
  } with {
    briefly "Delivery event pipeline"
    described as {
      |Wires Delivery event source to sink.
    }
  }
} with {
  briefly "Bounded context for last mile delivery"
  described as {
    |Final delivery operations context.
  }
}
