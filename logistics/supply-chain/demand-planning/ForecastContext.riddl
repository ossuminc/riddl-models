// Demand Planning - Forecast Context
context ForecastContext is {
  include "types.riddl"
  include "Forecast.riddl"
  repository ForecastRepository is {
    schema ForecastData is relational
      of forecasts as type Forecast
        index on field Forecast.status
        index on field Forecast.horizon.startDate
        index on field Forecast.method

    handler ForecastPersistence is {
      on command Forecast.CreateForecast is {
        tell event Forecast.ForecastCreated to entity ForecastContext.Forecast
      }
      on command Forecast.GenerateStatisticalForecast is {
        tell event Forecast.StatisticalForecastGenerated to entity ForecastContext.Forecast
      }
      on command Forecast.AddLocationForecast is {
        tell event Forecast.LocationForecastAdded to entity ForecastContext.Forecast
      }
      on command Forecast.AdjustForecast is {
        tell event Forecast.ForecastAdjusted to entity ForecastContext.Forecast
      }
      on command Forecast.AddConsensusInput is {
        tell event Forecast.ConsensusInputAdded to entity ForecastContext.Forecast
      }
      on command Forecast.ApproveForecast is {
        tell event Forecast.ForecastApproved to entity ForecastContext.Forecast
      }
      on command Forecast.ActivateForecast is {
        tell event Forecast.ForecastActivated to entity ForecastContext.Forecast
      }
      on command Forecast.CalculateAccuracy is {
        tell event Forecast.AccuracyCalculated to entity ForecastContext.Forecast
      }
      on command Forecast.ArchiveForecast is {
        tell event Forecast.ForecastArchived to entity ForecastContext.Forecast
      }
    } with {
      briefly "Persists forecast commands"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Forecast data persistence"
    described as {
      |Persistent storage for forecasts.
    }
  }
  projector ForecastAnalytics is {
    updates repository ForecastContext.ForecastRepository
    record PlanningMetrics is  {
      activeForecastCount: Natural with {
        briefly "Active"
        described as {
          |Active forecasts.
        }
      }
      averageMAPE: Decimal(5,2) with {
        briefly "Avg MAPE"
        described as {
          |Average MAPE.
        }
      }
      bestPerformingMethod: String(1,50) with {
        briefly "Best method"
        described as {
          |Best method.
        }
      }
      totalAdjustmentCount: Natural with {
        briefly "Adjustments"
        described as {
          |Total adjustments.
        }
      }
      consensusAccuracy: Decimal(5,2) with {
        briefly "Consensus"
        described as {
          |Consensus accuracy.
        }
      }
    } with {
      briefly "Planning metrics"
      described as {
        |Demand planning metrics.
      }
    }
    handler AnalyticsHandler is {
      on event Forecast.ForecastCreated is {
        tell event Forecast.ForecastCreated to repository ForecastContext.ForecastRepository
      }
      on event Forecast.ForecastActivated is {
        tell event Forecast.ForecastActivated to repository ForecastContext.ForecastRepository
      }
      on event Forecast.AccuracyCalculated is {
        tell event Forecast.AccuracyCalculated to repository ForecastContext.ForecastRepository
      }
      on event Forecast.ForecastAdjusted is {
        tell event Forecast.ForecastAdjusted to repository ForecastContext.ForecastRepository
      }
    } with {
      briefly "Maintains planning analytics"
      described as {
        |Projects events into metrics.
      }
    }
  } with {
    briefly "Forecast analytics"
    described as {
      |Demand planning performance.
    }
  }
  type ForecastEvent is one of {
    ForecastContext.Forecast.ForecastCreated,
    ForecastContext.Forecast.ForecastActivated,
    ForecastContext.Forecast.ForecastArchived
  } with {
    briefly "Forecast event union"
    described as {
      |Union of Forecast events for streaming.
    }
  }
  source ForecastEventSource is {
    outlet ForecastEvents is type ForecastEvent
    handler ForecastEventEmitter is {
      on init is { tell command Forecast.InitializeForecast to entity ForecastContext.Forecast }
      on other is { ??? }
      on event Forecast.ForecastCreated is {
        send event Forecast.ForecastCreated to outlet ForecastEvents
      }
      on event Forecast.ForecastActivated is {
        send event Forecast.ForecastActivated to outlet ForecastEvents
      }
      on event Forecast.ForecastArchived is {
        send event Forecast.ForecastArchived to outlet ForecastEvents
      }
    } with {
      briefly "Event emitter"
      described as {
        |Emits Forecast events to the stream.
      }
    }
  } with {
    briefly "Forecast event source"
    described as {
      |Publishes Forecast events to the event stream.
    }
  }
  sink ForecastEventSink is {
    inlet IncomingForecastEvents is type ForecastEvent
    handler ForecastEventReceiver is {
      on init is { ??? }
      on other is { ??? }
      on event Forecast.ForecastCreated is {
        tell event Forecast.ForecastCreated to repository ForecastContext.ForecastRepository
      }
      on event Forecast.ForecastActivated is {
        tell event Forecast.ForecastActivated to repository ForecastContext.ForecastRepository
      }
      on event Forecast.ForecastArchived is {
        tell event Forecast.ForecastArchived to repository ForecastContext.ForecastRepository
      }
    } with {
      briefly "Event receiver"
      described as {
        |Receives Forecast events for persistence.
      }
    }
  } with {
    briefly "Forecast event sink"
    described as {
      |Receives Forecast events from streaming.
    }
  }
  connector ForecastEventPipeline is {
    from outlet ForecastContext.ForecastEventSource.ForecastEvents to inlet ForecastContext.ForecastEventSink.IncomingForecastEvents
  } with {
    briefly "Forecast event pipeline"
    described as {
      |Wires Forecast event source to sink.
    }
  }
} with {
  briefly "Bounded context for demand planning"
  described as {
    |Demand forecasting context.
  }
}
