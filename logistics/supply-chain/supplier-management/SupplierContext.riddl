// Supplier Management - Supplier Context
context SupplierContext is {
  include "types.riddl"
  include "Supplier.riddl"
  repository SupplierRepository is {
    schema SupplierData is relational
      of suppliers as type Supplier
        index on field Supplier.supplierId
        index on field Supplier.supplierInfo.category
        index on field Supplier.status

    handler SupplierPersistence is {
      on command Supplier.RegisterSupplier is {
        tell event Supplier.SupplierRegistered to entity SupplierContext.Supplier
      }
      on command Supplier.QualifySupplier is {
        tell event Supplier.SupplierQualified to entity SupplierContext.Supplier
      }
      on command Supplier.ActivateSupplier is {
        tell event Supplier.SupplierActivated to entity SupplierContext.Supplier
      }
      on command Supplier.AssignContract is {
        tell event Supplier.ContractAssigned to entity SupplierContext.Supplier
      }
      on command Supplier.RecordPerformance is {
        tell event Supplier.PerformanceRecorded to entity SupplierContext.Supplier
      }
      on command Supplier.AddCertification is {
        tell event Supplier.CertificationAdded to entity SupplierContext.Supplier
      }
      on command Supplier.AssessRisk is {
        tell event Supplier.RiskAssessed to entity SupplierContext.Supplier
      }
      on command Supplier.SuspendSupplier is {
        tell event Supplier.SupplierSuspended to entity SupplierContext.Supplier
      }
      on command Supplier.DisqualifySupplier is {
        tell event Supplier.SupplierDisqualified to entity SupplierContext.Supplier
      }
      on command Supplier.ReinstateSupplier is {
        tell event Supplier.SupplierReinstated to entity SupplierContext.Supplier
      }
    } with {
      briefly "Persists supplier commands"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Supplier data persistence"
    described as {
      |Persistent storage for suppliers.
    }
  }
  projector SupplierMetrics is {
    updates repository SupplierContext.SupplierRepository
    record SupplierDashboard is  {
      totalSuppliers: Natural with {
        briefly "Total"
        described as {
          |Total registered suppliers.
        }
      }
      activeSuppliers: Natural with {
        briefly "Active"
        described as {
          |Active suppliers.
        }
      }
      suspendedSuppliers: Natural with {
        briefly "Suspended"
        described as {
          |Suspended suppliers.
        }
      }
      averagePerformance: Decimal(5,2) with {
        briefly "Avg score"
        described as {
          |Average performance score.
        }
      }
      highRiskCount: Natural with {
        briefly "High risk"
        described as {
          |High risk suppliers.
        }
      }
    } with {
      briefly "Supplier dashboard"
      described as {
        |Supplier management dashboard metrics.
      }
    }
    handler MetricsHandler is {
      on event Supplier.SupplierRegistered is {
        tell event Supplier.SupplierRegistered to repository SupplierContext.SupplierRepository
      }
      on event Supplier.SupplierActivated is {
        tell event Supplier.SupplierActivated to repository SupplierContext.SupplierRepository
      }
      on event Supplier.PerformanceRecorded is {
        tell event Supplier.PerformanceRecorded to repository SupplierContext.SupplierRepository
      }
      on event Supplier.RiskAssessed is {
        tell event Supplier.RiskAssessed to repository SupplierContext.SupplierRepository
      }
      on event Supplier.SupplierSuspended is {
        tell event Supplier.SupplierSuspended to repository SupplierContext.SupplierRepository
      }
      on event Supplier.SupplierDisqualified is {
        tell event Supplier.SupplierDisqualified to repository SupplierContext.SupplierRepository
      }
    } with {
      briefly "Maintains supplier metrics"
      described as {
        |Projects events into dashboard metrics.
      }
    }
  } with {
    briefly "Supplier metrics"
    described as {
      |Supplier management analytics and dashboard.
    }
  }
  type SupplierEvent is one of {
    SupplierContext.Supplier.SupplierRegistered,
    SupplierContext.Supplier.SupplierActivated,
    SupplierContext.Supplier.SupplierDisqualified
  } with {
    briefly "Supplier event union"
    described as {
      |Union of Supplier events for streaming.
    }
  }
  source SupplierEventSource is {
    outlet SupplierEvents is type SupplierEvent
    handler SupplierEventEmitter is {
      on init is { tell command Supplier.InitializeSupplier to entity SupplierContext.Supplier }
      on other is { ??? }
      on event Supplier.SupplierRegistered is {
        send event Supplier.SupplierRegistered to outlet SupplierEvents
      }
      on event Supplier.SupplierActivated is {
        send event Supplier.SupplierActivated to outlet SupplierEvents
      }
      on event Supplier.SupplierDisqualified is {
        send event Supplier.SupplierDisqualified to outlet SupplierEvents
      }
    } with {
      briefly "Event emitter"
      described as {
        |Emits Supplier events to the stream.
      }
    }
  } with {
    briefly "Supplier event source"
    described as {
      |Publishes Supplier events to the event stream.
    }
  }
  sink SupplierEventSink is {
    inlet IncomingSupplierEvents is type SupplierEvent
    handler SupplierEventReceiver is {
      on init is { ??? }
      on other is { ??? }
      on event Supplier.SupplierRegistered is {
        tell event Supplier.SupplierRegistered to repository SupplierContext.SupplierRepository
      }
      on event Supplier.SupplierActivated is {
        tell event Supplier.SupplierActivated to repository SupplierContext.SupplierRepository
      }
      on event Supplier.SupplierDisqualified is {
        tell event Supplier.SupplierDisqualified to repository SupplierContext.SupplierRepository
      }
    } with {
      briefly "Event receiver"
      described as {
        |Receives Supplier events for persistence.
      }
    }
  } with {
    briefly "Supplier event sink"
    described as {
      |Receives Supplier events from streaming.
    }
  }
  connector SupplierEventPipeline is {
    from outlet SupplierContext.SupplierEventSource.SupplierEvents to inlet SupplierContext.SupplierEventSink.IncomingSupplierEvents
  } with {
    briefly "Supplier event pipeline"
    described as {
      |Wires Supplier event source to sink.
    }
  }
} with {
  briefly "Bounded context for supplier management"
  described as {
    |Supplier lifecycle and relationship management context.
  }
}
