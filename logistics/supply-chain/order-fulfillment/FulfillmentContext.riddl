// Order Fulfillment - Fulfillment Context
context FulfillmentContext is {
  include "types.riddl"
  include "FulfillmentOrder.riddl"
  repository FulfillmentRepository is {
    schema FulfillmentData is relational
      of orders as type FulfillmentOrder
        index on field FulfillmentOrder.orderId
        index on field FulfillmentOrder.salesOrderId
        index on field FulfillmentOrder.status
        index on field FulfillmentOrder.warehouseId

    handler FulfillmentPersistence is {
      on command FulfillmentOrder.CreateOrder is {
        tell event FulfillmentOrder.OrderCreated to entity FulfillmentContext.FulfillmentOrder
      }
      on command FulfillmentOrder.AllocateInventory is {
        tell event FulfillmentOrder.InventoryAllocated to entity FulfillmentContext.FulfillmentOrder
      }
      on command FulfillmentOrder.RecordPick is {
        tell event FulfillmentOrder.ItemPicked to entity FulfillmentContext.FulfillmentOrder
      }
      on command FulfillmentOrder.PackOrder is {
        tell event FulfillmentOrder.OrderPacked to entity FulfillmentContext.FulfillmentOrder
      }
      on command FulfillmentOrder.ShipOrder is {
        tell event FulfillmentOrder.OrderShipped to entity FulfillmentContext.FulfillmentOrder
      }
      on command FulfillmentOrder.ConfirmDelivery is {
        tell event FulfillmentOrder.DeliveryConfirmed to entity FulfillmentContext.FulfillmentOrder
      }
    } with {
      briefly "Persists fulfillment commands"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Fulfillment data persistence"
    described as {
      |Persistent storage for orders.
    }
  }
  projector FulfillmentMetrics is {
    updates repository FulfillmentContext.FulfillmentRepository
    record WarehouseMetrics is  {
      warehouseId: WarehouseId with {
        briefly "Warehouse"
        described as {
          |Warehouse ID.
        }
      }
      ordersProcessed: Natural with {
        briefly "Processed"
        described as {
          |Orders processed.
        }
      }
      ordersShipped: Natural with {
        briefly "Shipped"
        described as {
          |Orders shipped.
        }
      }
      avgFulfillmentTime: Decimal(6,2) with {
        briefly "Avg time"
        described as {
          |Avg fulfillment hours.
        }
      }
      onTimeRate: Decimal(5,2) with {
        briefly "On time"
        described as {
          |On-time percentage.
        }
      }
      pickAccuracy: Decimal(5,2) with {
        briefly "Accuracy"
        described as {
          |Pick accuracy pct.
        }
      }
    } with {
      briefly "Warehouse metrics"
      described as {
        |Fulfillment metrics by warehouse.
      }
    }
    handler MetricsHandler is {
      on event FulfillmentOrder.OrderCreated is {
        tell event FulfillmentOrder.OrderCreated to repository FulfillmentContext.FulfillmentRepository
      }
      on event FulfillmentOrder.OrderShipped is {
        tell event FulfillmentOrder.OrderShipped to repository FulfillmentContext.FulfillmentRepository
      }
      on event FulfillmentOrder.DeliveryConfirmed is {
        tell event FulfillmentOrder.DeliveryConfirmed to repository FulfillmentContext.FulfillmentRepository
      }
    } with {
      briefly "Maintains fulfillment metrics"
      described as {
        |Projects events into metrics.
      }
    }
  } with {
    briefly "Fulfillment metrics"
    described as {
      |Order fulfillment analytics.
    }
  }
  type FulfillmentOrderEvent is one of {
    FulfillmentContext.FulfillmentOrder.OrderCreated,
    FulfillmentContext.FulfillmentOrder.OrderShipped,
    FulfillmentContext.FulfillmentOrder.DeliveryConfirmed
  } with {
    briefly "FulfillmentOrder event union"
    described as {
      |Union of FulfillmentOrder events for streaming.
    }
  }
  source FulfillmentOrderEventSource is {
    outlet FulfillmentOrderEvents is type FulfillmentOrderEvent
    handler FulfillmentOrderEventEmitter is {
      on init is { tell command FulfillmentOrder.InitializeFulfillmentOrder to entity FulfillmentContext.FulfillmentOrder }
      on other is { ??? }
      on event FulfillmentOrder.OrderCreated is {
        send event FulfillmentOrder.OrderCreated to outlet FulfillmentOrderEvents
      }
      on event FulfillmentOrder.OrderShipped is {
        send event FulfillmentOrder.OrderShipped to outlet FulfillmentOrderEvents
      }
      on event FulfillmentOrder.DeliveryConfirmed is {
        send event FulfillmentOrder.DeliveryConfirmed to outlet FulfillmentOrderEvents
      }
    } with {
      briefly "Event emitter"
      described as {
        |Emits FulfillmentOrder events to the stream.
      }
    }
  } with {
    briefly "FulfillmentOrder event source"
    described as {
      |Publishes FulfillmentOrder events to the event stream.
    }
  }
  sink FulfillmentOrderEventSink is {
    inlet IncomingFulfillmentOrderEvents is type FulfillmentOrderEvent
    handler FulfillmentOrderEventReceiver is {
      on init is { ??? }
      on other is { ??? }
      on event FulfillmentOrder.OrderCreated is {
        tell event FulfillmentOrder.OrderCreated to repository FulfillmentContext.FulfillmentRepository
      }
      on event FulfillmentOrder.OrderShipped is {
        tell event FulfillmentOrder.OrderShipped to repository FulfillmentContext.FulfillmentRepository
      }
      on event FulfillmentOrder.DeliveryConfirmed is {
        tell event FulfillmentOrder.DeliveryConfirmed to repository FulfillmentContext.FulfillmentRepository
      }
    } with {
      briefly "Event receiver"
      described as {
        |Receives FulfillmentOrder events for persistence.
      }
    }
  } with {
    briefly "FulfillmentOrder event sink"
    described as {
      |Receives FulfillmentOrder events from streaming.
    }
  }
  connector FulfillmentOrderEventPipeline is {
    from outlet FulfillmentContext.FulfillmentOrderEventSource.FulfillmentOrderEvents to inlet FulfillmentContext.FulfillmentOrderEventSink.IncomingFulfillmentOrderEvents
  } with {
    briefly "FulfillmentOrder event pipeline"
    described as {
      |Wires FulfillmentOrder event source to sink.
    }
  }
} with {
  briefly "Bounded context for order fulfillment"
  described as {
    |Supply chain fulfillment context.
  }
}
