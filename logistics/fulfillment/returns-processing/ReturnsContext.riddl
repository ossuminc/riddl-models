// Returns Processing - Returns Context
context ReturnsContext is {
  include "types.riddl"
  include "Return.riddl"
  repository ReturnsRepository is {
    schema ReturnsData is relational
      of returns as type Return
        index on field Return.returnId
        index on field Return.orderId
        index on field Return.status
        index on field Return.rmaNumber

    handler ReturnsPersistence is {
      on command Return.RequestReturn is {
        tell event Return.ReturnRequested to entity ReturnsContext.Return
      }
      on command Return.AuthorizeReturn is {
        tell event Return.ReturnAuthorized to entity ReturnsContext.Return
      }
      on command Return.ReceiveReturn is {
        tell event Return.ReturnReceived to entity ReturnsContext.Return
      }
      on command Return.InspectItem is {
        tell event Return.ItemInspected to entity ReturnsContext.Return
      }
      on command Return.ProcessRefund is {
        tell event Return.RefundProcessed to entity ReturnsContext.Return
      }
    } with {
      briefly "Persists return commands"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Returns data persistence"
    described as {
      |Persistent storage for returns.
    }
  }
  projector ReturnsAnalytics is {
    updates repository ReturnsContext.ReturnsRepository
    record ReturnsMetrics is  {
      period: String(1,20) with {
        briefly "Period"
        described as {
          |Time period.
        }
      }
      totalReturns: Natural with {
        briefly "Total"
        described as {
          |Total returns.
        }
      }
      totalRefunded: Decimal(15,2) with {
        briefly "Refunded"
        described as {
          |Total refunded.
        }
      }
      approvalRate: Decimal(5,2) with {
        briefly "Approval"
        described as {
          |Approval rate pct.
        }
      }
      avgProcessingDays: Decimal(5,2) with {
        briefly "Avg days"
        described as {
          |Avg processing days.
        }
      }
      topReason: ReturnReason with {
        briefly "Top reason"
        described as {
          |Most common reason.
        }
      }
    } with {
      briefly "Returns metrics"
      described as {
        |Return processing metrics.
      }
    }
    handler AnalyticsHandler is {
      on event Return.ReturnRequested is {
        tell event Return.ReturnRequested to repository ReturnsContext.ReturnsRepository
      }
      on event Return.RefundProcessed is {
        tell event Return.RefundProcessed to repository ReturnsContext.ReturnsRepository
      }
      on event Return.ReturnRejected is {
        tell event Return.ReturnRejected to repository ReturnsContext.ReturnsRepository
      }
    } with {
      briefly "Maintains returns analytics"
      described as {
        |Projects events into analytics.
      }
    }
  } with {
    briefly "Returns analytics"
    described as {
      |Returns processing analysis.
    }
  }
  type ReturnEvent is one of {
    ReturnsContext.Return.ReturnRequested,
    ReturnsContext.Return.RefundProcessed,
    ReturnsContext.Return.ReturnRejected
  } with {
    briefly "Return event union"
    described as {
      |Union of Return events for streaming.
    }
  }
  source ReturnEventSource is {
    outlet ReturnEvents is type ReturnEvent
    handler ReturnEventEmitter is {
      on init is { tell command Return.InitializeReturn to entity ReturnsContext.Return }
      on other is { ??? }
      on event Return.ReturnRequested is {
        send event Return.ReturnRequested to outlet ReturnEvents
      }
      on event Return.RefundProcessed is {
        send event Return.RefundProcessed to outlet ReturnEvents
      }
      on event Return.ReturnRejected is {
        send event Return.ReturnRejected to outlet ReturnEvents
      }
    } with {
      briefly "Event emitter"
      described as {
        |Emits Return events to the stream.
      }
    }
  } with {
    briefly "Return event source"
    described as {
      |Publishes Return events to the event stream.
    }
  }
  sink ReturnEventSink is {
    inlet IncomingReturnEvents is type ReturnEvent
    handler ReturnEventReceiver is {
      on init is { ??? }
      on other is { ??? }
      on event Return.ReturnRequested is {
        tell event Return.ReturnRequested to repository ReturnsContext.ReturnsRepository
      }
      on event Return.RefundProcessed is {
        tell event Return.RefundProcessed to repository ReturnsContext.ReturnsRepository
      }
      on event Return.ReturnRejected is {
        tell event Return.ReturnRejected to repository ReturnsContext.ReturnsRepository
      }
    } with {
      briefly "Event receiver"
      described as {
        |Receives Return events for persistence.
      }
    }
  } with {
    briefly "Return event sink"
    described as {
      |Receives Return events from streaming.
    }
  }
  connector ReturnEventPipeline is {
    from outlet ReturnsContext.ReturnEventSource.ReturnEvents to inlet ReturnsContext.ReturnEventSink.IncomingReturnEvents
  } with {
    briefly "Return event pipeline"
    described as {
      |Wires Return event source to sink.
    }
  }
} with {
  briefly "Bounded context for returns processing"
  described as {
    |Product returns management context.
  }
}
