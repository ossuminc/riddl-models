// Care Coordination - Care Plan Context
context CarePlanContext is {
  include "types.riddl"
  include "CarePlan.riddl"
  // Repository for care plan persistence
  repository CarePlanRepository is {
    schema CarePlanData is relational
      of carePlans as type CarePlan
        index on field CarePlan.carePlanId
        index on field CarePlan.patientId

    handler CarePlanPersistence is {
      on command CarePlan.CreateCarePlan is {
        tell event CarePlan.CarePlanCreated to entity CarePlanContext.CarePlan
      }
      on command CarePlan.AddCareTeamMember is {
        tell event CarePlan.CareTeamMemberAdded to entity CarePlanContext.CarePlan
      }
      on command CarePlan.RemoveCareTeamMember is {
        tell event CarePlan.CareTeamMemberRemoved to entity CarePlanContext.CarePlan
      }
      on command CarePlan.AddGoal is {
        tell event CarePlan.GoalAdded to entity CarePlanContext.CarePlan
      }
      on command CarePlan.UpdateGoalStatus is {
        tell event CarePlan.GoalStatusUpdated to entity CarePlanContext.CarePlan
      }
      on command CarePlan.AddTask is {
        tell event CarePlan.TaskAdded to entity CarePlanContext.CarePlan
      }
      on command CarePlan.CompleteTask is {
        tell event CarePlan.TaskCompleted to entity CarePlanContext.CarePlan
      }
      on command CarePlan.CreateReferral is {
        tell event CarePlan.ReferralCreated to entity CarePlanContext.CarePlan
      }
      on command CarePlan.UpdateReferralStatus is {
        tell event CarePlan.ReferralStatusUpdated to entity CarePlanContext.CarePlan
      }
      on command CarePlan.ActivateCarePlan is {
        tell event CarePlan.CarePlanActivated to entity CarePlanContext.CarePlan
      }
      on command CarePlan.CompleteCarePlan is {
        tell event CarePlan.CarePlanCompleted to entity CarePlanContext.CarePlan
      }
    } with {
      briefly "Persists care plan events"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Care plan data persistence"
    described as {
      | The CarePlanRepository provides persistent storage for
      | care plans, goals, tasks, and referrals.
    }
  }
  // Projector for care coordination analytics
  projector CareCoordinationAnalytics is {
    updates repository CarePlanContext.CarePlanRepository
    record CoordinationStats is  {
      activePlans: Natural with {
        briefly "Active"
        described as {
          |Active care plans.
        }
      }
      goalsAchieved: Natural with {
        briefly "Goals"
        described as {
          |Goals achieved.
        }
      }
      pendingReferrals: Natural with {
        briefly "Referrals"
        described as {
          |Pending referrals.
        }
      }
      overdueTasks: Natural with {
        briefly "Overdue"
        described as {
          |Overdue tasks.
        }
      }
      avgPlanDuration: Duration with {
        briefly "Avg duration"
        described as {
          |Average plan duration.
        }
      }
    } with {
      briefly "Coordination statistics"
      described as {
        |Care coordination metrics.
      }
    }
    handler AnalyticsHandler is {
      on event CarePlan.CarePlanCreated is {
        tell event CarePlan.CarePlanCreated to repository CarePlanContext.CarePlanRepository
      }
      on event CarePlan.GoalStatusUpdated is {
        tell event CarePlan.GoalStatusUpdated to repository CarePlanContext.CarePlanRepository
      }
      on event CarePlan.ReferralCreated is {
        tell event CarePlan.ReferralCreated to repository CarePlanContext.CarePlanRepository
      }
      on event CarePlan.CarePlanCompleted is {
        tell event CarePlan.CarePlanCompleted to repository CarePlanContext.CarePlanRepository
      }
    } with {
      briefly "Maintains coordination analytics"
      described as {
        |Projects events into analytics views.
      }
    }
  } with {
    briefly "Coordination analytics projections"
    described as {
      |Maintains care coordination analytics data.
    }
  }
  // Event union for streaming
  type CarePlanEvent is one of {
    CarePlanContext.CarePlan.CarePlanCreated,
    CarePlanContext.CarePlan.CareTeamMemberAdded,
    CarePlanContext.CarePlan.CareTeamMemberRemoved,
    CarePlanContext.CarePlan.GoalAdded,
    CarePlanContext.CarePlan.GoalStatusUpdated,
    CarePlanContext.CarePlan.TaskAdded,
    CarePlanContext.CarePlan.TaskCompleted,
    CarePlanContext.CarePlan.ReferralCreated,
    CarePlanContext.CarePlan.ReferralStatusUpdated,
    CarePlanContext.CarePlan.CarePlanActivated,
    CarePlanContext.CarePlan.CarePlanCompleted
  } with {
    briefly "Care plan events"
    described as {
      |Union of all care plan entity events for streaming.
    }
  }
  source CarePlanSource is {
    outlet CarePlanEvents is type CarePlanEvent with {
      briefly "Care plan event outlet"
      described as {
        |Publishes care plan events.
      }
    }
    handler CarePlanSourceHandler is {
      on init is {
        tell command CarePlan.InitializeCarePlan to entity CarePlanContext.CarePlan
      }
      on event CarePlan.CarePlanCreated is {
        send event CarePlan.CarePlanCreated to outlet CarePlanEvents
      }
      on event CarePlan.CarePlanActivated is {
        send event CarePlan.CarePlanActivated to outlet CarePlanEvents
      }
      on event CarePlan.CarePlanCompleted is {
        send event CarePlan.CarePlanCompleted to outlet CarePlanEvents
      }
      on other is { ??? }
    } with {
      briefly "Care plan source handler"
      described as {
        |Forwards care plan events to the outlet.
      }
    }
  } with {
    briefly "Care plan event source"
    described as {
      |Source streamlet that publishes care plan events.
    }
  }
  sink CarePlanSink is {
    inlet CarePlanEventsIn is type CarePlanEvent with {
      briefly "Care plan event inlet"
      described as {
        |Receives care plan events.
      }
    }
    handler CarePlanSinkHandler is {
      on init is { ??? }
      on event CarePlan.CarePlanCreated is {
        tell event CarePlan.CarePlanCreated to repository CarePlanContext.CarePlanRepository
      }
      on event CarePlan.CarePlanCompleted is {
        tell event CarePlan.CarePlanCompleted to repository CarePlanContext.CarePlanRepository
      }
      on other is { ??? }
    } with {
      briefly "Care plan sink handler"
      described as {
        |Persists care plan events from the inlet.
      }
    }
  } with {
    briefly "Care plan event sink"
    described as {
      |Sink streamlet that consumes care plan events.
    }
  }
  connector CarePlanFlow is {
    from outlet CarePlanContext.CarePlanSource.CarePlanEvents to
      inlet CarePlanContext.CarePlanSink.CarePlanEventsIn
  } with {
    briefly "Care plan event flow"
    described as {
      |Connects care plan source to sink for event streaming.
    }
  }
} with {
  briefly "Bounded context for care coordination"
  described as {
    | The CarePlanContext is the bounded context for
    | care plans, referrals, and team coordination.
  }
}
