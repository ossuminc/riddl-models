// Patient Registration - Patient Context
context PatientContext is {
  include "types.riddl"
  include "Patient.riddl"
  // Repository for patient persistence
  repository PatientRepository is {
    schema PatientData is relational
      of patients as type Patient
        index on field Patient.patientId
        index on field Patient.mrn
        index on field Patient.demographics.lastName

    handler PatientPersistence is {
      on command Patient.RegisterPatient is {
        tell event Patient.PatientRegistered to entity PatientContext.Patient
      }
      on command Patient.UpdateDemographics is {
        tell event Patient.DemographicsUpdated to entity PatientContext.Patient
      }
      on command Patient.UpdateAddress is {
        tell event Patient.AddressUpdated to entity PatientContext.Patient
      }
      on command Patient.UpdateContact is {
        tell event Patient.ContactUpdated to entity PatientContext.Patient
      }
      on command Patient.AddEmergencyContact is {
        tell event Patient.EmergencyContactAdded to entity PatientContext.Patient
      }
      on command Patient.AddInsurance is {
        tell event Patient.InsuranceAdded to entity PatientContext.Patient
      }
      on command Patient.UpdateInsurance is {
        tell event Patient.InsuranceUpdated to entity PatientContext.Patient
      }
      on command Patient.RecordConsent is {
        tell event Patient.ConsentRecorded to entity PatientContext.Patient
      }
      on command Patient.DeactivatePatient is {
        tell event Patient.PatientDeactivated to entity PatientContext.Patient
      }
      on command Patient.ReactivatePatient is {
        tell event Patient.PatientReactivated to entity PatientContext.Patient
      }
      on command Patient.MergePatients is {
        tell event Patient.PatientsMerged to entity PatientContext.Patient
      }
    } with {
      briefly "Persists patient commands"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Patient data persistence"
    described as {
      | The PatientRepository provides persistent storage for
      | patient records and demographics.
    }
  }
  // Projector for patient analytics
  projector PatientAnalytics is {
    updates repository PatientContext.PatientRepository
    record PatientStats is  {
      totalPatients: Natural with {
        briefly "Total"
        described as {
          |Total patients.
        }
      }
      activePatients: Natural with {
        briefly "Active"
        described as {
          |Active patients.
        }
      }
      newRegistrations: Natural with {
        briefly "New"
        described as {
          |New registrations today.
        }
      }
      insuranceCoverage: Decimal(5,4) with {
        briefly "Insured"
        described as {
          |Percent with insurance.
        }
      }
      avgAge: Decimal(5,2) with {
        briefly "Avg age"
        described as {
          |Average patient age.
        }
      }
    } with {
      briefly "Patient statistics"
      described as {
        |Patient registration metrics.
      }
    }
    handler AnalyticsHandler is {
      on event Patient.PatientRegistered is {
        tell event Patient.PatientRegistered to repository PatientContext.PatientRepository
      }
      on event Patient.PatientDeactivated is {
        tell event Patient.PatientDeactivated to repository PatientContext.PatientRepository
      }
      on event Patient.InsuranceAdded is {
        tell event Patient.InsuranceAdded to repository PatientContext.PatientRepository
      }
    } with {
      briefly "Maintains patient analytics"
      described as {
        |Projects events into analytics views.
      }
    }
  } with {
    briefly "Patient analytics projections"
    described as {
      |Maintains patient registration analytics data.
    }
  }
  type PatientEvent is one of {
    PatientContext.Patient.PatientRegistered,
    PatientContext.Patient.DemographicsUpdated,
    PatientContext.Patient.AddressUpdated,
    PatientContext.Patient.ContactUpdated,
    PatientContext.Patient.EmergencyContactAdded,
    PatientContext.Patient.InsuranceAdded,
    PatientContext.Patient.InsuranceUpdated,
    PatientContext.Patient.ConsentRecorded,
    PatientContext.Patient.PatientDeactivated,
    PatientContext.Patient.PatientReactivated,
    PatientContext.Patient.PatientsMerged
  } with {
    briefly "Patient events"
    described as {
      |Union of all patient entity events for streaming.
    }
  }
  source PatientSource is {
    outlet PatientEvents is type PatientEvent with {
      briefly "Patient event outlet"
      described as {
        |Publishes patient events.
      }
    }
    handler PatientSourceHandler is {
      on init is {
        tell command Patient.InitializePatient to entity PatientContext.Patient
      }
      on event Patient.PatientRegistered is {
        send event Patient.PatientRegistered to outlet PatientEvents
      }
      on event Patient.PatientDeactivated is {
        send event Patient.PatientDeactivated to outlet PatientEvents
      }
      on event Patient.PatientReactivated is {
        send event Patient.PatientReactivated to outlet PatientEvents
      }
      on other is { ??? }
    } with {
      briefly "Patient source handler"
      described as {
        |Forwards patient events to the outlet.
      }
    }
  } with {
    briefly "Patient event source"
    described as {
      |Source streamlet that publishes patient events.
    }
  }
  sink PatientSink is {
    inlet PatientEventsIn is type PatientEvent with {
      briefly "Patient event inlet"
      described as {
        |Receives patient events.
      }
    }
    handler PatientSinkHandler is {
      on init is { ??? }
      on event Patient.PatientRegistered is {
        tell event Patient.PatientRegistered to repository PatientContext.PatientRepository
      }
      on event Patient.PatientDeactivated is {
        tell event Patient.PatientDeactivated to repository PatientContext.PatientRepository
      }
      on other is { ??? }
    } with {
      briefly "Patient sink handler"
      described as {
        |Persists patient events from the inlet.
      }
    }
  } with {
    briefly "Patient event sink"
    described as {
      |Sink streamlet that consumes patient events.
    }
  }
  connector PatientFlow is {
    from outlet PatientContext.PatientSource.PatientEvents to
      inlet PatientContext.PatientSink.PatientEventsIn
  } with {
    briefly "Patient event flow"
    described as {
      |Connects patient source to sink for event streaming.
    }
  }
} with {
  briefly "Bounded context for patient registration"
  described as {
    | The PatientContext is the bounded context for
    | patient demographics and registration management.
  }
}
