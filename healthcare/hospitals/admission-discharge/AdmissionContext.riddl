// Hospital Admission/Discharge - Admission Context
context AdmissionContext is {
  include "types.riddl"
  include "Admission.riddl"
  // Repository for admission persistence
  repository AdmissionRepository is {
    schema AdmissionData is relational
      of admissions as type Admission
        index on field Admission.admissionId
        index on field Admission.patientId

    handler AdmissionPersistence is {
      on command Admission.CreateAdmission is {
        tell event Admission.AdmissionCreated to entity AdmissionContext.Admission
      }
      on command Admission.AssignBed is {
        tell event Admission.BedAssigned to entity AdmissionContext.Admission
      }
      on command Admission.RequestTransfer is {
        tell event Admission.TransferRequested to entity AdmissionContext.Admission
      }
      on command Admission.TransferPatient is {
        tell event Admission.PatientTransferred to entity AdmissionContext.Admission
      }
      on command Admission.UpdateCondition is {
        tell event Admission.ConditionUpdated to entity AdmissionContext.Admission
      }
      on command Admission.InitiateDischarge is {
        tell event Admission.DischargeInitiated to entity AdmissionContext.Admission
      }
      on command Admission.CompleteDischarge is {
        tell event Admission.DischargeCompleted to entity AdmissionContext.Admission
      }
    } with {
      briefly "Persists admission commands"
      described as {
        |Handles command-driven persistence for admissions.
      }
    }
  } with {
    briefly "Admission data persistence"
    described as {
      | The AdmissionRepository provides persistent storage for
      | admission records, bed assignments, and transfers.
    }
  }
  // Repository for bed census
  repository BedCensusRepository is {
    schema BedCensusData is relational
      of beds as type BedAssignment
        index on field BedAssignment.bedId
        index on field BedAssignment.unitId

    handler BedCensusPersistence is {
      on command Admission.AssignBed is {
        tell event Admission.BedAssigned to entity AdmissionContext.Admission
      }
      on command Admission.TransferPatient is {
        tell event Admission.PatientTransferred to entity AdmissionContext.Admission
      }
      on command Admission.CompleteDischarge is {
        tell event Admission.DischargeCompleted to entity AdmissionContext.Admission
      }
    } with {
      briefly "Maintains bed census"
      described as {
        |Tracks real-time bed occupancy status.
      }
    }
  } with {
    briefly "Bed census persistence"
    described as {
      | The BedCensusRepository tracks current bed occupancy
      | and availability across all hospital units.
    }
  }
  // Projector for bed occupancy metrics
  projector BedOccupancyProjector is {
    updates repository AdmissionContext.AdmissionRepository
    record OccupancyStats is  {
      unitId: UnitId with {
        briefly "Unit"
        described as {
          |Hospital unit.
        }
      }
      unitName: String(1,100) with {
        briefly "Name"
        described as {
          |Unit name.
        }
      }
      totalBeds: Natural with {
        briefly "Total"
        described as {
          |Total beds in unit.
        }
      }
      occupiedBeds: Natural with {
        briefly "Occupied"
        described as {
          |Currently occupied.
        }
      }
      availableBeds: Natural with {
        briefly "Available"
        described as {
          |Available for assignment.
        }
      }
      pendingClean: Natural with {
        briefly "Pending clean"
        described as {
          |Awaiting housekeeping.
        }
      }
      occupancyRate: Decimal(5,4) with {
        briefly "Rate"
        described as {
          |Occupancy percentage.
        }
      }
      asOfTime: TimeStamp with {
        briefly "As of"
        described as {
          |Snapshot time.
        }
      }
    } with {
      briefly "Occupancy statistics"
      described as {
        |Real-time bed occupancy metrics by unit.
      }
    }
    handler OccupancyHandler is {
      on event Admission.BedAssigned is {
        tell event Admission.BedAssigned to repository AdmissionContext.AdmissionRepository
      }
      on event Admission.PatientTransferred is {
        tell event Admission.PatientTransferred to repository AdmissionContext.AdmissionRepository
      }
      on event Admission.DischargeCompleted is {
        tell event Admission.DischargeCompleted to repository AdmissionContext.AdmissionRepository
      }
    } with {
      briefly "Maintains occupancy metrics"
      described as {
        |Projects bed events into occupancy statistics.
      }
    }
  } with {
    briefly "Bed occupancy projections"
    described as {
      |Maintains real-time bed occupancy analytics.
    }
  }
  // Projector for length of stay analytics
  projector LengthOfStayProjector is {
    updates repository AdmissionContext.AdmissionRepository
    record LOSStats is  {
      filterUnitId: UnitId? with {
        briefly "Unit"
        described as {
          |Hospital unit filter.
        }
      }
      filterAdmissionType: AdmissionType? with {
        briefly "Type"
        described as {
          |Admission type filter.
        }
      }
      averageLOS: Decimal(6,2) with {
        briefly "Avg LOS"
        described as {
          |Average length of stay in days.
        }
      }
      medianLOS: Decimal(6,2) with {
        briefly "Median LOS"
        described as {
          |Median length of stay.
        }
      }
      minLOS: Natural with {
        briefly "Min"
        described as {
          |Shortest stay.
        }
      }
      maxLOS: Natural with {
        briefly "Max"
        described as {
          |Longest stay.
        }
      }
      totalDischarges: Natural with {
        briefly "Discharges"
        described as {
          |Total discharges in period.
        }
      }
      periodStart: Date with {
        briefly "Start"
        described as {
          |Period start date.
        }
      }
      periodEnd: Date with {
        briefly "End"
        described as {
          |Period end date.
        }
      }
    } with {
      briefly "Length of stay statistics"
      described as {
        |Aggregated length of stay metrics.
      }
    }
    handler LOSHandler is {
      on event Admission.DischargeCompleted is {
        tell event Admission.DischargeCompleted to repository AdmissionContext.AdmissionRepository
      }
    } with {
      briefly "Maintains LOS analytics"
      described as {
        |Projects discharge events into LOS metrics.
      }
    }
  } with {
    briefly "Length of stay projections"
    described as {
      |Maintains length of stay analytics for quality reporting.
    }
  }
  // Projector for throughput metrics
  projector ThroughputProjector is {
    updates repository AdmissionContext.AdmissionRepository
    record ThroughputStats is  {
      periodDate: Date with {
        briefly "Date"
        described as {
          |Statistics date.
        }
      }
      admissions: Natural with {
        briefly "Admissions"
        described as {
          |New admissions.
        }
      }
      discharges: Natural with {
        briefly "Discharges"
        described as {
          |Total discharges.
        }
      }
      transfers: Natural with {
        briefly "Transfers"
        described as {
          |Inter-unit transfers.
        }
      }
      emergencyAdmits: Natural with {
        briefly "Emergency"
        described as {
          |Emergency admissions.
        }
      }
      electiveAdmits: Natural with {
        briefly "Elective"
        described as {
          |Elective admissions.
        }
      }
      averageTimeToAssignment: Duration with {
        briefly "Time to bed"
        described as {
          |Average time to bed assignment.
        }
      }
      averageDischargeTime: Duration with {
        briefly "Discharge time"
        described as {
          |Average discharge processing time.
        }
      }
    } with {
      briefly "Throughput statistics"
      described as {
        |Daily patient flow metrics.
      }
    }
    handler ThroughputHandler is {
      on event Admission.AdmissionCreated is {
        tell event Admission.AdmissionCreated to repository AdmissionContext.AdmissionRepository
      }
      on event Admission.BedAssigned is {
        tell event Admission.BedAssigned to repository AdmissionContext.AdmissionRepository
      }
      on event Admission.PatientTransferred is {
        tell event Admission.PatientTransferred to repository AdmissionContext.AdmissionRepository
      }
      on event Admission.DischargeCompleted is {
        tell event Admission.DischargeCompleted to repository AdmissionContext.AdmissionRepository
      }
    } with {
      briefly "Maintains throughput metrics"
      described as {
        |Projects events into throughput analytics.
      }
    }
  } with {
    briefly "Throughput projections"
    described as {
      |Maintains daily patient flow and throughput metrics.
    }
  }
  type AdmissionEvent is one of {
    AdmissionContext.Admission.AdmissionCreated,
    AdmissionContext.Admission.BedAssigned,
    AdmissionContext.Admission.TransferRequested,
    AdmissionContext.Admission.PatientTransferred,
    AdmissionContext.Admission.ConditionUpdated,
    AdmissionContext.Admission.DischargeInitiated,
    AdmissionContext.Admission.DischargeCompleted
  } with {
    briefly "Admission events"
    described as {
      |Union of all admission entity events for streaming.
    }
  }
  source AdmissionSource is {
    outlet AdmissionEvents is type AdmissionEvent with {
      briefly "Admission event outlet"
      described as {
        |Publishes admission events.
      }
    }
    handler AdmissionSourceHandler is {
      on init is {
        tell command Admission.InitializeAdmission to entity AdmissionContext.Admission
      }
      on event Admission.AdmissionCreated is {
        send event Admission.AdmissionCreated to outlet AdmissionEvents
      }
      on event Admission.DischargeCompleted is {
        send event Admission.DischargeCompleted to outlet AdmissionEvents
      }
      on other is { ??? }
    } with {
      briefly "Admission source handler"
      described as {
        |Forwards admission events to the outlet.
      }
    }
  } with {
    briefly "Admission event source"
    described as {
      |Source streamlet that publishes admission events.
    }
  }
  sink AdmissionSink is {
    inlet AdmissionEventsIn is type AdmissionEvent with {
      briefly "Admission event inlet"
      described as {
        |Receives admission events.
      }
    }
    handler AdmissionSinkHandler is {
      on init is { ??? }
      on event Admission.AdmissionCreated is {
        tell event Admission.AdmissionCreated to repository AdmissionContext.AdmissionRepository
      }
      on event Admission.DischargeCompleted is {
        tell event Admission.DischargeCompleted to repository AdmissionContext.AdmissionRepository
      }
      on other is { ??? }
    } with {
      briefly "Admission sink handler"
      described as {
        |Persists admission events from the inlet.
      }
    }
  } with {
    briefly "Admission event sink"
    described as {
      |Sink streamlet that consumes admission events.
    }
  }
  connector AdmissionFlow is {
    from outlet AdmissionContext.AdmissionSource.AdmissionEvents to
      inlet AdmissionContext.AdmissionSink.AdmissionEventsIn
  } with {
    briefly "Admission event flow"
    described as {
      |Connects admission source to sink for event streaming.
    }
  }
} with {
  briefly "Bounded context for hospital admissions"
  described as {
    | The AdmissionContext is the bounded context for
    | patient admissions, bed management, and discharges.
  }
}
