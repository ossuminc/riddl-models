// Game Economy - Wallet Context
context WalletContext is {
  include "types.riddl"
  include "Wallet.riddl"
  // Repository for wallet persistence
  repository WalletRepository is {
    schema WalletData is relational
      of wallets as type Wallet
        index on field Wallet.walletId
        index on field Wallet.playerId

    handler WalletPersistence is {
      on command Wallet.CreateWallet is {
        tell event Wallet.WalletCreated to entity
          WalletContext.Wallet
      }
      on command Wallet.AddCurrency is {
        tell event Wallet.CurrencyAdded to entity
          WalletContext.Wallet
      }
      on command Wallet.SpendCurrency is {
        tell event Wallet.CurrencySpent to entity
          WalletContext.Wallet
      }
      on command Wallet.TransferCurrency is {
        tell event Wallet.CurrencyTransferred to entity
          WalletContext.Wallet
      }
      on command Wallet.AddItem is {
        tell event Wallet.ItemAdded to entity
          WalletContext.Wallet
      }
      on command Wallet.RemoveItem is {
        tell event Wallet.ItemRemoved to entity
          WalletContext.Wallet
      }
      on command Wallet.PurchaseItem is {
        tell event Wallet.ItemPurchased to entity
          WalletContext.Wallet
      }
      on command Wallet.InitiateTrade is {
        tell event Wallet.TradeInitiated to entity
          WalletContext.Wallet
      }
      on command Wallet.CompleteTrade is {
        tell event Wallet.TradeCompleted to entity
          WalletContext.Wallet
      }
    } with {
      briefly "Persists wallet commands"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Wallet data persistence"
    described as {
      | The WalletRepository provides persistent storage for
      | player wallets, inventories, and transactions.
    }
  }
  // Projector for economy analytics
  projector EconomyAnalytics is {
    updates repository WalletContext.WalletRepository
    record EconomyStats is  {
      currencyType: CurrencyType with {
        briefly "Currency"
        described as {
          |Currency type.
        }
      }
      totalCirculating: Decimal(20,4) with {
        briefly "Circulating"
        described as {
          |Total in circulation.
        }
      }
      dailyEarned: Decimal(15,4) with {
        briefly "Earned"
        described as {
          |Daily earned.
        }
      }
      dailySpent: Decimal(15,4) with {
        briefly "Spent"
        described as {
          |Daily spent.
        }
      }
      activePlayers: Natural with {
        briefly "Players"
        described as {
          |Active players.
        }
      }
      averageBalance: Decimal(15,4) with {
        briefly "Average"
        described as {
          |Average balance.
        }
      }
    } with {
      briefly "Economy statistics"
      described as {
        |Game economy metrics.
      }
    }
    handler AnalyticsHandler is {
      on event Wallet.CurrencyAdded is {
        tell event Wallet.CurrencyAdded to repository
          WalletContext.WalletRepository
      }
      on event Wallet.CurrencySpent is {
        tell event Wallet.CurrencySpent to repository
          WalletContext.WalletRepository
      }
      on event Wallet.ItemPurchased is {
        tell event Wallet.ItemPurchased to repository
          WalletContext.WalletRepository
      }
      on event Wallet.TradeCompleted is {
        tell event Wallet.TradeCompleted to repository
          WalletContext.WalletRepository
      }
    } with {
      briefly "Maintains economy analytics"
      described as {
        |Projects events into analytics views.
      }
    }
  } with {
    briefly "Economy analytics projections"
    described as {
      |Maintains game economy analytics data.
    }
  }
  source WalletEventSource is {
    outlet WalletEvents is type WalletEvent
    handler WalletEventEmitter is {
      on init is {
        tell command InitializeWallet to entity
          WalletContext.Wallet
      }
      on other is { ??? }
      on event Wallet.WalletCreated is {
        send event Wallet.WalletCreated to outlet WalletEvents
      }
      on event Wallet.CurrencyAdded is {
        send event Wallet.CurrencyAdded to outlet WalletEvents
      }
      on event Wallet.CurrencySpent is {
        send event Wallet.CurrencySpent to outlet WalletEvents
      }
      on event Wallet.ItemPurchased is {
        send event Wallet.ItemPurchased to outlet WalletEvents
      }
      on event Wallet.TradeCompleted is {
        send event Wallet.TradeCompleted to outlet WalletEvents
      }
    } with {
      briefly "Wallet event emitter"
      described as {
        |Emits wallet lifecycle events into the streaming
        |topology.
      }
    }
  } with {
    briefly "Wallet event source"
    described as {
      |Publishes wallet entity events for streaming.
    }
  }
  sink WalletEventSink is {
    inlet IncomingWalletEvents is type WalletEvent
    handler WalletEventReceiver is {
      on init is { ??? }
      on other is { ??? }
      on event Wallet.WalletCreated is {
        tell event Wallet.WalletCreated to repository
          WalletContext.WalletRepository
      }
      on event Wallet.TradeCompleted is {
        tell event Wallet.TradeCompleted to repository
          WalletContext.WalletRepository
      }
    } with {
      briefly "Wallet event receiver"
      described as {
        |Receives wallet events and persists them.
      }
    }
  } with {
    briefly "Wallet event sink"
    described as {
      |Receives wallet events from the streaming topology.
    }
  }
  connector WalletEventPipeline is {
    from outlet WalletContext.WalletEventSource.WalletEvents
      to inlet WalletContext.WalletEventSink.IncomingWalletEvents
  } with {
    briefly "Wallet event pipeline"
    described as {
      |Wires wallet events from source to sink.
    }
  }
} with {
  briefly "Bounded context for game economy"
  described as {
    | The WalletContext is the bounded context for player
    | wallets, currencies, items, and transactions.
  }
}
