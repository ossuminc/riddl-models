// Matchmaking - Match Context
context MatchContext is {
  include "types.riddl"
  include "Match.riddl"
  // Repository for match persistence
  repository MatchRepository is {
    schema MatchData is relational
      of matches as type Match
        index on field Match.matchId
        index on field Match.gameMode

    handler MatchPersistence is {
      on command Match.CreateMatch is {
        tell event Match.MatchCreated to entity
          MatchContext.Match
      }
      on command Match.AssignServer is {
        tell event Match.ServerAssigned to entity
          MatchContext.Match
      }
      on command Match.ConfirmPlayer is {
        tell event Match.PlayerConfirmed to entity
          MatchContext.Match
      }
      on command Match.StartMatch is {
        tell event Match.MatchStarted to entity
          MatchContext.Match
      }
      on command Match.UpdateScore is {
        tell event Match.ScoreUpdated to entity
          MatchContext.Match
      }
      on command Match.EndMatch is {
        tell event Match.MatchEnded to entity
          MatchContext.Match
      }
      on command Match.CancelMatch is {
        tell event Match.MatchCancelled to entity
          MatchContext.Match
      }
      on command Match.RemovePlayer is {
        tell event Match.PlayerRemoved to entity
          MatchContext.Match
      }
    } with {
      briefly "Persists match commands"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Match data persistence"
    described as {
      | The MatchRepository provides persistent storage for
      | matches and matchmaking data.
    }
  }
  // Projector for matchmaking analytics
  projector MatchAnalytics is {
    updates repository MatchContext.MatchRepository
    record MatchStats is  {
      gameMode: GameMode with {
        briefly "Mode"
        described as {
          |Game mode.
        }
      }
      totalMatches: Natural with {
        briefly "Matches"
        described as {
          |Total matches.
        }
      }
      averageQueueTime: Duration with {
        briefly "Queue time"
        described as {
          |Avg queue time.
        }
      }
      averageMatchDuration: Duration with {
        briefly "Duration"
        described as {
          |Avg match duration.
        }
      }
      completionRate: Decimal(5,4) with {
        briefly "Completion"
        described as {
          |Completion rate.
        }
      }
      activePlayers: Natural with {
        briefly "Players"
        described as {
          |Active players.
        }
      }
    } with {
      briefly "Match statistics"
      described as {
        |Matchmaking metrics.
      }
    }
    handler AnalyticsHandler is {
      on event Match.MatchCreated is {
        tell event Match.MatchCreated to repository
          MatchContext.MatchRepository
      }
      on event Match.MatchStarted is {
        tell event Match.MatchStarted to repository
          MatchContext.MatchRepository
      }
      on event Match.MatchEnded is {
        tell event Match.MatchEnded to repository
          MatchContext.MatchRepository
      }
    } with {
      briefly "Maintains match analytics"
      described as {
        |Projects events into analytics views.
      }
    }
  } with {
    briefly "Match analytics projections"
    described as {
      |Maintains matchmaking analytics data.
    }
  }
  source MatchEventSource is {
    outlet MatchEvents is type MatchEvent
    handler MatchEventEmitter is {
      on init is {
        tell command InitializeMatch to entity
          MatchContext.Match
      }
      on other is { ??? }
      on event Match.MatchCreated is {
        send event Match.MatchCreated to outlet MatchEvents
      }
      on event Match.MatchStarted is {
        send event Match.MatchStarted to outlet MatchEvents
      }
      on event Match.MatchEnded is {
        send event Match.MatchEnded to outlet MatchEvents
      }
      on event Match.MatchCancelled is {
        send event Match.MatchCancelled to outlet MatchEvents
      }
    } with {
      briefly "Match event emitter"
      described as {
        |Emits match lifecycle events into the streaming
        |topology.
      }
    }
  } with {
    briefly "Match event source"
    described as {
      |Publishes match entity events for streaming.
    }
  }
  sink MatchEventSink is {
    inlet IncomingMatchEvents is type MatchEvent
    handler MatchEventReceiver is {
      on init is { ??? }
      on other is { ??? }
      on event Match.MatchCreated is {
        tell event Match.MatchCreated to repository
          MatchContext.MatchRepository
      }
      on event Match.MatchEnded is {
        tell event Match.MatchEnded to repository
          MatchContext.MatchRepository
      }
    } with {
      briefly "Match event receiver"
      described as {
        |Receives match events and persists them.
      }
    }
  } with {
    briefly "Match event sink"
    described as {
      |Receives match events from the streaming topology.
    }
  }
  connector MatchEventPipeline is {
    from outlet MatchContext.MatchEventSource.MatchEvents
      to inlet MatchContext.MatchEventSink.IncomingMatchEvents
  } with {
    briefly "Match event pipeline"
    described as {
      |Wires match events from source to sink.
    }
  }
} with {
  briefly "Bounded context for matchmaking"
  described as {
    | The MatchContext is the bounded context for player
    | matching, game sessions, and match results.
  }
}
