// Advertising Delivery - Ad Context
context AdContext is {
  include "types.riddl"
  include "AdImpression.riddl"
  // Repository for ad persistence
  repository AdRepository is {
    schema AdData is relational
      of impressions as type AdImpression
        index on field AdImpression.impressionId
        index on field AdImpression.adUnit.campaignId

    handler AdPersistence is {
      on command AdImpression.RecordImpression is {
        tell event AdImpression.ImpressionRecorded to entity AdContext.AdImpression
      }
      on command AdImpression.RecordStart is {
        tell event AdImpression.AdStarted to entity AdContext.AdImpression
      }
      on command AdImpression.RecordQuartile is {
        tell event AdImpression.QuartileReached to entity AdContext.AdImpression
      }
      on command AdImpression.RecordComplete is {
        tell event AdImpression.AdCompleted to entity AdContext.AdImpression
      }
      on command AdImpression.RecordSkip is {
        tell event AdImpression.AdSkipped to entity AdContext.AdImpression
      }
      on command AdImpression.RecordClick is {
        tell event AdImpression.AdClicked to entity AdContext.AdImpression
      }
      on command AdImpression.RecordError is {
        tell event AdImpression.AdErrorOccurred to entity AdContext.AdImpression
      }
    } with {
      briefly "Persists ad commands"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Ad data persistence"
    described as {
      | The AdRepository provides persistent storage for
      | ad impressions and engagement data.
    }
  }
  // Projector for ad analytics
  projector AdAnalytics is {
    updates repository AdContext.AdRepository
    record CampaignStats is  {
      campaignId: CampaignId with {
        briefly "Campaign"
        described as {
          |Campaign ID.
        }
      }
      impressions: Natural with {
        briefly "Impressions"
        described as {
          |Total impressions.
        }
      }
      views: Natural with {
        briefly "Views"
        described as {
          |View count.
        }
      }
      completions: Natural with {
        briefly "Completions"
        described as {
          |Completion count.
        }
      }
      clicks: Natural with {
        briefly "Clicks"
        described as {
          |Click count.
        }
      }
      clickRate: Decimal(5,4) with {
        briefly "CTR"
        described as {
          |Click-through rate.
        }
      }
      completionRate: Decimal(5,4) with {
        briefly "VCR"
        described as {
          |View completion rate.
        }
      }
    } with {
      briefly "Campaign statistics"
      described as {
        |Campaign performance metrics.
      }
    }
    handler AnalyticsHandler is {
      on event AdImpression.ImpressionRecorded is {
        tell event AdImpression.ImpressionRecorded to repository AdContext.AdRepository
      }
      on event AdImpression.AdStarted is {
        tell event AdImpression.AdStarted to repository AdContext.AdRepository
      }
      on event AdImpression.AdCompleted is {
        tell event AdImpression.AdCompleted to repository AdContext.AdRepository
      }
      on event AdImpression.AdClicked is {
        tell event AdImpression.AdClicked to repository AdContext.AdRepository
      }
    } with {
      briefly "Maintains ad analytics"
      described as {
        |Projects events into analytics views.
      }
    }
  } with {
    briefly "Ad analytics projections"
    described as {
      |Maintains advertising analytics data.
    }
  }
  source AdImpressionEventSource is {
    outlet AdImpressionEvents is type AdImpressionEvent
    handler AdImpressionEventEmitter is {
      on init is { tell command InitializeAdImpression to entity AdContext.AdImpression }
      on other is { ??? }
      on event AdImpression.ImpressionRecorded is {
        send event AdImpression.ImpressionRecorded to outlet AdImpressionEvents
      }
      on event AdImpression.AdCompleted is {
        send event AdImpression.AdCompleted to outlet AdImpressionEvents
      }
      on event AdImpression.AdClicked is {
        send event AdImpression.AdClicked to outlet AdImpressionEvents
      }
    } with {
      briefly "Ad impression event emitter"
      described as {
        |Emits ad impression events into streaming topology.
      }
    }
  } with {
    briefly "Ad impression event source"
    described as {
      |Publishes ad impression events for streaming.
    }
  }
  sink AdImpressionEventSink is {
    inlet IncomingAdImpressionEvents is type AdImpressionEvent
    handler AdImpressionEventReceiver is {
      on init is { ??? }
      on other is { ??? }
      on event AdImpression.ImpressionRecorded is {
        tell event AdImpression.ImpressionRecorded to repository AdContext.AdRepository
      }
      on event AdImpression.AdClicked is {
        tell event AdImpression.AdClicked to repository AdContext.AdRepository
      }
    } with {
      briefly "Ad impression event receiver"
      described as {
        |Receives ad impression events and persists them.
      }
    }
  } with {
    briefly "Ad impression event sink"
    described as {
      |Receives ad impression events from streaming topology.
    }
  }
  connector AdImpressionEventPipeline is {
    from outlet AdContext.AdImpressionEventSource.AdImpressionEvents
      to inlet AdContext.AdImpressionEventSink.IncomingAdImpressionEvents
  } with {
    briefly "Ad impression event pipeline"
    described as {
      |Wires ad impression events from source to sink.
    }
  }
} with {
  briefly "Bounded context for advertising"
  described as {
    | The AdContext is the bounded context for ad delivery,
    | impression tracking, and performance analytics.
  }
}
