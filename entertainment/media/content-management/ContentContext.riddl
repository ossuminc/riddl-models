// Content Management - Content Context
context ContentContext is {
  include "types.riddl"
  include "Content.riddl"
  // Repository for content persistence
  repository ContentRepository is {
    schema ContentData is relational
      of contents as type Content
        index on field Content.contentId
        index on field Content.info.contentType

    handler ContentPersistence is {
      on command Content.CreateContent is {
        tell event Content.ContentCreated to entity ContentContext.Content
      }
      on command Content.UpdateMetadata is {
        tell event Content.MetadataUpdated to entity ContentContext.Content
      }
      on command Content.AddAsset is {
        tell event Content.AssetAdded to entity ContentContext.Content
      }
      on command Content.RemoveAsset is {
        tell event Content.AssetRemoved to entity ContentContext.Content
      }
      on command Content.CreateVersion is {
        tell event Content.VersionCreated to entity ContentContext.Content
      }
      on command Content.AssignRights is {
        tell event Content.RightsAssigned to entity ContentContext.Content
      }
      on command Content.SubmitForReview is {
        tell event Content.ContentSubmittedForReview to entity ContentContext.Content
      }
      on command Content.ApproveContent is {
        tell event Content.ContentApproved to entity ContentContext.Content
      }
      on command Content.RejectContent is {
        tell event Content.ContentRejected to entity ContentContext.Content
      }
      on command Content.PublishContent is {
        tell event Content.ContentPublished to entity ContentContext.Content
      }
      on command Content.UnpublishContent is {
        tell event Content.ContentUnpublished to entity ContentContext.Content
      }
      on command Content.ArchiveContent is {
        tell event Content.ContentArchived to entity ContentContext.Content
      }
    } with {
      briefly "Persists content commands"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Content data persistence"
    described as {
      | The ContentRepository provides persistent storage for
      | content items, assets, and rights.
    }
  }
  // Projector for content analytics
  projector ContentAnalytics is {
    updates repository ContentContext.ContentRepository
    record ContentStats is  {
      contentType: ContentType with {
        briefly "Type"
        described as {
          |Content type.
        }
      }
      totalItems: Natural with {
        briefly "Items"
        described as {
          |Total content items.
        }
      }
      publishedItems: Natural with {
        briefly "Published"
        described as {
          |Published items.
        }
      }
      totalAssets: Natural with {
        briefly "Assets"
        described as {
          |Total assets.
        }
      }
      totalStorageBytes: Natural with {
        briefly "Storage"
        described as {
          |Total storage used.
        }
      }
    } with {
      briefly "Content statistics"
      described as {
        |Content library metrics.
      }
    }
    handler AnalyticsHandler is {
      on event Content.ContentCreated is {
        tell event Content.ContentCreated to repository ContentContext.ContentRepository
      }
      on event Content.AssetAdded is {
        tell event Content.AssetAdded to repository ContentContext.ContentRepository
      }
      on event Content.ContentPublished is {
        tell event Content.ContentPublished to repository ContentContext.ContentRepository
      }
      on event Content.ContentArchived is {
        tell event Content.ContentArchived to repository ContentContext.ContentRepository
      }
    } with {
      briefly "Maintains content analytics"
      described as {
        |Projects events into analytics views.
      }
    }
  } with {
    briefly "Content analytics projections"
    described as {
      |Maintains content library analytics data.
    }
  }
  source ContentEventSource is {
    outlet ContentEvents is type ContentEvent
    handler ContentEventEmitter is {
      on init is { tell command InitializeContent to entity ContentContext.Content }
      on other is { ??? }
      on event Content.ContentCreated is { send event Content.ContentCreated to outlet ContentEvents }
      on event Content.ContentPublished is { send event Content.ContentPublished to outlet ContentEvents }
      on event Content.ContentArchived is { send event Content.ContentArchived to outlet ContentEvents }
    } with {
      briefly "Content event emitter"
      described as {
        |Emits content lifecycle events into streaming topology.
      }
    }
  } with {
    briefly "Content event source"
    described as {
      |Publishes content entity events for streaming.
    }
  }
  sink ContentEventSink is {
    inlet IncomingContentEvents is type ContentEvent
    handler ContentEventReceiver is {
      on init is { ??? }
      on other is { ??? }
      on event Content.ContentCreated is { tell event Content.ContentCreated to repository ContentContext.ContentRepository }
      on event Content.ContentArchived is { tell event Content.ContentArchived to repository ContentContext.ContentRepository }
    } with {
      briefly "Content event receiver"
      described as {
        |Receives content events and persists them.
      }
    }
  } with {
    briefly "Content event sink"
    described as {
      |Receives content events from streaming topology.
    }
  }
  connector ContentEventPipeline is {
    from outlet ContentContext.ContentEventSource.ContentEvents to inlet ContentContext.ContentEventSink.IncomingContentEvents
  } with {
    briefly "Content event pipeline"
    described as {
      |Wires content events from source to sink.
    }
  }
} with {
  briefly "Bounded context for content management"
  described as {
    | The ContentContext is the bounded context for digital
    | content lifecycle, metadata, and distribution management.
  }
}
