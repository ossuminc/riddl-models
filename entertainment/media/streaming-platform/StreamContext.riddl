// Streaming Platform - Stream Context
context StreamContext is {
  include "types.riddl"
  include "Stream.riddl"
  // Repository for stream persistence
  repository StreamRepository is {
    schema StreamData is relational
      of streams as type Stream
        index on field Stream.streamId
        index on field Stream.subscriberId

    handler StreamPersistence is {
      on command Stream.StartStream is {
        tell event Stream.StreamStarted to entity StreamContext.Stream
      }
      on command Stream.PauseStream is {
        tell event Stream.StreamPaused to entity StreamContext.Stream
      }
      on command Stream.ResumeStream is {
        tell event Stream.StreamResumed to entity StreamContext.Stream
      }
      on command Stream.SeekPosition is {
        tell event Stream.PositionSeeked to entity StreamContext.Stream
      }
      on command Stream.ChangeQuality is {
        tell event Stream.QualityChanged to entity StreamContext.Stream
      }
      on command Stream.ReportMetrics is {
        tell event Stream.MetricsReported to entity StreamContext.Stream
      }
      on command Stream.EndStream is {
        tell event Stream.StreamEnded to entity StreamContext.Stream
      }
      on command Stream.ReportError is {
        tell event Stream.StreamErrorOccurred to entity StreamContext.Stream
      }
    } with {
      briefly "Persists stream commands"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Stream data persistence"
    described as {
      | The StreamRepository provides persistent storage for
      | streaming sessions and playback analytics.
    }
  }
  // Projector for streaming analytics
  projector StreamAnalytics is {
    updates repository StreamContext.StreamRepository
    record StreamStats is  {
      contentId: ContentId with {
        briefly "Content"
        described as {
          |Content ID.
        }
      }
      totalViews: Natural with {
        briefly "Views"
        described as {
          |Total views.
        }
      }
      totalWatchTime: Duration with {
        briefly "Watch time"
        described as {
          |Total watch time.
        }
      }
      averageWatchPercent: Decimal(5,2) with {
        briefly "Avg percent"
        described as {
          |Average completion.
        }
      }
      concurrentStreams: Natural with {
        briefly "Concurrent"
        described as {
          |Peak concurrent.
        }
      }
      avgBufferEvents: Decimal(8,2) with {
        briefly "Buffers"
        described as {
          |Average rebuffers.
        }
      }
    } with {
      briefly "Stream statistics"
      described as {
        |Content streaming metrics.
      }
    }
    handler AnalyticsHandler is {
      on event Stream.StreamStarted is {
        tell event Stream.StreamStarted to repository StreamContext.StreamRepository
      }
      on event Stream.MetricsReported is {
        tell event Stream.MetricsReported to repository StreamContext.StreamRepository
      }
      on event Stream.StreamEnded is {
        tell event Stream.StreamEnded to repository StreamContext.StreamRepository
      }
    } with {
      briefly "Maintains stream analytics"
      described as {
        |Projects events into analytics views.
      }
    }
  } with {
    briefly "Stream analytics projections"
    described as {
      |Maintains streaming analytics data.
    }
  }
  source StreamEventSource is {
    outlet StreamEvents is type StreamEvent
    handler StreamEventEmitter is {
      on init is { tell command InitializeStream to entity StreamContext.Stream }
      on other is { ??? }
      on event Stream.StreamStarted is { send event Stream.StreamStarted to outlet StreamEvents }
      on event Stream.StreamEnded is { send event Stream.StreamEnded to outlet StreamEvents }
      on event Stream.StreamErrorOccurred is { send event Stream.StreamErrorOccurred to outlet StreamEvents }
    } with {
      briefly "Stream event emitter"
      described as {
        |Emits stream lifecycle events into streaming topology.
      }
    }
  } with {
    briefly "Stream event source"
    described as {
      |Publishes stream entity events for streaming.
    }
  }
  sink StreamEventSink is {
    inlet IncomingStreamEvents is type StreamEvent
    handler StreamEventReceiver is {
      on init is { ??? }
      on other is { ??? }
      on event Stream.StreamStarted is { tell event Stream.StreamStarted to repository StreamContext.StreamRepository }
      on event Stream.StreamEnded is { tell event Stream.StreamEnded to repository StreamContext.StreamRepository }
    } with {
      briefly "Stream event receiver"
      described as {
        |Receives stream events and persists them.
      }
    }
  } with {
    briefly "Stream event sink"
    described as {
      |Receives stream events from streaming topology.
    }
  }
  connector StreamEventPipeline is {
    from outlet StreamContext.StreamEventSource.StreamEvents to inlet StreamContext.StreamEventSink.IncomingStreamEvents
  } with {
    briefly "Stream event pipeline"
    described as {
      |Wires stream events from source to sink.
    }
  }
} with {
  briefly "Bounded context for streaming"
  described as {
    | The StreamContext is the bounded context for streaming
    | sessions, playback control, and viewing analytics.
  }
}
