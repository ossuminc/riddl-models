// Event Ticketing - Ticketing Context
context TicketingContext is {
  include "types.riddl"
  include "Ticket.riddl"
  repository TicketingRepository is {
    schema TicketingData is relational
      of tickets as type Ticket
        index on field Ticket.ticketId
        index on field Ticket.eventInfo.eventId
        index on field Ticket.status

    handler TicketingPersistence is {
      on command Ticket.CreateTicket is {
        tell event Ticket.TicketCreated to entity
          TicketingContext.Ticket
      }
      on command Ticket.ReserveTicket is {
        tell event Ticket.TicketReserved to entity
          TicketingContext.Ticket
      }
      on command Ticket.PurchaseTicket is {
        tell event Ticket.TicketPurchased to entity
          TicketingContext.Ticket
      }
      on command Ticket.DeliverTicket is {
        tell event Ticket.TicketDelivered to entity
          TicketingContext.Ticket
      }
      on command Ticket.ValidateTicket is {
        tell event Ticket.TicketValidated to entity
          TicketingContext.Ticket
      }
      on command Ticket.RefundTicket is {
        tell event Ticket.TicketRefunded to entity
          TicketingContext.Ticket
      }
    } with {
      briefly "Persists ticketing commands"
      described as {
        |Handles event-driven ticket persistence.
      }
    }
  } with {
    briefly "Ticketing data persistence"
    described as {
      |Persistent storage for tickets.
    }
  }
  projector TicketingMetrics is {
    updates repository TicketingContext.TicketingRepository
    record SalesMetrics is  {
      ticketsCreated: Natural with {
        briefly "Created"
        described as {
          |Tickets created.
        }
      }
      ticketsSold: Natural with {
        briefly "Sold"
        described as {
          |Tickets sold.
        }
      }
      ticketsRefunded: Natural with {
        briefly "Refunded"
        described as {
          |Tickets refunded.
        }
      }
      totalRevenue: Decimal(12,2) with {
        briefly "Revenue"
        described as {
          |Total ticket revenue.
        }
      }
      averageTicketPrice: Decimal(10,2) with {
        briefly "Avg price"
        described as {
          |Average ticket price.
        }
      }
    } with {
      briefly "Sales metrics"
      described as {
        |Ticket sales metrics.
      }
    }
    handler MetricsHandler is {
      on event Ticket.TicketCreated is {
        tell event Ticket.TicketCreated to repository
          TicketingContext.TicketingRepository
      }
      on event Ticket.TicketPurchased is {
        tell event Ticket.TicketPurchased to repository
          TicketingContext.TicketingRepository
      }
      on event Ticket.TicketRefunded is {
        tell event Ticket.TicketRefunded to repository
          TicketingContext.TicketingRepository
      }
      on event Ticket.TicketValidated is {
        tell event Ticket.TicketValidated to repository
          TicketingContext.TicketingRepository
      }
    } with {
      briefly "Maintains ticketing metrics"
      described as {
        |Projects events into sales metrics.
      }
    }
  } with {
    briefly "Ticketing metrics"
    described as {
      |Ticket sales and entry analytics.
    }
  }
  source TicketEventSource is {
    outlet TicketEvents is type TicketEvent
    handler TicketEventEmitter is {
      on init is {
        tell command InitializeTicket to entity
          TicketingContext.Ticket
      }
      on other is { ??? }
      on event Ticket.TicketCreated is {
        send event Ticket.TicketCreated to outlet TicketEvents
      }
      on event Ticket.TicketPurchased is {
        send event Ticket.TicketPurchased to outlet TicketEvents
      }
      on event Ticket.TicketRefunded is {
        send event Ticket.TicketRefunded to outlet TicketEvents
      }
      on event Ticket.TicketValidated is {
        send event Ticket.TicketValidated to outlet TicketEvents
      }
    } with {
      briefly "Ticket event emitter"
      described as {
        |Emits ticket lifecycle events into the streaming
        |topology.
      }
    }
  } with {
    briefly "Ticket event source"
    described as {
      |Publishes ticket entity events for streaming.
    }
  }
  sink TicketEventSink is {
    inlet IncomingTicketEvents is type TicketEvent
    handler TicketEventReceiver is {
      on init is { ??? }
      on other is { ??? }
      on event Ticket.TicketCreated is {
        tell event Ticket.TicketCreated to repository
          TicketingContext.TicketingRepository
      }
      on event Ticket.TicketRefunded is {
        tell event Ticket.TicketRefunded to repository
          TicketingContext.TicketingRepository
      }
    } with {
      briefly "Ticket event receiver"
      described as {
        |Receives ticket events and persists them.
      }
    }
  } with {
    briefly "Ticket event sink"
    described as {
      |Receives ticket events from the streaming topology.
    }
  }
  connector TicketEventPipeline is {
    from outlet TicketingContext.TicketEventSource.TicketEvents
      to inlet TicketingContext.TicketEventSink.IncomingTicketEvents
  } with {
    briefly "Ticket event pipeline"
    described as {
      |Wires ticket events from source to sink.
    }
  }
} with {
  briefly "Bounded context for event ticketing"
  described as {
    |Event ticketing bounded context.
  }
}
