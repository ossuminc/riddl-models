// Production Management - Production Context
context ProductionContext is {
  include "types.riddl"
  include "Production.riddl"
  repository ProductionRepository is {
    schema ProductionData is relational
      of productions as type Production
        index on field Production.productionId
        index on field Production.productionInfo.venueId
        index on field Production.status

    handler ProductionPersistence is {
      on command Production.CreateProduction is {
        tell event Production.ProductionCreated to entity
          ProductionContext.Production
      }
      on command Production.AssignCrew is {
        tell event Production.CrewAssigned to entity
          ProductionContext.Production
      }
      on command Production.AllocateEquipment is {
        tell event Production.EquipmentAllocated to entity
          ProductionContext.Production
      }
      on command Production.ScheduleRehearsal is {
        tell event Production.RehearsalScheduled to entity
          ProductionContext.Production
      }
      on command Production.CompleteRehearsal is {
        tell event Production.RehearsalCompleted to entity
          ProductionContext.Production
      }
      on command Production.CompleteShow is {
        tell event Production.ShowCompleted to entity
          ProductionContext.Production
      }
    } with {
      briefly "Persists production commands"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Production data persistence"
    described as {
      |Persistent storage for productions.
    }
  }
  projector ProductionMetrics is {
    updates repository ProductionContext.ProductionRepository
    record EventMetrics is  {
      productionsCreated: Natural with {
        briefly "Created"
        described as {
          |Productions created.
        }
      }
      productionsCompleted: Natural with {
        briefly "Completed"
        described as {
          |Productions completed.
        }
      }
      productionsCancelled: Natural with {
        briefly "Cancelled"
        described as {
          |Productions cancelled.
        }
      }
      totalAttendance: Natural with {
        briefly "Attendance"
        described as {
          |Total audience attendance.
        }
      }
      averageCrewSize: Decimal(8,2) with {
        briefly "Avg crew"
        described as {
          |Average crew size per production.
        }
      }
    } with {
      briefly "Event metrics"
      described as {
        |Production event metrics.
      }
    }
    handler MetricsHandler is {
      on event Production.ProductionCreated is {
        tell event Production.ProductionCreated to repository
          ProductionContext.ProductionRepository
      }
      on event Production.ShowCompleted is {
        tell event Production.ShowCompleted to repository
          ProductionContext.ProductionRepository
      }
      on event Production.ProductionCancelled is {
        tell event Production.ProductionCancelled to repository
          ProductionContext.ProductionRepository
      }
    } with {
      briefly "Maintains production metrics"
      described as {
        |Projects events into metrics.
      }
    }
  } with {
    briefly "Production metrics"
    described as {
      |Production management analytics.
    }
  }
  source ProductionEventSource is {
    outlet ProductionEvents is type ProductionEvent
    handler ProductionEventEmitter is {
      on init is {
        tell command InitializeProduction to entity
          ProductionContext.Production
      }
      on other is { ??? }
      on event Production.ProductionCreated is {
        send event Production.ProductionCreated to outlet ProductionEvents
      }
      on event Production.ShowCompleted is {
        send event Production.ShowCompleted to outlet ProductionEvents
      }
      on event Production.ProductionCancelled is {
        send event Production.ProductionCancelled to outlet ProductionEvents
      }
    } with {
      briefly "Production event emitter"
      described as {
        |Emits production lifecycle events into the streaming
        |topology.
      }
    }
  } with {
    briefly "Production event source"
    described as {
      |Publishes production entity events for streaming.
    }
  }
  sink ProductionEventSink is {
    inlet IncomingProductionEvents is type ProductionEvent
    handler ProductionEventReceiver is {
      on init is { ??? }
      on other is { ??? }
      on event Production.ProductionCreated is {
        tell event Production.ProductionCreated to repository
          ProductionContext.ProductionRepository
      }
      on event Production.ProductionCancelled is {
        tell event Production.ProductionCancelled to repository
          ProductionContext.ProductionRepository
      }
    } with {
      briefly "Production event receiver"
      described as {
        |Receives production events and persists them.
      }
    }
  } with {
    briefly "Production event sink"
    described as {
      |Receives production events from the streaming topology.
    }
  }
  connector ProductionEventPipeline is {
    from outlet ProductionContext.ProductionEventSource.ProductionEvents
      to inlet ProductionContext.ProductionEventSink.IncomingProductionEvents
  } with {
    briefly "Production event pipeline"
    described as {
      |Wires production events from source to sink.
    }
  }
} with {
  briefly "Bounded context for production management"
  described as {
    |Live event production management context.
  }
}
