// Portfolio Management - Portfolio Context
context PortfolioContext is {
  include "types.riddl"
  include "PortfolioCompany.riddl"
  // Repository for portfolio company persistence
  repository PortfolioRepository is {
    schema PortfolioData is relational
      of portfolioCompanies as type PortfolioCompany
        index on field PortfolioCompany.companyId
        index on field PortfolioCompany.investment.fundId
        index on field PortfolioCompany.status

    handler PortfolioPersistence is {
      on command PortfolioCompany.AcquireCompany is {
        tell event PortfolioCompany.CompanyAcquired to entity PortfolioContext.PortfolioCompany
      }
      on command PortfolioCompany.UpdateCompanyInfo is {
        tell event PortfolioCompany.CompanyInfoUpdated to entity PortfolioContext.PortfolioCompany
      }
      on command PortfolioCompany.RecordFinancials is {
        tell event PortfolioCompany.FinancialsRecorded to entity PortfolioContext.PortfolioCompany
      }
      on command PortfolioCompany.UpdateValuation is {
        tell event PortfolioCompany.ValuationUpdated to entity PortfolioContext.PortfolioCompany
      }
      on command PortfolioCompany.MakeFollowOn is {
        tell event PortfolioCompany.FollowOnMade to entity PortfolioContext.PortfolioCompany
      }
      on command PortfolioCompany.AppointBoardMember is {
        tell event PortfolioCompany.BoardMemberAppointed to entity PortfolioContext.PortfolioCompany
      }
      on command PortfolioCompany.RemoveBoardMember is {
        tell event PortfolioCompany.BoardMemberRemoved to entity PortfolioContext.PortfolioCompany
      }
      on command PortfolioCompany.ExitInvestment is {
        tell event PortfolioCompany.InvestmentExited to entity PortfolioContext.PortfolioCompany
      }
      on command PortfolioCompany.WriteOffInvestment is {
        tell event PortfolioCompany.InvestmentWrittenOff to entity PortfolioContext.PortfolioCompany
      }
    } with {
      briefly "Persists portfolio company events"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Portfolio data persistence"
    described as {
      | The PortfolioRepository provides persistent storage for
      | portfolio companies, valuations, and financial data.
    }
  }
  // Projector for portfolio analytics
  projector PortfolioAnalytics is {
    updates repository PortfolioContext.PortfolioRepository
    record PortfolioSummary is  {
      totalCompanies: Natural with {
        briefly "Companies"
        described as {
          |Total portfolio companies.
        }
      }
      activeCompanies: Natural with {
        briefly "Active"
        described as {
          |Active companies.
        }
      }
      totalInvested: MonetaryAmount with {
        briefly "Invested"
        described as {
          |Total capital invested.
        }
      }
      currentValue: MonetaryAmount with {
        briefly "Value"
        described as {
          |Current portfolio value.
        }
      }
      unrealizedGain: MonetaryAmount with {
        briefly "Unrealized"
        described as {
          |Unrealized gain/loss.
        }
      }
      grossMOIC: Decimal(6,2) with {
        briefly "MOIC"
        described as {
          |Gross multiple on invested capital.
        }
      }
    } with {
      briefly "Portfolio summary"
      described as {
        |Aggregate portfolio metrics.
      }
    }
    record FundPerformance is  {
      fundId: FundId with {
        briefly "Fund"
        described as {
          |Fund identifier.
        }
      }
      investedCapital: MonetaryAmount with {
        briefly "Invested"
        described as {
          |Capital invested.
        }
      }
      realizedValue: MonetaryAmount with {
        briefly "Realized"
        described as {
          |Realized proceeds.
        }
      }
      unrealizedValue: MonetaryAmount with {
        briefly "Unrealized"
        described as {
          |Unrealized value.
        }
      }
      totalValue: MonetaryAmount with {
        briefly "Total"
        described as {
          |Total value.
        }
      }
      grossMOIC: Decimal(6,2) with {
        briefly "MOIC"
        described as {
          |Gross multiple.
        }
      }
      netIRR: Decimal(6,2) with {
        briefly "IRR"
        described as {
          |Net IRR.
        }
      }
    } with {
      briefly "Fund performance"
      described as {
        |Fund-level performance metrics.
      }
    }
    record CompanyPerformance is  {
      companyId: PortfolioCompanyId with {
        briefly "Company"
        described as {
          |Company ID.
        }
      }
      companyName: String(1,200) with {
        briefly "Name"
        described as {
          |Company name.
        }
      }
      invested: MonetaryAmount with {
        briefly "Invested"
        described as {
          |Capital invested.
        }
      }
      currentValue: MonetaryAmount with {
        briefly "Value"
        described as {
          |Current value.
        }
      }
      moic: Decimal(6,2) with {
        briefly "MOIC"
        described as {
          |Return multiple.
        }
      }
      holdingPeriod: Natural with {
        briefly "Holding"
        described as {
          |Holding period in months.
        }
      }
      lastRevenueGrowth: Decimal(6,2) with {
        briefly "Growth"
        described as {
          |Last revenue growth.
        }
      }
    } with {
      briefly "Company performance"
      described as {
        |Individual company performance.
      }
    }
    handler AnalyticsHandler is {
      on event PortfolioCompany.CompanyAcquired is {
        tell event PortfolioCompany.CompanyAcquired to repository PortfolioContext.PortfolioRepository
      }
      on event PortfolioCompany.ValuationUpdated is {
        tell event PortfolioCompany.ValuationUpdated to repository PortfolioContext.PortfolioRepository
      }
      on event PortfolioCompany.FollowOnMade is {
        tell event PortfolioCompany.FollowOnMade to repository PortfolioContext.PortfolioRepository
      }
      on event PortfolioCompany.InvestmentExited is {
        tell event PortfolioCompany.InvestmentExited to repository PortfolioContext.PortfolioRepository
      }
      on event PortfolioCompany.FinancialsRecorded is {
        tell event PortfolioCompany.FinancialsRecorded to repository PortfolioContext.PortfolioRepository
      }
    } with {
      briefly "Maintains portfolio analytics"
      described as {
        |Projects events into analytics views.
      }
    }
  } with {
    briefly "Portfolio analytics projections"
    described as {
      |Maintains portfolio performance analytics.
    }
  }
  source PortfolioCompanySource is {
    outlet PortfolioCompanyEvents is type PortfolioCompanyEvent
    handler PortfolioCompanySourceHandler is {
      on init is {
        tell command PortfolioCompany.InitializePortfolioCompany to entity PortfolioContext.PortfolioCompany
      }
      on other is { ??? }
      on event PortfolioCompany.CompanyAcquired is {
        send event PortfolioCompany.CompanyAcquired to outlet PortfolioCompanyEvents
      }
      on event PortfolioCompany.ValuationUpdated is {
        send event PortfolioCompany.ValuationUpdated to outlet PortfolioCompanyEvents
      }
      on event PortfolioCompany.InvestmentExited is {
        send event PortfolioCompany.InvestmentExited to outlet PortfolioCompanyEvents
      }
    } with {
      briefly "Portfolio company source handler"
      described as {
        |Handles portfolio company events and sends to outlet.
      }
    }
  } with {
    briefly "Portfolio company event source"
    described as {
      |Publishes portfolio company entity events.
    }
  }
  sink PortfolioCompanySink is {
    inlet PortfolioCompanyInlet is type PortfolioCompanyEvent
    handler PortfolioCompanySinkHandler is {
      on init is { ??? }
      on other is { ??? }
      on event PortfolioCompany.CompanyAcquired is {
        tell event PortfolioCompany.CompanyAcquired to repository PortfolioContext.PortfolioRepository
      }
      on event PortfolioCompany.ValuationUpdated is {
        tell event PortfolioCompany.ValuationUpdated to repository PortfolioContext.PortfolioRepository
      }
      on event PortfolioCompany.InvestmentExited is {
        tell event PortfolioCompany.InvestmentExited to repository PortfolioContext.PortfolioRepository
      }
    } with {
      briefly "Portfolio company sink handler"
      described as {
        |Receives portfolio company events and persists them.
      }
    }
  } with {
    briefly "Portfolio company event sink"
    described as {
      |Receives portfolio company events for persistence.
    }
  }
  connector PortfolioCompanyFlow is {
    from outlet PortfolioContext.PortfolioCompanySource.PortfolioCompanyEvents to
      inlet PortfolioContext.PortfolioCompanySink.PortfolioCompanyInlet
  } with {
    briefly "Portfolio company event flow"
    described as {
      |Connects portfolio company source to sink.
    }
  }
} with {
  briefly "Bounded context for portfolio management"
  described as {
    | The PortfolioContext is the bounded context for
    | private equity portfolio company management.
  }
}
