// Portfolio Management - VC Portfolio Context
context VCPortfolioContext is {
  include "types.riddl"
  include "PortfolioInvestment.riddl"
  repository PortfolioRepository is {
    schema PortfolioData is relational
      of portfolioInvestments as type PortfolioInvestment
        index on field PortfolioInvestment.investmentId
        index on field PortfolioInvestment.companyInfo.companyId
        index on field PortfolioInvestment.status

    handler PortfolioPersistence is {
      on command PortfolioInvestment.RecordInvestment is {
        tell event PortfolioInvestment.InvestmentRecorded to entity VCPortfolioContext.PortfolioInvestment
      }
      on command PortfolioInvestment.AddMilestone is {
        tell event PortfolioInvestment.MilestoneAdded to entity VCPortfolioContext.PortfolioInvestment
      }
      on command PortfolioInvestment.UpdateMilestone is {
        tell event PortfolioInvestment.MilestoneUpdated to entity VCPortfolioContext.PortfolioInvestment
      }
      on command PortfolioInvestment.AssignBoardSeat is {
        tell event PortfolioInvestment.BoardSeatAssigned to entity VCPortfolioContext.PortfolioInvestment
      }
      on command PortfolioInvestment.RecordFollowOn is {
        tell event PortfolioInvestment.FollowOnRecorded to entity VCPortfolioContext.PortfolioInvestment
      }
      on command PortfolioInvestment.RecordExit is {
        tell event PortfolioInvestment.ExitRecorded to entity VCPortfolioContext.PortfolioInvestment
      }
      on command PortfolioInvestment.WriteOff is {
        tell event PortfolioInvestment.InvestmentWrittenOff to entity VCPortfolioContext.PortfolioInvestment
      }
    } with {
      briefly "Persists portfolio commands"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Portfolio data persistence"
    described as {
      |Persistent storage for portfolio investments.
    }
  }
  projector PortfolioAnalytics is {
    updates repository VCPortfolioContext.PortfolioRepository
    record FundMetrics is  {
      totalInvested: Decimal(14,2) with {
        briefly "Invested"
        described as {
          |Total capital invested.
        }
      }
      totalRealized: Decimal(14,2) with {
        briefly "Realized"
        described as {
          |Total realized returns.
        }
      }
      activeInvestments: Natural with {
        briefly "Active"
        described as {
          |Active investment count.
        }
      }
      exitedInvestments: Natural with {
        briefly "Exited"
        described as {
          |Exited investment count.
        }
      }
      writtenOffCount: Natural with {
        briefly "Written off"
        described as {
          |Written-off investment count.
        }
      }
      averageMOIC: Decimal(6,2) with {
        briefly "Avg MOIC"
        described as {
          |Average multiple on invested capital.
        }
      }
    } with {
      briefly "Fund metrics"
      described as {
        |Fund-level performance metrics.
      }
    }
    handler AnalyticsHandler is {
      on event PortfolioInvestment.InvestmentRecorded is {
        tell event PortfolioInvestment.InvestmentRecorded to repository VCPortfolioContext.PortfolioRepository
      }
      on event PortfolioInvestment.FollowOnRecorded is {
        tell event PortfolioInvestment.FollowOnRecorded to repository VCPortfolioContext.PortfolioRepository
      }
      on event PortfolioInvestment.ExitRecorded is {
        tell event PortfolioInvestment.ExitRecorded to repository VCPortfolioContext.PortfolioRepository
      }
      on event PortfolioInvestment.InvestmentWrittenOff is {
        tell event PortfolioInvestment.InvestmentWrittenOff to repository VCPortfolioContext.PortfolioRepository
      }
      on event PortfolioInvestment.InvestmentMarkedDown is {
        tell event PortfolioInvestment.InvestmentMarkedDown to repository VCPortfolioContext.PortfolioRepository
      }
    } with {
      briefly "Maintains portfolio analytics"
      described as {
        |Projects events into fund metrics.
      }
    }
  } with {
    briefly "Portfolio analytics"
    described as {
      |Fund-level portfolio performance analytics.
    }
  }
  source PortfolioInvestmentSource is {
    outlet PortfolioInvestmentEvents is type PortfolioInvestmentEvent
    handler PortfolioInvestmentSourceHandler is {
      on init is {
        tell command PortfolioInvestment.InitializePortfolioInvestment to entity VCPortfolioContext.PortfolioInvestment
      }
      on other is { ??? }
      on event PortfolioInvestment.InvestmentRecorded is {
        send event PortfolioInvestment.InvestmentRecorded to outlet PortfolioInvestmentEvents
      }
      on event PortfolioInvestment.ExitRecorded is {
        send event PortfolioInvestment.ExitRecorded to outlet PortfolioInvestmentEvents
      }
      on event PortfolioInvestment.InvestmentWrittenOff is {
        send event PortfolioInvestment.InvestmentWrittenOff to outlet PortfolioInvestmentEvents
      }
    } with {
      briefly "Portfolio investment source handler"
      described as {
        |Handles portfolio investment events and sends to outlet.
      }
    }
  } with {
    briefly "Portfolio investment event source"
    described as {
      |Publishes portfolio investment entity events.
    }
  }
  sink PortfolioInvestmentSink is {
    inlet PortfolioInvestmentInlet is type PortfolioInvestmentEvent
    handler PortfolioInvestmentSinkHandler is {
      on init is { ??? }
      on other is { ??? }
      on event PortfolioInvestment.InvestmentRecorded is {
        tell event PortfolioInvestment.InvestmentRecorded to repository VCPortfolioContext.PortfolioRepository
      }
      on event PortfolioInvestment.ExitRecorded is {
        tell event PortfolioInvestment.ExitRecorded to repository VCPortfolioContext.PortfolioRepository
      }
    } with {
      briefly "Portfolio investment sink handler"
      described as {
        |Receives portfolio investment events and persists them.
      }
    }
  } with {
    briefly "Portfolio investment event sink"
    described as {
      |Receives portfolio investment events for persistence.
    }
  }
  connector PortfolioInvestmentFlow is {
    from outlet VCPortfolioContext.PortfolioInvestmentSource.PortfolioInvestmentEvents to
      inlet VCPortfolioContext.PortfolioInvestmentSink.PortfolioInvestmentInlet
  } with {
    briefly "Portfolio investment event flow"
    described as {
      |Connects portfolio investment source to sink.
    }
  }
} with {
  briefly "Bounded context for VC portfolio management"
  described as {
    |Venture capital portfolio management context.
  }
}
