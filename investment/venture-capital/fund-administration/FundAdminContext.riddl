// Fund Administration - Fund Admin Context
context FundAdminContext is {
  include "types.riddl"
  include "FundAccount.riddl"
  repository FundAdminRepository is {
    schema FundAdminData is relational
      of fundAccounts as type FundAccount
        index on field FundAccount.accountId
        index on field FundAccount.fundInfo.fundId
        index on field FundAccount.status

    handler FundAdminPersistence is {
      on command FundAccount.CreateFundAccount is {
        tell event FundAccount.FundAccountCreated to entity FundAdminContext.FundAccount
      }
      on command FundAccount.IssueCapitalCall is {
        tell event FundAccount.CapitalCallIssued to entity FundAdminContext.FundAccount
      }
      on command FundAccount.RecordCallPayment is {
        tell event FundAccount.CallPaymentReceived to entity FundAdminContext.FundAccount
      }
      on command FundAccount.ProcessDistribution is {
        tell event FundAccount.DistributionProcessed to entity FundAdminContext.FundAccount
      }
      on command FundAccount.CalculateNav is {
        tell event FundAccount.NavCalculated to entity FundAdminContext.FundAccount
      }
      on command FundAccount.RecordTransaction is {
        tell event FundAccount.TransactionRecorded to entity FundAdminContext.FundAccount
      }
    } with {
      briefly "Persists fund administration events"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Fund administration data persistence"
    described as {
      |Persistent storage for fund administration.
    }
  }
  projector FundMetrics is {
    updates repository FundAdminContext.FundAdminRepository
    record FundPerformanceMetrics is  {
      totalFundsManaged: Natural with {
        briefly "Funds"
        described as {
          |Total funds managed.
        }
      }
      totalCapitalCommitted: Decimal(18,2) with {
        briefly "Committed"
        described as {
          |Total capital committed.
        }
      }
      totalCapitalCalled: Decimal(18,2) with {
        briefly "Called"
        described as {
          |Total capital called.
        }
      }
      totalDistributions: Decimal(18,2) with {
        briefly "Distributed"
        described as {
          |Total distributions.
        }
      }
      averageNavPerFund: Decimal(18,2) with {
        briefly "Avg NAV"
        described as {
          |Average NAV per fund.
        }
      }
    } with {
      briefly "Fund performance metrics"
      described as {
        |Aggregate fund performance statistics.
      }
    }
    handler MetricsHandler is {
      on event FundAccount.FundAccountCreated is {
        tell event FundAccount.FundAccountCreated to repository FundAdminContext.FundAdminRepository
      }
      on event FundAccount.CapitalCallIssued is {
        tell event FundAccount.CapitalCallIssued to repository FundAdminContext.FundAdminRepository
      }
      on event FundAccount.DistributionProcessed is {
        tell event FundAccount.DistributionProcessed to repository FundAdminContext.FundAdminRepository
      }
      on event FundAccount.NavCalculated is {
        tell event FundAccount.NavCalculated to repository FundAdminContext.FundAdminRepository
      }
    } with {
      briefly "Maintains fund performance metrics"
      described as {
        |Projects events into performance metrics.
      }
    }
  } with {
    briefly "Fund performance metrics"
    described as {
      |Fund administration analytics.
    }
  }
  source FundAccountSource is {
    outlet FundAccountEvents is type FundAccountEvent
    handler FundAccountSourceHandler is {
      on init is {
        tell command FundAccount.InitializeFundAccount to entity FundAdminContext.FundAccount
      }
      on other is { ??? }
      on event FundAccount.FundAccountCreated is {
        send event FundAccount.FundAccountCreated to outlet FundAccountEvents
      }
      on event FundAccount.CapitalCallIssued is {
        send event FundAccount.CapitalCallIssued to outlet FundAccountEvents
      }
      on event FundAccount.FundTerminated is {
        send event FundAccount.FundTerminated to outlet FundAccountEvents
      }
    } with {
      briefly "Fund account source handler"
      described as {
        |Handles fund account events and sends to outlet.
      }
    }
  } with {
    briefly "Fund account event source"
    described as {
      |Publishes fund account entity events.
    }
  }
  sink FundAccountSink is {
    inlet FundAccountInlet is type FundAccountEvent
    handler FundAccountSinkHandler is {
      on init is { ??? }
      on other is { ??? }
      on event FundAccount.FundAccountCreated is {
        tell event FundAccount.FundAccountCreated to repository FundAdminContext.FundAdminRepository
      }
      on event FundAccount.CapitalCallIssued is {
        tell event FundAccount.CapitalCallIssued to repository FundAdminContext.FundAdminRepository
      }
    } with {
      briefly "Fund account sink handler"
      described as {
        |Receives fund account events and persists them.
      }
    }
  } with {
    briefly "Fund account event sink"
    described as {
      |Receives fund account events for persistence.
    }
  }
  connector FundAccountFlow is {
    from outlet FundAdminContext.FundAccountSource.FundAccountEvents to
      inlet FundAdminContext.FundAccountSink.FundAccountInlet
  } with {
    briefly "Fund account event flow"
    described as {
      |Connects fund account source to sink.
    }
  }
} with {
  briefly "Bounded context for fund administration"
  described as {
    |Venture capital fund administration context.
  }
}
