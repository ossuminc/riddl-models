// Investment Portfolio - Portfolio Context
context PortfolioContext is {
  include "types.riddl"
  include "Portfolio.riddl"
  repository PortfolioRepository is {
    schema PortfolioData is relational
      of portfolios as type Portfolio
        index on field Portfolio.portfolioId
        index on field Portfolio.accountId
        index on field Portfolio.status

    handler PortfolioPersistence is {
      on command Portfolio.CreatePortfolio is {
        tell event Portfolio.PortfolioCreated to entity PortfolioContext.Portfolio
      }
      on command Portfolio.UpdateAllocations is {
        tell event Portfolio.AllocationsUpdated to entity PortfolioContext.Portfolio
      }
      on command Portfolio.RebalancePortfolio is {
        tell event Portfolio.PortfolioRebalanced to entity PortfolioContext.Portfolio
      }
      on command Portfolio.RecordTradeFill is {
        tell event Portfolio.TradeFilled to entity PortfolioContext.Portfolio
      }
      on command Portfolio.AnalyzeRisk is {
        tell event Portfolio.RiskAnalyzed to entity PortfolioContext.Portfolio
      }
      on command Portfolio.ClosePortfolio is {
        tell event Portfolio.PortfolioClosed to entity PortfolioContext.Portfolio
      }
    } with {
      briefly "Persists portfolio commands"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Portfolio data persistence"
    described as {
      |Persistent storage for portfolios.
    }
  }
  projector PortfolioMetrics is {
    updates repository PortfolioContext.PortfolioRepository
    record PortfolioAnalytics is  {
      totalPortfolios: Natural with {
        briefly "Total"
        described as {
          |Total portfolios.
        }
      }
      activePortfolios: Natural with {
        briefly "Active"
        described as {
          |Active portfolios.
        }
      }
      totalTradesExecuted: Natural with {
        briefly "Trades"
        described as {
          |Total trades executed.
        }
      }
      averageTrackingError: Decimal(8,4) with {
        briefly "Avg tracking error"
        described as {
          |Average tracking error.
        }
      }
    } with {
      briefly "Portfolio analytics"
      described as {
        |Aggregate portfolio metrics.
      }
    }
    handler MetricsHandler is {
      on event Portfolio.PortfolioCreated is {
        tell event Portfolio.PortfolioCreated to repository PortfolioContext.PortfolioRepository
      }
      on event Portfolio.TradeExecuted is {
        tell event Portfolio.TradeExecuted to repository PortfolioContext.PortfolioRepository
      }
      on event Portfolio.BenchmarkCompared is {
        tell event Portfolio.BenchmarkCompared to repository PortfolioContext.PortfolioRepository
      }
      on event Portfolio.PortfolioClosed is {
        tell event Portfolio.PortfolioClosed to repository PortfolioContext.PortfolioRepository
      }
    } with {
      briefly "Maintains portfolio metrics"
      described as {
        |Projects events into analytics.
      }
    }
  } with {
    briefly "Portfolio metrics"
    described as {
      |Investment portfolio analytics.
    }
  }
  source PortfolioSource is {
    outlet PortfolioEvents is type PortfolioEvent
    handler PortfolioSourceHandler is {
      on init is {
        tell command Portfolio.InitializePortfolio to entity PortfolioContext.Portfolio
      }
      on other is { ??? }
      on event Portfolio.PortfolioCreated is {
        send event Portfolio.PortfolioCreated to outlet PortfolioEvents
      }
      on event Portfolio.TradeExecuted is {
        send event Portfolio.TradeExecuted to outlet PortfolioEvents
      }
      on event Portfolio.PortfolioClosed is {
        send event Portfolio.PortfolioClosed to outlet PortfolioEvents
      }
    } with {
      briefly "Portfolio source handler"
      described as {
        |Handles portfolio events and sends to outlet.
      }
    }
  } with {
    briefly "Portfolio event source"
    described as {
      |Publishes portfolio entity events.
    }
  }
  sink PortfolioSink is {
    inlet PortfolioInlet is type PortfolioEvent
    handler PortfolioSinkHandler is {
      on init is { ??? }
      on other is { ??? }
      on event Portfolio.PortfolioCreated is {
        tell event Portfolio.PortfolioCreated to repository PortfolioContext.PortfolioRepository
      }
      on event Portfolio.TradeExecuted is {
        tell event Portfolio.TradeExecuted to repository PortfolioContext.PortfolioRepository
      }
      on event Portfolio.PortfolioClosed is {
        tell event Portfolio.PortfolioClosed to repository PortfolioContext.PortfolioRepository
      }
    } with {
      briefly "Portfolio sink handler"
      described as {
        |Receives portfolio events and persists them.
      }
    }
  } with {
    briefly "Portfolio event sink"
    described as {
      |Receives portfolio events for persistence.
    }
  }
  connector PortfolioFlow is {
    from outlet PortfolioContext.PortfolioSource.PortfolioEvents to
      inlet PortfolioContext.PortfolioSink.PortfolioInlet
  } with {
    briefly "Portfolio event flow"
    described as {
      |Connects portfolio source to sink.
    }
  }
} with {
  briefly "Bounded context for portfolio management"
  described as {
    |Investment portfolio management context.
  }
}
