// Client Reporting - Reporting Context
context ReportingContext is {
  include "types.riddl"
  include "ClientReport.riddl"
  repository ReportingRepository is {
    schema ReportingData is relational
      of clientReports as type ClientReport
        index on field ClientReport.reportId
        index on field ClientReport.request.clientId
        index on field ClientReport.status

    handler ReportingPersistence is {
      on command ClientReport.GenerateReport is {
        tell event ClientReport.ReportGenerated to entity ReportingContext.ClientReport
      }
      on command ClientReport.AttachPortfolioData is {
        tell event ClientReport.PortfolioDataAttached to entity ReportingContext.ClientReport
      }
      on command ClientReport.CalculatePerformance is {
        tell event ClientReport.PerformanceCalculated to entity ReportingContext.ClientReport
      }
      on command ClientReport.ApproveReport is {
        tell event ClientReport.ReportApproved to entity ReportingContext.ClientReport
      }
      on command ClientReport.DistributeReport is {
        tell event ClientReport.ReportDistributed to entity ReportingContext.ClientReport
      }
    } with {
      briefly "Persists reporting commands"
      described as {
        |Handles command-driven persistence.
      }
    }
  } with {
    briefly "Reporting data persistence"
    described as {
      |Persistent storage for client reports.
    }
  }
  projector ReportingMetrics is {
    updates repository ReportingContext.ReportingRepository
    record ClientReportMetrics is  {
      reportsGenerated: Natural with {
        briefly "Generated"
        described as {
          |Reports generated.
        }
      }
      reportsDistributed: Natural with {
        briefly "Distributed"
        described as {
          |Reports distributed.
        }
      }
      reportsFailed: Natural with {
        briefly "Failed"
        described as {
          |Reports failed.
        }
      }
      averageProcessingTime: Decimal(8,2) with {
        briefly "Avg time"
        described as {
          |Average processing hours.
        }
      }
    } with {
      briefly "Client report metrics"
      described as {
        |Report processing metrics.
      }
    }
    handler MetricsHandler is {
      on event ClientReport.ReportGenerated is {
        tell event ClientReport.ReportGenerated to repository ReportingContext.ReportingRepository
      }
      on event ClientReport.ReportDistributed is {
        tell event ClientReport.ReportDistributed to repository ReportingContext.ReportingRepository
      }
      on event ClientReport.ReportFailed is {
        tell event ClientReport.ReportFailed to repository ReportingContext.ReportingRepository
      }
    } with {
      briefly "Maintains reporting metrics"
      described as {
        |Projects events into metrics.
      }
    }
  } with {
    briefly "Reporting metrics"
    described as {
      |Client reporting analytics.
    }
  }
  source ClientReportSource is {
    outlet ClientReportEvents is type ClientReportEvent
    handler ClientReportSourceHandler is {
      on init is {
        tell command ClientReport.InitializeClientReport to entity ReportingContext.ClientReport
      }
      on other is { ??? }
      on event ClientReport.ReportGenerated is {
        send event ClientReport.ReportGenerated to outlet ClientReportEvents
      }
      on event ClientReport.ReportDistributed is {
        send event ClientReport.ReportDistributed to outlet ClientReportEvents
      }
      on event ClientReport.ReportFailed is {
        send event ClientReport.ReportFailed to outlet ClientReportEvents
      }
      on event ClientReport.ReportArchived is {
        send event ClientReport.ReportArchived to outlet ClientReportEvents
      }
    } with {
      briefly "Client report source handler"
      described as {
        |Handles client report events and sends to outlet.
      }
    }
  } with {
    briefly "Client report event source"
    described as {
      |Publishes client report entity events.
    }
  }
  sink ClientReportSink is {
    inlet ClientReportInlet is type ClientReportEvent
    handler ClientReportSinkHandler is {
      on init is { ??? }
      on other is { ??? }
      on event ClientReport.ReportGenerated is {
        tell event ClientReport.ReportGenerated to repository ReportingContext.ReportingRepository
      }
      on event ClientReport.ReportDistributed is {
        tell event ClientReport.ReportDistributed to repository ReportingContext.ReportingRepository
      }
      on event ClientReport.ReportFailed is {
        tell event ClientReport.ReportFailed to repository ReportingContext.ReportingRepository
      }
    } with {
      briefly "Client report sink handler"
      described as {
        |Receives client report events and persists them.
      }
    }
  } with {
    briefly "Client report event sink"
    described as {
      |Receives client report events for persistence.
    }
  }
  connector ClientReportFlow is {
    from outlet ReportingContext.ClientReportSource.ClientReportEvents to
      inlet ReportingContext.ClientReportSink.ClientReportInlet
  } with {
    briefly "Client report event flow"
    described as {
      |Connects client report source to sink.
    }
  }
} with {
  briefly "Bounded context for client reporting"
  described as {
    |Investment client reporting context.
  }
}
