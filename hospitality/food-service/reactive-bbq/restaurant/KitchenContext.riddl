// Kitchen bounded context
context Kitchen is {
  include "kitchen-types.riddl"
  include "KitchenTicket.riddl"
  repository KitchenTicketRepository is {
    schema KitchenTicketData is relational
      of tickets as type KitchenTicket
        index on field KitchenTicket.kitchenTicketId
        index on field KitchenTicket.ticketStatus
        index on field KitchenTicket.assignedStation

    handler KitchenTicketPersistence is {
      on command KitchenTicket.ReceiveTicket is {
        tell event KitchenTicket.TicketReceived to entity
          Kitchen.KitchenTicket
        do "insert row into KitchenTicketData.tickets with
          kitchenTicketId, sourceOrderId, ticketSource,
          ticketItems, ticketStatus = Received, receivedAt"
      }
      on command KitchenTicket.AssignStation is {
        tell event KitchenTicket.StationAssigned to entity
          Kitchen.KitchenTicket
        do "update KitchenTicketData.tickets set currentStation
          = assignedStation, ticketStatus = Assigned where
          kitchenTicketId matches"
      }
      on command KitchenTicket.StartPreparation is {
        tell event KitchenTicket.PreparationStarted to entity
          Kitchen.KitchenTicket
        do "update KitchenTicketData.tickets set ticketStatus =
          InPreparation, actualPreparationStartedAt = startedAt
          where kitchenTicketId matches"
      }
      on command KitchenTicket.MarkItemReady is {
        tell event KitchenTicket.ItemMarkedReady to entity
          Kitchen.KitchenTicket
        do "update KitchenTicketData.tickets set
          ticketItems[readyMenuItemId].ticketItemReady = true
          where kitchenTicketId matches"
      }
      on command KitchenTicket.ApproveTicket is {
        tell event KitchenTicket.TicketApproved to entity
          Kitchen.KitchenTicket
        do "update KitchenTicketData.tickets set ticketStatus =
          Approved, ticketApprovedAt = approvedAt where
          kitchenTicketId matches"
      }
      on command KitchenTicket.NotifyServer is {
        tell event KitchenTicket.ServerNotified to entity
          Kitchen.KitchenTicket
        do "update KitchenTicketData.tickets set ticketStatus =
          ServerNotifiedTicket where kitchenTicketId matches"
      }
    } with {
      briefly "Kitchen ticket persistence"
      described as {
        |Persists kitchen ticket events to the tickets table
        |and updates the current state projection.
      }
    }
  } with {
    briefly "Kitchen ticket repository"
    described as {
      |Stores and retrieves kitchen ticket data.
    }
  }
  projector KitchenDisplay is {
    record KitchenDisplayEntry is  {
      kitchenTicketId: KitchenTicketId with {
        briefly "ID"
        described as {
          |Ticket identifier.
        }
      }
      ticketSource: TicketSource with {
        briefly "Source"
        described as {
          |Dine-in or online.
        }
      }
      ticketItems: TicketItem+ with {
        briefly "Items"
        described as {
          |Items on the ticket.
        }
      }
      ticketStatus: TicketStatus with {
        briefly "Status"
        described as {
          |Current status.
        }
      }
      displayStation: StationName? with {
        briefly "Station"
        described as {
          |Assigned station.
        }
      }
      receivedAt: TimeStamp with {
        briefly "Received at"
        described as {
          |When received.
        }
      }
    } with {
      briefly "Display entry"
      described as {
        |A single entry on the kitchen display.
      }
    }
    handler KitchenDisplayHandler is {
      on event KitchenTicket.TicketReceived is {
        do "insert KitchenDisplayEntry with kitchenTicketId =
          event.kitchenTicketId, ticketSource =
          event.ticketSource, ticketItems = event.ticketItems,
          ticketStatus = Received, displayStation = none,
          receivedAt = event.receivedAt"
      }
      on event KitchenTicket.StationAssigned is {
        do "update KitchenDisplayEntry set displayStation =
          event.assignedStation, ticketStatus = Assigned
          where kitchenTicketId = event.kitchenTicketId"
      }
      on event KitchenTicket.PreparationStarted is {
        do "update KitchenDisplayEntry set ticketStatus =
          InPreparation where kitchenTicketId =
          event.kitchenTicketId"
      }
      on event KitchenTicket.ItemMarkedReady is {
        do "update KitchenDisplayEntry set
          ticketItems[event.readyMenuItemId].ticketItemReady
          = true where kitchenTicketId =
          event.kitchenTicketId"
      }
      on event KitchenTicket.TicketApproved is {
        do "update KitchenDisplayEntry set ticketStatus =
          Approved where kitchenTicketId =
          event.kitchenTicketId"
      }
      on event KitchenTicket.ServerNotified is {
        do "delete KitchenDisplayEntry where kitchenTicketId =
          event.kitchenTicketId"
      }
    } with {
      briefly "Kitchen display handler"
      described as {
        |Projects ticket events onto the real-time kitchen
        |display screen, replacing handwritten tickets and
        |preventing order loss during peak hours.
      }
    }
  } with {
    briefly "Kitchen display projector"
    described as {
      | Real-time kitchen display screen showing active
      | tickets, station assignments, and preparation status.
      | Replaces handwritten tickets and prevents order loss.
    }
  }
  flow TicketQueue is {
    inlet IncomingTickets is type KitchenTicketEvent
    outlet DisplayTickets is type KitchenTicketEvent
  } with {
    briefly "Kitchen ticket queue"
    described as {
      |Processes incoming kitchen tickets in FIFO order,
      |ensuring tickets are handled in the sequence received.
      |Prevents ticket loss during peak hours by providing
      |backpressure when the kitchen is at capacity.
    }
  }
  adaptor FromFrontOfHouse from context Restaurant.FrontOfHouse is {
    handler FrontOfHouseIntake is {
      on event Restaurant.FrontOfHouse.TableOrder.OrderSubmitted is {
        do "filter event.orderItems where
          orderLineItem.itemCategory is not drink"
        do "map each food OrderLine to TicketItem with
          ticketMenuItemId = orderLineItem.itemCode,
          ticketItemName = orderLineItem.itemName,
          ticketItemQuantity = orderLineQuantity,
          ticketItemNotes = orderLineNotes,
          ticketItemReady = false"
        do "construct ReceiveTicket with new KitchenTicketId,
          sourceOrderId = event.tableOrderId, ticketSource =
          DineIn, ticketItems = mapped list, receivedAt =
          current timestamp"
        tell command ReceiveTicket to entity Kitchen.KitchenTicket
      }
    } with {
      briefly "FOH intake"
      described as {
        |Converts dine-in orders to kitchen tickets with
        |DineIn source marker for display routing.
      }
    }
  } with {
    briefly "Front of house adaptor"
    described as {
      |Receives submitted dine-in orders and converts them
      |to kitchen tickets.
    }
  }
  adaptor FromOnlineOrdering from context Restaurant.OnlineOrdering is {
    handler OnlineIntake is {
      on event Restaurant.OnlineOrdering.OnlineOrder.OnlineOrderSubmitted is {
        do "map each event.orderCartItems CartItem to TicketItem
          with ticketMenuItemId = cartMenuItemId, ticketItemName
          = cartItemName, ticketItemQuantity = cartItemQuantity,
          ticketItemNotes = cartItemNotes, ticketItemReady =
          false"
        do "construct ReceiveTicket with new KitchenTicketId,
          sourceOrderId = event.onlineOrderId, ticketSource =
          Online, ticketItems = mapped list, receivedAt =
          current timestamp"
        tell command ReceiveTicket to entity Kitchen.KitchenTicket
      }
    } with {
      briefly "Online intake"
      described as {
        |Converts online orders to kitchen tickets with Online
        |source marker for fulfillment routing.
      }
    }
  } with {
    briefly "Online ordering adaptor"
    described as {
      |Receives submitted online orders and converts them
      |to kitchen tickets.
    }
  }
} with {
  briefly "Kitchen context"
  described as {
    | Manages kitchen ticket queue, station assignments,
    | preparation tracking, and quality control. Provides
    | the kitchen display screen that replaces handwritten
    | tickets and prevents order loss during peak hours.
  }
}
