// External systems used by the Restaurant domain
context PaymentGateway is {
  command AuthorizePayment is  {
    paymentGatewayTransactionId: String(1,100) with {
      briefly "Transaction ID"
      described as {
        |External transaction identifier.
      }
    }
    authorizeAmount: Decimal(10,2) with {
      briefly "Amount"
      described as {
        |Amount to authorize.
      }
    }
    authorizeMethod: String(1,50) with {
      briefly "Method"
      described as {
        |Payment method.
      }
    }
  } with {
    briefly "Authorize payment"
    described as {
      |Authorize a payment through the gateway.
    }
  }
  event PaymentAuthorized is  {
    paymentGatewayTransactionId: String(1,100) with {
      briefly "Transaction ID"
      described as {
        |External transaction identifier.
      }
    }
    authorizedAmount: Decimal(10,2) with {
      briefly "Amount"
      described as {
        |Authorized amount.
      }
    }
    authorizationCode: String(1,50) with {
      briefly "Authorization code"
      described as {
        |Gateway authorization code.
      }
    }
  } with {
    briefly "Payment authorized"
    described as {
      |Emitted when payment is authorized.
    }
  }
  command CapturePayment is  {
    captureTransactionId: String(1,100) with {
      briefly "Transaction ID"
      described as {
        |Transaction to capture.
      }
    }
    captureAmount: Decimal(10,2) with {
      briefly "Amount"
      described as {
        |Amount to capture.
      }
    }
  } with {
    briefly "Capture payment"
    described as {
      |Capture an authorized payment.
    }
  }
  event PaymentCaptured is  {
    captureTransactionId: String(1,100) with {
      briefly "Transaction ID"
      described as {
        |Captured transaction.
      }
    }
    capturedAmount: Decimal(10,2) with {
      briefly "Amount"
      described as {
        |Captured amount.
      }
    }
  } with {
    briefly "Payment captured"
    described as {
      |Emitted when payment is captured.
    }
  }
  handler PaymentHandler is {
    on command AuthorizePayment is {
      do "submit authorization request to payment processor"
    }
    on command CapturePayment is {
      do "submit capture request to payment processor"
    }
  } with {
    briefly "Payment handler"
    described as {
      |Processes payment authorization and capture requests
      |through the external payment gateway.
    }
  }
  type PaymentGatewayEvent is one of {
    PaymentGateway.PaymentAuthorized,
    PaymentGateway.PaymentCaptured
  } with {
    briefly "Payment gateway event alternation"
    described as {
      |Union of all payment gateway events for streaming.
    }
  }
  source PaymentEventSource is {
    outlet PaymentResults is type PaymentGatewayEvent
    handler PaymentEventEmitter is {
      on event PaymentAuthorized is {
        send event PaymentAuthorized to outlet PaymentResults
      }
      on event PaymentCaptured is {
        send event PaymentCaptured to outlet PaymentResults
      }
    } with {
      briefly "Payment event emitter"
      described as {
        |Emits payment gateway response events into the
        |streaming topology.
      }
    }
  } with {
    briefly "Payment event source"
    described as {
      |Emits payment authorization and capture results from
      |the external payment gateway.
    }
  }
} with {
  option external()
  briefly "External payment gateway"
  described as {
    |Third-party payment processing service.
  }
}
context NotificationService is {
  command SendPushNotification is  {
    notificationRecipient: String(1,100) with {
      briefly "Recipient"
      described as {
        |Recipient identifier.
      }
    }
    notificationTitle: String(1,200) with {
      briefly "Title"
      described as {
        |Notification title.
      }
    }
    notificationBody: String(1,1000) with {
      briefly "Body"
      described as {
        |Notification body text.
      }
    }
  } with {
    briefly "Send push notification"
    described as {
      |Send a push notification to a device.
    }
  }
  event PushNotificationSent is  {
    notificationRecipient: String(1,100) with {
      briefly "Recipient"
      described as {
        |Recipient.
      }
    }
    sentAt: TimeStamp with {
      briefly "Sent at"
      described as {
        |When the notification was sent.
      }
    }
  } with {
    briefly "Push notification sent"
    described as {
      |Emitted when a push notification is delivered.
    }
  }
  handler NotificationHandler is {
    on command SendPushNotification is {
      do "dispatch push notification to recipient device"
    }
  } with {
    briefly "Notification handler"
    described as {
      |Processes push notification dispatch requests
      |through the external notification service.
    }
  }
  type NotificationEvent is one of {
    NotificationService.PushNotificationSent
  } with {
    briefly "Notification event alternation"
    described as {
      |Union of notification service events for streaming.
    }
  }
  source NotificationEventSource is {
    outlet NotificationResults is type NotificationEvent
    handler NotificationEventEmitter is {
      on event PushNotificationSent is {
        send event PushNotificationSent to outlet NotificationResults
      }
    } with {
      briefly "Notification event emitter"
      described as {
        |Emits notification delivery confirmations into
        |the streaming topology.
      }
    }
  } with {
    briefly "Notification event source"
    described as {
      |Emits push notification delivery confirmations.
    }
  }
} with {
  option external()
  briefly "External notification service"
  described as {
    |Push notification delivery service for mobile devices.
  }
}
