// Online Ordering bounded context
context OnlineOrdering is {
  include "online-types.riddl"
  include "OnlineOrder.riddl"
  repository OnlineOrderRepository is {
    schema OnlineOrderData is relational
      of onlineOrders as type OnlineOrder
        index on field OnlineOrder.onlineOrderId
        index on field OnlineOrder.customerId
        index on field OnlineOrder.onlineOrderStatus
      with {
      briefly "Online order data schema"
      described as {
        |Relational schema for persisting online order state
        |with indexes on order, customer, and status.
      }
    }
    handler OnlineOrderPersistence is {
      on command OnlineOrder.BrowseMenu is {
        tell event OnlineOrder.MenuBrowsed to entity
          OnlineOrdering.OnlineOrder
        do "insert row into OnlineOrderData.onlineOrders with
          onlineOrderId, customerId, onlineOrderStatus =
          Browsing, createdAt = browsedAt"
      }
      on command OnlineOrder.AddToCart is {
        tell event OnlineOrder.ItemAddedToCart to entity
          OnlineOrdering.OnlineOrder
        do "append cartItem to orderCartItems array in
          OnlineOrderData.onlineOrders where onlineOrderId
          matches"
      }
      on command OnlineOrder.RemoveFromCart is {
        tell event OnlineOrder.ItemRemovedFromCart to entity
          OnlineOrdering.OnlineOrder
        do "remove CartItem with removedCartItemId from
          orderCartItems array in OnlineOrderData.onlineOrders
          where onlineOrderId matches"
      }
      on command OnlineOrder.SelectFulfillment is {
        tell event OnlineOrder.FulfillmentSelected to entity
          OnlineOrdering.OnlineOrder
        do "update OnlineOrderData.onlineOrders set
          selectedFulfillment = fulfillmentType,
          selectedDeliveryAddress = deliveryAddress,
          onlineOrderStatus = FulfillmentChosen where
          onlineOrderId matches"
      }
      on command OnlineOrder.SubmitOnlineOrder is {
        tell event OnlineOrder.OnlineOrderSubmitted to entity
          OnlineOrdering.OnlineOrder
        do "update OnlineOrderData.onlineOrders set
          onlineOrderStatus = OnlineSubmitted,
          actualOnlineSubmittedAt = onlineSubmittedAt where
          onlineOrderId matches"
      }
      on command OnlineOrder.ProcessOnlinePayment is {
        tell event OnlineOrder.OnlinePaymentProcessed to entity
          OnlineOrdering.OnlineOrder
        do "update OnlineOrderData.onlineOrders set
          processedOnlinePayment = onlinePayment,
          onlineOrderStatus = OnlinePaid where onlineOrderId
          matches"
      }
    } with {
      briefly "Online order persistence"
      described as {
        |Persists online order events to the onlineOrders table
        |and updates the current state projection.
      }
    }
  } with {
    briefly "Online order repository"
    described as {
      |Stores and retrieves online order data.
    }
  }
  source OnlineOrderEventSource is {
    outlet SubmittedOnlineOrderEvents is type OnlineOrderEvent
    handler OnlineOrderEventEmitter is {
      on event OnlineOrder.OnlineOrderSubmitted is {
        send event OnlineOrder.OnlineOrderSubmitted to
          outlet SubmittedOnlineOrderEvents
      }
    } with {
      briefly "Online order event emitter"
      described as {
        |Emits online order submission events into the
        |streaming topology for kitchen routing.
      }
    }
  } with {
    briefly "Online order event source"
    described as {
      |Emits online order submission events from the
      |OnlineOrder entity into the streaming topology for
      |kitchen routing.
    }
  }
  flow OnlineOrderPipeline is {
    inlet SubmittedOnlineOrders is type OnlineOrderEvent
    outlet KitchenOrders is type KitchenTicketEvent
    handler OnlineOrderPipelineHandler is {
      on event OnlineOrder.OnlineOrderSubmitted is {
        do "convert online order cart items to kitchen ticket
          format and forward to kitchen queue"
        send event OnlineOrder.OnlineOrderSubmitted to
          outlet KitchenOrders
      }
    } with {
      briefly "Online order pipeline handler"
      described as {
        |Converts online orders to kitchen tickets and
        |merges with dine-in orders for unified processing.
      }
    }
  } with {
    briefly "Online order pipeline"
    described as {
      |Processes submitted online orders in FIFO order,
      |converting cart items to kitchen tickets. Ensures
      |online orders are queued fairly alongside dine-in
      |orders during peak hours.
    }
  }
  adaptor ToKitchen to context Restaurant.Kitchen is {
    handler OnlineKitchenRouting is {
      on command Restaurant.Kitchen.KitchenTicket.ReceiveTicket is {
        do "map each OnlineOrderSubmitted.orderCartItems CartItem
          to TicketItem with ticketMenuItemId = cartMenuItemId,
          ticketItemName = cartItemName, ticketItemQuantity =
          cartItemQuantity, ticketItemNotes = cartItemNotes,
          ticketItemReady = false"
        do "construct ReceiveTicket with new KitchenTicketId,
          sourceOrderId = event.onlineOrderId, ticketSource =
          Online, ticketItems = mapped list, receivedAt =
          current timestamp"
        tell command ReceiveTicket to entity
          Kitchen.KitchenTicket
      }
    } with {
      briefly "Kitchen routing"
      described as {
        |Routes online orders to the kitchen.
      }
    }
  } with {
    briefly "Kitchen adaptor"
    described as {
      |Sends submitted online orders to kitchen.
    }
  }
  adaptor ToDelivery to context Restaurant.Delivery is { 
    handler DeliveryRouting is {
      on command Restaurant.Delivery.DeliveryOrder.CreateDelivery is {
        do "construct CreateDelivery with new DeliveryId,
          sourceOnlineOrderId = event.onlineOrderId,
          deliveryCustomerName from customer profile,
          deliveryCustomerPhone from customer profile,
          deliveryDestination = event.deliveryAddress,
          requestedDeliveryTime = event.requestedTime"
        tell command CreateDelivery to entity
          Delivery.DeliveryOrder
      }
    } with {
      briefly "Delivery routing"
      described as {
        |Routes delivery orders to the delivery context.
      }
    }
  } with {
    briefly "Delivery adaptor"
    described as {
      | Sends orders with delivery fulfillment to the
      | delivery context. This decoupling enables electronic
      | menus to operate independently of delivery.
    }
  }
  adaptor ToLoyalty to context Restaurant.Loyalty is { 
    handler OnlineLoyaltyRouting is {
      on command Restaurant.Loyalty.LoyaltyAccount.AccruePoints is {
        let pointsEarned = "OnlinePaymentProcessed.onlinePayment
          .onlinePaymentAmount truncated to integer as
          accrualPoints"
        do "construct AccruePoints with loyaltyAccountId looked
          up by event.customerId, accrualPoints = pointsEarned,
          accrualReason = online purchase, accrualOrderRef =
          OnlinePaymentProcessed.onlineOrderId"
        tell command AccruePoints to entity Loyalty.LoyaltyAccount
      }
    } with {
      briefly "Loyalty routing"
      described as {
        |Routes payment events for loyalty accrual.
      }
    }
  } with {
    briefly "Loyalty adaptor"
    described as {
      |Sends online payment events to loyalty context.
    }
  }
  connector OnlineSourceToPipeline is {
    from outlet
      OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
      to inlet OnlineOrdering.OnlineOrderPipeline.SubmittedOnlineOrders
  } with {
    briefly "Source to pipeline connector"
    described as {
      |Wires online order events from the source into the
      |order pipeline for kitchen routing.
    }
  }
  connector OnlineToKitchen is {
    from outlet OnlineOrdering.OnlineOrderPipeline.KitchenOrders to
      inlet Kitchen.TicketQueue.IncomingTickets
  } with {
    option is persistent
    briefly "Online to kitchen connector"
    described as {
      |Wires online orders from the order pipeline to the
      |kitchen ticket queue, merging with dine-in orders for
      |unified kitchen processing.
    }
  }
} with {
  briefly "Online ordering context"
  described as {
    | Manages the online ordering experience including menu
    | browsing, cart management, fulfillment selection, and
    | checkout. Decoupled from delivery context so electronic
    | menus can be developed independently. Communicates with
    | kitchen, delivery, and loyalty via adaptors.
  }
}
