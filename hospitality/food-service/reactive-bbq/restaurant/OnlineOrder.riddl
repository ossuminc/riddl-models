        error "Order is completed"
      }
      on command AddToCart is {
        send event AddToCartRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Order is completed"
      }
      on command RemoveFromCart is {
        send event RemoveFromCartRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Order is completed"
      }
      on command SelectFulfillment is {
        send event SelectFulfillmentRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Order is completed"
      }
      on command SubmitOnlineOrder is {
        send event SubmitOnlineOrderRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Order is completed"
      }
      on command ProcessOnlinePayment is {
        send event ProcessOnlinePaymentRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Order is completed"
      }
      on command MarkOnlineInPreparation is {
        send event MarkOnlineInPreparationRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Order is completed"
      }
      on command MarkReadyForPickup is {
        send event MarkReadyForPickupRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Order is completed"
      }
      on command MarkOutForDelivery is {
        send event MarkOutForDeliveryRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Order is completed"
      }
      on command CompleteOnlineOrder is {
        send event CompleteOnlineOrderRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Order is already completed"
      }
      on command CancelOnlineOrder is {
        send event CancelOnlineOrderRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot cancel a completed order"
      }
