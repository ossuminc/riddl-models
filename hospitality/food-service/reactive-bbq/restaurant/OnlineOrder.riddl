// OnlineOrder entity for the OnlineOrdering context
entity OnlineOrder is {
  // ---- Commands ----
  command InitializeOnlineOrder is { ??? } with {
    briefly "Initialize online order"
    described as {
      |Initialize the OnlineOrder entity on source startup.
    }
  }
  command BrowseMenu is  {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Session/order identifier.
      }
    }
    customerId: CustomerId with {
      briefly "Customer ID"
      described as {
        |Customer browsing the menu.
      }
    }
    browsedAt: TimeStamp with {
      briefly "Browsed at"
      described as {
        |When the menu was browsed.
      }
    }
  } with {
    briefly "Browse menu"
    described as {
      |Customer begins browsing the online menu.
    }
  }
  command AddToCart is  {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order to add item to.
      }
    }
    cartItem: CartItem with {
      briefly "Item"
      described as {
        |Item to add to cart.
      }
    }
  } with {
    briefly "Add to cart"
    described as {
      |Add an item to the online shopping cart.
    }
  }
  command RemoveFromCart is  {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order to remove item from.
      }
    }
    removedCartItemId: String(1,50) with {
      briefly "Menu item ID"
      described as {
        |Item to remove from cart.
      }
    }
  } with {
    briefly "Remove from cart"
    described as {
      |Remove an item from the online shopping cart.
    }
  }
  command SelectFulfillment is  {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order to set fulfillment for.
      }
    }
    fulfillmentType: FulfillmentType with {
      briefly "Fulfillment"
      described as {
        |Pickup or delivery.
      }
    }
    deliveryAddress: DeliveryAddress? with {
      briefly "Address"
      described as {
        |Delivery address if delivery fulfillment.
      }
    }
    requestedTime: TimeStamp? with {
      briefly "Requested time"
      described as {
        |Requested pickup or delivery time.
      }
    }
  } with {
    briefly "Select fulfillment"
    described as {
      |Choose pickup or delivery fulfillment.
    }
  }
  command SubmitOnlineOrder is  {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order to submit.
      }
    }
    onlineSubmittedAt: TimeStamp with {
      briefly "Submitted at"
      described as {
        |When the order was submitted.
      }
    }
  } with {
    briefly "Submit online order"
    described as {
      |Submit the online order for processing.
    }
  }
  command ProcessOnlinePayment is  {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order to pay for.
      }
    }
    onlinePayment: OnlinePaymentInfo with {
      briefly "Payment"
      described as {
        |Payment details.
      }
    }
  } with {
    briefly "Process online payment"
    described as {
      |Process payment for the online order.
    }
  }
  command MarkOnlineInPreparation is {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order being prepared.
      }
    }
  } with {
    briefly "Mark in preparation"
    described as {
      |Mark the order as actively being prepared by the
      |kitchen. Triggered by adaptor from Kitchen context.
    }
  }
  command MarkReadyForPickup is {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order ready for pickup.
      }
    }
    readyForPickupAt: TimeStamp with {
      briefly "Ready at"
      described as {
        |When the order became ready.
      }
    }
  } with {
    briefly "Mark ready for pickup"
    described as {
      |Mark a pickup order as ready for customer collection.
    }
  }
  command MarkOutForDelivery is {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order dispatched for delivery.
      }
    }
    dispatchedAt: TimeStamp with {
      briefly "Dispatched at"
      described as {
        |When the driver was dispatched.
      }
    }
  } with {
    briefly "Mark out for delivery"
    described as {
      |Mark a delivery order as dispatched with the driver.
    }
  }
  command CompleteOnlineOrder is {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order to complete.
      }
    }
    completedAt: TimeStamp with {
      briefly "Completed at"
      described as {
        |When the order was completed.
      }
    }
  } with {
    briefly "Complete online order"
    described as {
      |Mark the order as completed after pickup or delivery.
    }
  }
  command CancelOnlineOrder is {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order to cancel.
      }
    }
    cancellationReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Reason for cancellation.
      }
    }
    cancelledAt: TimeStamp with {
      briefly "Cancelled at"
      described as {
        |When the cancellation was requested.
      }
    }
  } with {
    briefly "Cancel online order"
    described as {
      |Cancel an online order. Allowed from any state before
      |delivery or pickup completion. If the order has already
      |been paid, cancellation implies a refund.
    }
  }
  // ---- Query/Result ----
  query GetOnlineOrder is {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order to retrieve.
      }
    }
  } with {
    briefly "Get online order"
    described as {
      |Query an online order by its identifier.
    }
  }
  result OnlineOrderResult is {
    order: OnlineOrderData with {
      briefly "Order"
      described as {
        |The requested online order data.
      }
    }
  } with {
    briefly "Online order result"
    described as {
      |Result containing the requested online order data.
    }
  }
  // ---- Events ----
  event MenuBrowsed is  {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    customerId: CustomerId with {
      briefly "Customer ID"
      described as {
        |Customer.
      }
    }
    browsedAt: TimeStamp with {
      briefly "Browsed at"
      described as {
        |When browsed.
      }
    }
  } with {
    briefly "Menu browsed"
    described as {
      |Emitted when a customer begins browsing.
    }
  }
  event ItemAddedToCart is  {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    cartItem: CartItem with {
      briefly "Item"
      described as {
        |Added item.
      }
    }
  } with {
    briefly "Item added to cart"
    described as {
      |Emitted when an item is added to the cart.
    }
  }
  event ItemRemovedFromCart is  {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    removedCartItemId: String(1,50) with {
      briefly "Menu item ID"
      described as {
        |Removed item.
      }
    }
  } with {
    briefly "Item removed from cart"
    described as {
      |Emitted when an item is removed from the cart.
    }
  }
  event FulfillmentSelected is  {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    fulfillmentType: FulfillmentType with {
      briefly "Fulfillment"
      described as {
        |Chosen fulfillment type.
      }
    }
    deliveryAddress: DeliveryAddress? with {
      briefly "Address"
      described as {
        |Delivery address if applicable.
      }
    }
    requestedTime: TimeStamp? with {
      briefly "Requested time"
      described as {
        |Requested time.
      }
    }
  } with {
    briefly "Fulfillment selected"
    described as {
      |Emitted when customer selects pickup or delivery.
    }
  }
  event OnlineOrderSubmitted is  {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    customerId: CustomerId with {
      briefly "Customer ID"
      described as {
        |Customer.
      }
    }
    orderCartItems: CartItem+ with {
      briefly "Items"
      described as {
        |All items in the order.
      }
    }
    fulfillmentType: FulfillmentType with {
      briefly "Fulfillment"
      described as {
        |Fulfillment type.
      }
    }
    deliveryAddress: DeliveryAddress? with {
      briefly "Address"
      described as {
        |Delivery address if applicable.
      }
    }
    onlineSubmittedAt: TimeStamp with {
      briefly "Submitted at"
      described as {
        |When submitted.
      }
    }
  } with {
    briefly "Online order submitted"
    described as {
      |Emitted when the online order is submitted.
    }
  }
  event OnlinePaymentProcessed is  {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    onlinePayment: OnlinePaymentInfo with {
      briefly "Payment"
      described as {
        |Payment details.
      }
    }
    onlinePaidAt: TimeStamp with {
      briefly "Paid at"
      described as {
        |When payment was processed.
      }
    }
  } with {
    briefly "Online payment processed"
    described as {
      |Emitted when online payment is processed.
    }
  }
  event OnlineOrderInPreparation is {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
  } with {
    briefly "Online order in preparation"
    described as {
      |Emitted when the kitchen begins preparing the order.
    }
  }
  event OnlineOrderReadyForPickup is {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    readyForPickupAt: TimeStamp with {
      briefly "Ready at"
      described as {
        |When the order became ready.
      }
    }
  } with {
    briefly "Online order ready for pickup"
    described as {
      |Emitted when a pickup order is ready for customer
      |collection.
    }
  }
  event OnlineOrderOutForDelivery is {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    dispatchedAt: TimeStamp with {
      briefly "Dispatched at"
      described as {
        |When dispatched.
      }
    }
  } with {
    briefly "Online order out for delivery"
    described as {
      |Emitted when a delivery order is dispatched.
    }
  }
  event OnlineOrderCompleted is {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    completedAt: TimeStamp with {
      briefly "Completed at"
      described as {
        |When completed.
      }
    }
  } with {
    briefly "Online order completed"
    described as {
      |Emitted when an online order is completed after
      |pickup or delivery.
    }
  }
  event OnlineOrderCancelled is {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    cancellationReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Reason for cancellation.
      }
    }
    requiresRefund: Boolean with {
      briefly "Requires refund"
      described as {
        |Whether the cancellation requires a refund of
        |previously processed payment.
      }
    }
    cancelledAt: TimeStamp with {
      briefly "Cancelled at"
      described as {
        |When cancelled.
      }
    }
  } with {
    briefly "Online order cancelled"
    described as {
      |Emitted when an online order is cancelled. If the
      |order was already paid, a refund is triggered.
    }
  }
  // ---- Rejection Events ----
  event BrowseMenuRejected is {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    rejectionReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Why the command was rejected.
      }
    }
  } with {
    briefly "Browse menu rejected"
    described as {
      |Emitted when a BrowseMenu command is rejected.
    }
  }
  event AddToCartRejected is {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    rejectionReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Why the command was rejected.
      }
    }
  } with {
    briefly "Add to cart rejected"
    described as {
      |Emitted when an AddToCart command is rejected.
    }
  }
  event RemoveFromCartRejected is {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    rejectionReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Why the command was rejected.
      }
    }
  } with {
    briefly "Remove from cart rejected"
    described as {
      |Emitted when a RemoveFromCart command is rejected.
    }
  }
  event SelectFulfillmentRejected is {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    rejectionReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Why the command was rejected.
      }
    }
  } with {
    briefly "Select fulfillment rejected"
    described as {
      |Emitted when a SelectFulfillment command is rejected.
    }
  }
  event SubmitOnlineOrderRejected is {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    rejectionReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Why the command was rejected.
      }
    }
  } with {
    briefly "Submit online order rejected"
    described as {
      |Emitted when a SubmitOnlineOrder command is rejected.
    }
  }
  event ProcessOnlinePaymentRejected is {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    rejectionReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Why the command was rejected.
      }
    }
  } with {
    briefly "Process online payment rejected"
    described as {
      |Emitted when a ProcessOnlinePayment command is rejected.
    }
  }
  event MarkOnlineInPreparationRejected is {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    rejectionReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Why the command was rejected.
      }
    }
  } with {
    briefly "Mark in preparation rejected"
    described as {
      |Emitted when a MarkOnlineInPreparation command is rejected.
    }
  }
  event MarkReadyForPickupRejected is {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    rejectionReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Why the command was rejected.
      }
    }
  } with {
    briefly "Mark ready for pickup rejected"
    described as {
      |Emitted when a MarkReadyForPickup command is rejected.
    }
  }
  event MarkOutForDeliveryRejected is {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    rejectionReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Why the command was rejected.
      }
    }
  } with {
    briefly "Mark out for delivery rejected"
    described as {
      |Emitted when a MarkOutForDelivery command is rejected.
    }
  }
  event CompleteOnlineOrderRejected is {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    rejectionReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Why the command was rejected.
      }
    }
  } with {
    briefly "Complete online order rejected"
    described as {
      |Emitted when a CompleteOnlineOrder command is rejected.
    }
  }
  event CancelOnlineOrderRejected is {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    rejectionReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Why the command was rejected.
      }
    }
  } with {
    briefly "Cancel online order rejected"
    described as {
      |Emitted when a CancelOnlineOrder command is rejected.
    }
  }
  // ---- State ----
  record OnlineOrderData is {
    onlineOrderId: OnlineOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    customerId: CustomerId with {
      briefly "Customer ID"
      described as {
        |Customer.
      }
    }
    orderCartItems: CartItem+ with {
      briefly "Items"
      described as {
        |Items in the cart.
      }
    }
    selectedFulfillment: FulfillmentType? with {
      briefly "Fulfillment"
      described as {
        |Chosen fulfillment type.
      }
    }
    selectedDeliveryAddress: DeliveryAddress? with {
      briefly "Address"
      described as {
        |Delivery address if applicable.
      }
    }
    processedOnlinePayment: OnlinePaymentInfo? with {
      briefly "Payment"
      described as {
        |Payment info when processed.
      }
    }
    createdAt: TimeStamp with {
      briefly "Created at"
      described as {
        |When the session started.
      }
    }
    actualOnlineSubmittedAt: TimeStamp? with {
      briefly "Submitted at"
      described as {
        |When submitted.
      }
    }
    completedAt: TimeStamp? with {
      briefly "Completed at"
      described as {
        |When the order was completed.
      }
    }
    cancelledAt: TimeStamp? with {
      briefly "Cancelled at"
      described as {
        |When the order was cancelled.
      }
    }
    cancellationReason: String(1,500)? with {
      briefly "Cancellation reason"
      described as {
        |Reason for cancellation if applicable.
      }
    }
  } with {
    briefly "Online order state data"
    described as {
      |Full state of an online order. Shared across all
      |lifecycle states as a superset record.
    }
  }
  state Browsing of type OnlineOrder.OnlineOrderData is {
    handler BrowsingInitHandler is {
      on init is {
        set state Browsing to "onlineOrderId, customerId, orderCartItems = empty, selectedFulfillment = none, selectedDeliveryAddress = none, processedOnlinePayment = none, createdAt = current timestamp, actualOnlineSubmittedAt = none, completedAt = none, cancelledAt = none, cancellationReason = none"
      }
    } with {
      briefly "Browsing init handler"
      described as {
        |Initializes the Browsing state with default values.
      }
    }
    handler BrowsingHandler is {
      on command AddToCart is {
        tell event ItemAddedToCart to entity
          OnlineOrdering.OnlineOrder
        send event ItemAddedToCart to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
      }
      on event ItemAddedToCart is {
        do "append ItemAddedToCart.cartItem to
          OnlineOrderData.orderCartItems"
      }
      on command RemoveFromCart is {
        tell event ItemRemovedFromCart to entity
          OnlineOrdering.OnlineOrder
        send event ItemRemovedFromCart to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
      }
      on event ItemRemovedFromCart is {
        do "remove CartItem from OnlineOrderData
          .orderCartItems where cartMenuItemId =
          ItemRemovedFromCart.removedCartItemId"
      }
      on command SelectFulfillment is {
        when "fulfillment is DeliveryFulfillment" then
          do "validate SelectFulfillment.deliveryAddress is within
            restaurant service area by ZIP code"
        end
        tell event FulfillmentSelected to entity
          OnlineOrdering.OnlineOrder
        send event FulfillmentSelected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
      }
      on event FulfillmentSelected is {
        morph entity OnlineOrdering.OnlineOrder to state
          OnlineOrdering.OnlineOrder.FulfillmentChosen
            with event FulfillmentSelected
        set field OnlineOrder.FulfillmentChosen.selectedFulfillment
          to "fulfillmentType from event"
        when "fulfillment is DeliveryFulfillment" then
          set field
            OnlineOrder.FulfillmentChosen.selectedDeliveryAddress
            to "deliveryAddress from event"
        end
      }
      on command CancelOnlineOrder is {
        tell event OnlineOrderCancelled to entity
          OnlineOrdering.OnlineOrder
        send event OnlineOrderCancelled to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
      }
      on event OnlineOrderCancelled is {
        morph entity OnlineOrdering.OnlineOrder to state
          OnlineOrdering.OnlineOrder.Cancelled
            with event OnlineOrderCancelled
        set field OnlineOrder.Cancelled.cancelledAt to
          "cancelledAt from event"
        set field OnlineOrder.Cancelled.cancellationReason to
          "cancellationReason from event"
      }
      on command BrowseMenu is {
        send event BrowseMenuRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Online order session already started"
      }
      on command SubmitOnlineOrder is {
        send event SubmitOnlineOrderRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot submit before selecting fulfillment"
      }
      on command ProcessOnlinePayment is {
        send event ProcessOnlinePaymentRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot process payment before order is submitted"
      }
      on command MarkOnlineInPreparation is {
        send event MarkOnlineInPreparationRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot mark in preparation before payment"
      }
      on command MarkReadyForPickup is {
        send event MarkReadyForPickupRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot mark ready before preparation"
      }
      on command MarkOutForDelivery is {
        send event MarkOutForDeliveryRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot mark out for delivery before preparation"
      }
      on command CompleteOnlineOrder is {
        send event CompleteOnlineOrderRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot complete before pickup or delivery"
      }
    } with {
      briefly "Browsing state handler"
      described as {
        |Handles commands valid in the Browsing state.
        |AddToCart and RemoveFromCart modify the cart.
        |SelectFulfillment advances the lifecycle.
        |CancelOnlineOrder moves to Cancelled.
      }
    }
  } with {
    briefly "Browsing menu"
    described as {
      |Customer is browsing the menu and building their
      |cart. Items can be added and removed.
    }
  }
  state FulfillmentChosen of type OnlineOrder.OnlineOrderData is {
    handler FulfillmentChosenInitHandler is {
      on init is {
        set state FulfillmentChosen to "onlineOrderId, customerId, orderCartItems, selectedFulfillment = FulfillmentSelected.fulfillmentType, selectedDeliveryAddress = FulfillmentSelected.deliveryAddress, processedOnlinePayment = none, createdAt, actualOnlineSubmittedAt = none, completedAt = none, cancelledAt = none, cancellationReason = none"
      }
    } with {
      briefly "FulfillmentChosen init handler"
      described as {
        |Initializes the FulfillmentChosen state from the
        |FulfillmentSelected event.
      }
    }
    handler FulfillmentChosenHandler is {
      on command SubmitOnlineOrder is {
        tell event OnlineOrderSubmitted to entity
          OnlineOrdering.OnlineOrder
        send event OnlineOrderSubmitted to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
      }
      on event OnlineOrderSubmitted is {
        morph entity OnlineOrdering.OnlineOrder to state
          OnlineOrdering.OnlineOrder.Submitted
            with event OnlineOrderSubmitted
        set field OnlineOrder.Submitted.actualOnlineSubmittedAt to
          "onlineSubmittedAt from event"
        do "OnlineOrderSubmitted event triggers kitchen ticket
          creation via ToKitchen adaptor"
        when "OnlineOrderData.selectedFulfillment is
          DeliveryFulfillment" then
          tell command CreateDelivery to entity
            Delivery.DeliveryOrder
        end
      }
      on command CancelOnlineOrder is {
        tell event OnlineOrderCancelled to entity
          OnlineOrdering.OnlineOrder
        send event OnlineOrderCancelled to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
      }
      on event OnlineOrderCancelled is {
        morph entity OnlineOrdering.OnlineOrder to state
          OnlineOrdering.OnlineOrder.Cancelled
            with event OnlineOrderCancelled
        set field OnlineOrder.Cancelled.cancelledAt to
          "cancelledAt from event"
        set field OnlineOrder.Cancelled.cancellationReason to
          "cancellationReason from event"
      }
      on command BrowseMenu is {
        send event BrowseMenuRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Online order session already started"
      }
      on command AddToCart is {
        send event AddToCartRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot modify cart after fulfillment is selected"
      }
      on command RemoveFromCart is {
        send event RemoveFromCartRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot modify cart after fulfillment is selected"
      }
      on command SelectFulfillment is {
        send event SelectFulfillmentRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Fulfillment has already been selected"
      }
      on command ProcessOnlinePayment is {
        send event ProcessOnlinePaymentRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot process payment before order is submitted"
      }
      on command MarkOnlineInPreparation is {
        send event MarkOnlineInPreparationRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot mark in preparation before payment"
      }
      on command MarkReadyForPickup is {
        send event MarkReadyForPickupRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot mark ready before preparation"
      }
      on command MarkOutForDelivery is {
        send event MarkOutForDeliveryRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot mark out for delivery before preparation"
      }
      on command CompleteOnlineOrder is {
        send event CompleteOnlineOrderRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot complete before pickup or delivery"
      }
    } with {
      briefly "FulfillmentChosen state handler"
      described as {
        |Handles commands valid in the FulfillmentChosen state.
        |SubmitOnlineOrder advances the lifecycle.
        |CancelOnlineOrder moves to Cancelled.
      }
    }
  } with {
    briefly "Fulfillment chosen"
    described as {
      |Customer has selected pickup or delivery fulfillment.
      |Ready for submission.
    }
  }
  state Submitted of type OnlineOrder.OnlineOrderData is {
    handler SubmittedInitHandler is {
      on init is {
        set state OnlineOrder.Submitted to "onlineOrderId, customerId, orderCartItems, selectedFulfillment, selectedDeliveryAddress, processedOnlinePayment = none, createdAt, actualOnlineSubmittedAt = OnlineOrderSubmitted.onlineSubmittedAt, completedAt = none, cancelledAt = none, cancellationReason = none"
      }
    } with {
      briefly "Submitted init handler"
      described as {
        |Initializes the Submitted state from the
        |OnlineOrderSubmitted event.
      }
    }
    handler SubmittedHandler is {
      on command ProcessOnlinePayment is {
        tell event OnlinePaymentProcessed to entity
          OnlineOrdering.OnlineOrder
        send event OnlinePaymentProcessed to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
      }
      on event OnlinePaymentProcessed is {
        morph entity OnlineOrdering.OnlineOrder to state
          OnlineOrdering.OnlineOrder.Paid
            with event OnlinePaymentProcessed
        set field OnlineOrder.Paid.processedOnlinePayment to
          "payment info from event"
        do "OnlinePaymentProcessed event triggers PaymentGateway
          authorization via streaming topology and Loyalty
          point accrual via ToLoyalty adaptor"
      }
      on command CancelOnlineOrder is {
        tell event OnlineOrderCancelled to entity
          OnlineOrdering.OnlineOrder
        send event OnlineOrderCancelled to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
      }
      on event OnlineOrderCancelled is {
        morph entity OnlineOrdering.OnlineOrder to state
          OnlineOrdering.OnlineOrder.Cancelled
            with event OnlineOrderCancelled
        set field OnlineOrder.Cancelled.cancelledAt to
          "cancelledAt from event"
        set field OnlineOrder.Cancelled.cancellationReason to
          "cancellationReason from event"
      }
      on command BrowseMenu is {
        send event BrowseMenuRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Online order session already started"
      }
      on command AddToCart is {
        send event AddToCartRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot modify cart after order is submitted"
      }
      on command RemoveFromCart is {
        send event RemoveFromCartRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot modify cart after order is submitted"
      }
      on command SelectFulfillment is {
        send event SelectFulfillmentRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Fulfillment has already been selected"
      }
      on command SubmitOnlineOrder is {
        send event SubmitOnlineOrderRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Order has already been submitted"
      }
      on command MarkOnlineInPreparation is {
        send event MarkOnlineInPreparationRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot mark in preparation before payment"
      }
      on command MarkReadyForPickup is {
        send event MarkReadyForPickupRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot mark ready before preparation"
      }
      on command MarkOutForDelivery is {
        send event MarkOutForDeliveryRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot mark out for delivery before preparation"
      }
      on command CompleteOnlineOrder is {
        send event CompleteOnlineOrderRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot complete before pickup or delivery"
      }
    } with {
      briefly "Submitted state handler"
      described as {
        |Handles commands valid in the Submitted state.
        |ProcessOnlinePayment advances the lifecycle.
        |CancelOnlineOrder moves to Cancelled.
      }
    }
  } with {
    briefly "Order submitted"
    described as {
      |Order has been submitted for processing. Kitchen
      |ticket creation and delivery routing triggered.
    }
  }
  state Paid of type OnlineOrder.OnlineOrderData is {
    handler PaidInitHandler is {
      on init is {
        set state Paid to "onlineOrderId, customerId, orderCartItems, selectedFulfillment, selectedDeliveryAddress, processedOnlinePayment = OnlinePaymentProcessed.onlinePayment, createdAt, actualOnlineSubmittedAt, completedAt = none, cancelledAt = none, cancellationReason = none"
      }
    } with {
      briefly "Paid init handler"
      described as {
        |Initializes the Paid state from the
        |OnlinePaymentProcessed event.
      }
    }
    handler PaidHandler is {
      on command MarkOnlineInPreparation is {
        tell event OnlineOrderInPreparation to entity
          OnlineOrdering.OnlineOrder
        send event OnlineOrderInPreparation to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
      }
      on event OnlineOrderInPreparation is {
        morph entity OnlineOrdering.OnlineOrder to state
          OnlineOrdering.OnlineOrder.InPreparation
            with event OnlineOrderInPreparation
      }
      on command CancelOnlineOrder is {
        tell event OnlineOrderCancelled to entity
          OnlineOrdering.OnlineOrder
        send event OnlineOrderCancelled to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
      }
      on event OnlineOrderCancelled is {
        morph entity OnlineOrdering.OnlineOrder to state
          OnlineOrdering.OnlineOrder.Cancelled
            with event OnlineOrderCancelled
        set field OnlineOrder.Cancelled.cancelledAt to
          "cancelledAt from event"
        set field OnlineOrder.Cancelled.cancellationReason to
          "cancellationReason from event"
        when "OnlineOrderData.processedOnlinePayment is
          not empty" then
          do "trigger refund via PaymentGateway for
            processedOnlinePayment amount"
        end
      }
      on command BrowseMenu is {
        send event BrowseMenuRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Online order session already started"
      }
      on command AddToCart is {
        send event AddToCartRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot modify cart after order is submitted"
      }
      on command RemoveFromCart is {
        send event RemoveFromCartRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot modify cart after order is submitted"
      }
      on command SelectFulfillment is {
        send event SelectFulfillmentRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Fulfillment has already been selected"
      }
      on command SubmitOnlineOrder is {
        send event SubmitOnlineOrderRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Order has already been submitted"
      }
      on command ProcessOnlinePayment is {
        send event ProcessOnlinePaymentRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Payment has already been processed"
      }
      on command MarkReadyForPickup is {
        send event MarkReadyForPickupRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot mark ready before preparation"
      }
      on command MarkOutForDelivery is {
        send event MarkOutForDeliveryRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot mark out for delivery before preparation"
      }
      on command CompleteOnlineOrder is {
        send event CompleteOnlineOrderRejected to outlet
          OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
        error "Cannot complete before pickup or delivery"
      }
    } with {
      briefly "Paid state handler"
      described as {
        |Handles commands valid in the Paid state.
        |MarkOnlineInPreparation advances the lifecycle.
        |CancelOnlineOrder moves to Cancelled with refund.
      }
    }
  } with {
    briefly "Payment complete"
    described as {
      |Payment has been processed. Order is confirmed and
      |awaiting preparation.
    }
  }
  state InPreparation of type OnlineOrder.OnlineOrderData is {
