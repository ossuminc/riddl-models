      on init is {
        set state ReadyForPickup to "onlineOrderId, customerId, orderCartItems, selectedFulfillment, selectedDeliveryAddress, processedOnlinePayment, createdAt, actualOnlineSubmittedAt, completedAt = none, cancelledAt = none, cancellationReason = none"
