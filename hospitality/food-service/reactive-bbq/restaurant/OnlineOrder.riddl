  handler OnlineOrderCreationHandler is {
    on command BrowseMenu is {
      tell event MenuBrowsed to entity
        OnlineOrdering.OnlineOrder
      send event MenuBrowsed to outlet
        OnlineOrdering.OnlineOrderEventSource.SubmittedOnlineOrderEvents
    }
    on event MenuBrowsed is {
      morph entity OnlineOrdering.OnlineOrder to state
        OnlineOrdering.OnlineOrder.Browsing
          with event MenuBrowsed
    }
    on query GetOnlineOrder is {
      do "look up OnlineOrder by GetOnlineOrder.onlineOrderId"
      tell result OnlineOrderResult to entity
        OnlineOrdering.OnlineOrder
    }
  } with {
    briefly "Online order creation handler"
    described as {
      |Handles the initial BrowseMenu command when
      |the entity has no state yet.
    }
  }
} with {
  briefly "Online order entity"
  described as {
    | Manages the lifecycle of an online order from menu
    | browsing through cart management, fulfillment selection,
    | submission, and payment. State handlers ensure commands
    | are only valid in appropriate states, and events are
    | persisted before state transitions. Cancellation is
    | allowed from any state before delivery dispatch, with
    | automatic refund if payment was processed.
  }
}
