// DeliveryOrder entity for the Delivery context
entity DeliveryOrder is {
  // ---- Commands ----
  command CreateDelivery is  {
    deliveryId: DeliveryId with {
      briefly "ID"
      described as {
        |Identifier for the new delivery.
      }
    }
    sourceOnlineOrderId: String(1,50) with {
      briefly "Online order ID"
      described as {
        |Originating online order.
      }
    }
    deliveryCustomerName: String(1,100) with {
      briefly "Customer name"
      described as {
        |Name of the customer.
      }
    }
    deliveryCustomerPhone: String(7,20) with {
      briefly "Customer phone"
      described as {
        |Customer contact phone.
      }
    }
    deliveryDestination: DeliveryAddress with {
      briefly "Destination"
      described as {
        |Delivery destination address.
      }
    }
    requestedDeliveryTime: TimeStamp? with {
      briefly "Requested time"
      described as {
        |Customer-requested delivery time.
      }
    }
  } with {
    briefly "Create delivery"
    described as {
      |Create a new delivery from an online order.
    }
  }
  command AssignDriver is  {
    deliveryId: DeliveryId with {
      briefly "ID"
      described as {
        |Delivery to assign driver to.
      }
    }
    driverId: DriverId with {
      briefly "Driver ID"
      described as {
        |Driver being assigned.
      }
    }
    driverName: String(1,100) with {
      briefly "Driver name"
      described as {
        |Name of the assigned driver.
      }
    }
  } with {
    briefly "Assign driver"
    described as {
      |Assign a delivery driver.
    }
  }
  command DispatchDriver is  {
    deliveryId: DeliveryId with {
      briefly "ID"
      described as {
        |Delivery to dispatch.
      }
    }
    dispatchedAt: TimeStamp with {
      briefly "Dispatched at"
      described as {
        |When the driver was dispatched.
      }
    }
  } with {
    briefly "Dispatch driver"
    described as {
      |Dispatch the assigned driver for delivery.
    }
  }
  command RecordDeliveryLocation is  {
    deliveryId: DeliveryId with {
      briefly "ID"
      described as {
        |Delivery to record location for.
      }
    }
    driverLocation: GeoLocation with {
      briefly "Location"
      described as {
        |Current driver GPS location.
      }
    }
  } with {
    briefly "Record delivery location"
    described as {
      |Record the driver's current GPS location.
    }
  }
  command ConfirmDelivery is  {
    deliveryId: DeliveryId with {
      briefly "ID"
      described as {
        |Delivery to confirm.
      }
    }
    confirmedAt: TimeStamp with {
      briefly "Confirmed at"
      described as {
        |When the delivery was confirmed.
      }
    }
    deliverySignature: String(1,200)? with {
      briefly "Signature"
      described as {
        |Customer signature or confirmation.
      }
    }
  } with {
    briefly "Confirm delivery"
    described as {
      |Confirm the delivery was completed.
    }
  }
  command RecordDeliveryPayment is  {
    deliveryId: DeliveryId with {
      briefly "ID"
      described as {
        |Delivery to record payment for.
      }
    }
    deliveryTip: Decimal(8,2)? with {
      briefly "Tip"
      described as {
        |Driver tip amount.
      }
    }
    deliveryPaidAt: TimeStamp with {
      briefly "Paid at"
      described as {
        |When payment was recorded.
      }
    }
  } with {
    briefly "Record delivery payment"
    described as {
      |Record cash tip or additional payment at delivery.
    }
  }
  command ReportDeliveryIssue is  {
    deliveryId: DeliveryId with {
      briefly "ID"
      described as {
        |Delivery with the issue.
      }
    }
    issueType: DeliveryIssueType with {
      briefly "Issue type"
      described as {
        |Type of issue.
      }
    }
    issueDescription: String(1,1000) with {
      briefly "Description"
      described as {
        |Detailed description of the issue.
      }
    }
    reportedAt: TimeStamp with {
      briefly "Reported at"
      described as {
        |When the issue was reported.
      }
    }
  } with {
    briefly "Report delivery issue"
    described as {
      |Report an issue during delivery.
    }
  }
  command FailDelivery is {
    deliveryId: DeliveryId with {
      briefly "ID"
      described as {
        |Delivery that failed.
      }
    }
    failureReason: String(1,1000) with {
      briefly "Reason"
      described as {
        |Reason for the delivery failure.
      }
    }
    failedAt: TimeStamp with {
      briefly "Failed at"
      described as {
        |When the delivery was marked as failed.
      }
    }
  } with {
    briefly "Fail delivery"
    described as {
      |Mark a delivery as permanently failed, such as when
      |the customer is unavailable after timeout.
    }
  }
  // ---- Events ----
  event DeliveryCreated is  {
    deliveryId: DeliveryId with {
      briefly "ID"
      described as {
        |Delivery identifier.
      }
    }
    sourceOnlineOrderId: String(1,50) with {
      briefly "Online order ID"
      described as {
        |Originating order.
      }
    }
    deliveryDestination: DeliveryAddress with {
      briefly "Destination"
      described as {
        |Delivery address.
      }
    }
    createdAt: TimeStamp with {
      briefly "Created at"
      described as {
        |When created.
      }
    }
  } with {
    briefly "Delivery created"
    described as {
      |Emitted when a new delivery is created.
    }
  }
  event DriverAssigned is  {
    deliveryId: DeliveryId with {
      briefly "ID"
      described as {
        |Delivery identifier.
      }
    }
    driverId: DriverId with {
      briefly "Driver ID"
      described as {
        |Assigned driver.
      }
    }
    driverName: String(1,100) with {
      briefly "Driver name"
      described as {
        |Driver name.
      }
    }
    assignedAt: TimeStamp with {
      briefly "Assigned at"
      described as {
        |When assigned.
      }
    }
  } with {
    briefly "Driver assigned"
    described as {
      |Emitted when a driver is assigned to a delivery.
    }
  }
  event DriverDispatched is  {
    deliveryId: DeliveryId with {
      briefly "ID"
      described as {
        |Delivery identifier.
      }
    }
    dispatchedAt: TimeStamp with {
      briefly "Dispatched at"
      described as {
        |When dispatched.
      }
    }
  } with {
    briefly "Driver dispatched"
    described as {
      |Emitted when the driver is dispatched.
    }
  }
  event DeliveryLocationRecorded is  {
    deliveryId: DeliveryId with {
      briefly "ID"
      described as {
        |Delivery identifier.
      }
    }
    driverLocation: GeoLocation with {
      briefly "Location"
      described as {
        |GPS location.
      }
    }
  } with {
    briefly "Delivery location recorded"
    described as {
      |Emitted when a driver location update is recorded.
    }
  }
  event DeliveryConfirmed is  {
    deliveryId: DeliveryId with {
      briefly "ID"
      described as {
        |Delivery identifier.
      }
    }
    confirmedAt: TimeStamp with {
      briefly "Confirmed at"
      described as {
        |When confirmed.
      }
    }
  } with {
    briefly "Delivery confirmed"
    described as {
      |Emitted when delivery is confirmed complete.
    }
  }
  event DeliveryPaymentRecorded is  {
    deliveryId: DeliveryId with {
      briefly "ID"
      described as {
        |Delivery identifier.
      }
    }
    deliveryTip: Decimal(8,2)? with {
      briefly "Tip"
      described as {
        |Tip amount.
      }
    }
    deliveryPaidAt: TimeStamp with {
      briefly "Paid at"
      described as {
        |When recorded.
      }
    }
  } with {
    briefly "Delivery payment recorded"
    described as {
      |Emitted when delivery payment or tip is recorded.
    }
  }
  event DeliveryIssueReported is  {
    deliveryId: DeliveryId with {
      briefly "ID"
      described as {
        |Delivery identifier.
      }
    }
    issueType: DeliveryIssueType with {
      briefly "Issue type"
      described as {
        |Type of issue.
      }
    }
    issueDescription: String(1,1000) with {
      briefly "Description"
      described as {
        |Issue details.
      }
    }
    reportedAt: TimeStamp with {
      briefly "Reported at"
      described as {
        |When reported.
      }
    }
  } with {
    briefly "Delivery issue reported"
    described as {
      |Emitted when a delivery issue is reported.
    }
  }
  event DeliveryMarkedFailed is {
    deliveryId: DeliveryId with {
      briefly "ID"
      described as {
        |Delivery identifier.
      }
    }
    failureReason: String(1,1000) with {
      briefly "Reason"
      described as {
        |Reason for failure.
      }
    }
    failedAt: TimeStamp with {
      briefly "Failed at"
      described as {
        |When failed.
      }
    }
  } with {
    briefly "Delivery marked failed"
    described as {
      |Emitted when a delivery is permanently marked as
      |failed.
    }
  }
  // ---- State ----
  record DeliveryBase is {
    deliveryId: DeliveryId with {
      briefly "ID"
      described as {
        |Delivery identifier.
      }
    }
    sourceOnlineOrderId: String(1,50) with {
      briefly "Online order ID"
      described as {
        |Originating order.
      }
    }
    deliveryCustomerName: String(1,100) with {
      briefly "Customer name"
      described as {
        |Customer.
      }
    }
    deliveryCustomerPhone: String(7,20) with {
      briefly "Customer phone"
      described as {
        |Contact phone.
      }
    }
    deliveryDestination: DeliveryAddress with {
      briefly "Destination"
      described as {
        |Delivery address.
      }
    }
    createdAt: TimeStamp with {
      briefly "Created at"
      described as {
        |When created.
      }
    }
  } with {
    briefly "Delivery base data"
    described as {
      |Common fields shared by all delivery states.
    }
  }
  record PendingData is {
    base: DeliveryBase with {
      briefly "Base"
      described as {
        |Common delivery fields.
      }
    }
  } with {
    briefly "Pending state data"
    described as {
      |State data for a delivery awaiting driver assignment.
    }
  }
  record DriverAssignedData is {
    base: DeliveryBase with {
      briefly "Base"
      described as {
        |Common delivery fields.
      }
    }
    assignedDriverId: DriverId with {
      briefly "Driver ID"
      described as {
        |Assigned driver.
      }
    }
    assignedDriverName: String(1,100) with {
      briefly "Driver name"
      described as {
        |Driver name.
      }
    }
    assignedAt: TimeStamp with {
      briefly "Assigned at"
      described as {
        |When the driver was assigned.
      }
    }
  } with {
    briefly "Driver assigned state data"
    described as {
      |State data for a delivery with an assigned driver
      |awaiting dispatch.
    }
  }
  record InTransitData is {
    base: DeliveryBase with {
      briefly "Base"
      described as {
        |Common delivery fields.
      }
    }
    assignedDriverId: DriverId with {
      briefly "Driver ID"
      described as {
        |Assigned driver.
      }
    }
    assignedDriverName: String(1,100) with {
      briefly "Driver name"
      described as {
        |Driver name.
      }
    }
    dispatchedAt: TimeStamp with {
      briefly "Dispatched at"
      described as {
        |When dispatched.
      }
    }
    lastKnownLocation: GeoLocation? with {
      briefly "Last location"
      described as {
        |Last recorded GPS location.
      }
    }
  } with {
    briefly "In transit state data"
    described as {
      |State data for a delivery in transit with GPS
      |tracking of the driver.
    }
  }
  record DeliveredData is {
    base: DeliveryBase with {
      briefly "Base"
      described as {
        |Common delivery fields.
      }
    }
    assignedDriverId: DriverId with {
      briefly "Driver ID"
      described as {
        |Driver who completed the delivery.
      }
    }
    assignedDriverName: String(1,100) with {
      briefly "Driver name"
      described as {
        |Driver name.
      }
    }
    confirmedAt: TimeStamp with {
      briefly "Confirmed at"
      described as {
        |When the delivery was confirmed.
      }
    }
  } with {
    briefly "Delivered state data"
    described as {
      |State data for a completed delivery.
    }
  }
  record FailedData is {
    base: DeliveryBase with {
      briefly "Base"
      described as {
        |Common delivery fields.
      }
    }
    failureReason: String(1,1000) with {
      briefly "Reason"
      described as {
        |Reason for delivery failure.
      }
    }
    failedAt: TimeStamp with {
      briefly "Failed at"
      described as {
        |When the delivery failed.
      }
    }
    lastDriverId: DriverId? with {
      briefly "Last driver"
      described as {
        |Last assigned driver before failure.
      }
    }
  } with {
    briefly "Failed state data"
    described as {
      |State data for a failed delivery.
    }
  }
  state Pending of type DeliveryOrder.PendingData is {
    handler PendingHandler is {
      on command AssignDriver is {
        tell event DriverAssigned to entity
          Delivery.DeliveryOrder
      }
      on event DriverAssigned is {
        morph entity Delivery.DeliveryOrder to state
          Delivery.DeliveryOrder.DriverAssignedState
            with event DriverAssigned
        do "DriverAssigned event triggers push notification to
          driver via NotificationService streaming topology"
      }
      on command FailDelivery is {
        tell event DeliveryMarkedFailed to entity
          Delivery.DeliveryOrder
      }
      on event DeliveryMarkedFailed is {
        morph entity Delivery.DeliveryOrder to state
          Delivery.DeliveryOrder.Failed
            with event DeliveryMarkedFailed
      }
      on command CreateDelivery is {
        error "Delivery has already been created"
      }
      on command DispatchDriver is {
        error "Cannot dispatch before a driver is assigned"
      }
      on command RecordDeliveryLocation is {
        error "Cannot record location before driver is dispatched"
      }
      on command ConfirmDelivery is {
        error "Cannot confirm delivery before driver is dispatched"
      }
      on command RecordDeliveryPayment is {
        error "Cannot record payment before delivery is in transit"
      }
      on command ReportDeliveryIssue is {
        error "Cannot report issue before delivery is in transit"
      }
    } with {
      briefly "Pending state handler"
      described as {
        |Handles commands valid in the Pending state.
        |AssignDriver advances the lifecycle. FailDelivery
        |moves to the terminal Failed state.
      }
    }
  } with {
    briefly "Delivery pending"
    described as {
      |Delivery has been created and is awaiting driver
      |assignment. Can also return to this state from
      |InTransit due to vehicle breakdown reassignment.
    }
  }
  state DriverAssignedState of type DeliveryOrder.DriverAssignedData
    is {
    handler DriverAssignedHandler is {
      on command DispatchDriver is {
        tell event DriverDispatched to entity
          Delivery.DeliveryOrder
      }
      on event DriverDispatched is {
        morph entity Delivery.DeliveryOrder to state
          Delivery.DeliveryOrder.InTransit
            with event DriverDispatched
        do "DriverDispatched event triggers push notification to
          customer via NotificationService streaming topology"
      }
      on command FailDelivery is {
        tell event DeliveryMarkedFailed to entity
          Delivery.DeliveryOrder
      }
      on event DeliveryMarkedFailed is {
        morph entity Delivery.DeliveryOrder to state
          Delivery.DeliveryOrder.Failed
            with event DeliveryMarkedFailed
      }
      on command CreateDelivery is {
        error "Delivery has already been created"
      }
      on command AssignDriver is {
        error "Driver has already been assigned"
      }
      on command RecordDeliveryLocation is {
        error "Cannot record location before driver is dispatched"
      }
      on command ConfirmDelivery is {
        error "Cannot confirm delivery before driver is dispatched"
      }
      on command RecordDeliveryPayment is {
        error "Cannot record payment before delivery is in transit"
      }
      on command ReportDeliveryIssue is {
        error "Cannot report issue before delivery is in transit"
      }
    } with {
      briefly "DriverAssigned state handler"
      described as {
        |Handles commands valid in the DriverAssigned state.
        |DispatchDriver advances the lifecycle. FailDelivery
        |moves to the terminal Failed state.
      }
    }
  } with {
    briefly "Driver assigned"
    described as {
      |A driver has been assigned and notified. Awaiting
      |dispatch.
    }
  }
  state InTransit of type DeliveryOrder.InTransitData is {
    handler InTransitHandler is {
      on command RecordDeliveryLocation is {
        tell event DeliveryLocationRecorded to entity
          Delivery.DeliveryOrder
      }
      on event DeliveryLocationRecorded is {
        set field DeliveryOrder.InTransit.lastKnownLocation to
          "driverLocation from event"
      }
      on command ConfirmDelivery is {
        tell event DeliveryConfirmed to entity
          Delivery.DeliveryOrder
      }
      on event DeliveryConfirmed is {
        morph entity Delivery.DeliveryOrder to state
          Delivery.DeliveryOrder.Delivered
            with event DeliveryConfirmed
        do "DeliveryConfirmed event triggers push notification
          to customer via NotificationService streaming topology"
      }
      on command RecordDeliveryPayment is {
        tell event DeliveryPaymentRecorded to entity
          Delivery.DeliveryOrder
      }
      on event DeliveryPaymentRecorded is {
        do "record tip and payment details"
      }
      on command ReportDeliveryIssue is {
        tell event DeliveryIssueReported to entity
          Delivery.DeliveryOrder
      }
      on event DeliveryIssueReported is {
        match "issueType" {
          case "AddressNotFound" {
            tell command SendPushNotification to entity
              Restaurant.NotificationService
          }
          case "CustomerUnavailable" {
            tell command SendPushNotification to entity
              Restaurant.NotificationService
            do "schedule FailDelivery command after 10-minute
              timeout if no customer response"
          }
          case "FoodDamaged" {
            tell command SendPushNotification to entity
              Restaurant.NotificationService
            do "construct ReceiveTicket replacement order from
              DeliveryBase.sourceOnlineOrderId and send to
              Kitchen.KitchenTicket"
          }
          case "VehicleBreakdown" {
            morph entity Delivery.DeliveryOrder to state
              Delivery.DeliveryOrder.Pending
                with event DeliveryIssueReported
            do "query available drivers by GeoLocation proximity
              excluding current driver"
          }
          case "TrafficDelay" {
            tell command SendPushNotification to entity
              Restaurant.NotificationService
          }
          default {
            tell command SendPushNotification to entity
              Restaurant.NotificationService
          }
        }
      }
      on command FailDelivery is {
        tell event DeliveryMarkedFailed to entity
          Delivery.DeliveryOrder
      }
      on event DeliveryMarkedFailed is {
        morph entity Delivery.DeliveryOrder to state
          Delivery.DeliveryOrder.Failed
            with event DeliveryMarkedFailed
      }
      on command CreateDelivery is {
        error "Delivery has already been created"
      }
      on command AssignDriver is {
        error "Cannot reassign driver while in transit"
      }
      on command DispatchDriver is {
        error "Driver has already been dispatched"
      }
    } with {
      briefly "InTransit state handler"
      described as {
        |Handles commands valid in the InTransit state.
        |RecordDeliveryLocation updates GPS tracking.
        |ConfirmDelivery completes delivery. ReportDeliveryIssue
        |handles various issue types including VehicleBreakdown
        |which morphs back to Pending for driver reassignment.
        |FailDelivery moves to the terminal Failed state.
      }
    }
  } with {
    briefly "In transit"
    described as {
      |Driver has been dispatched and is en route. GPS
      |location updates are being tracked.
    }
  }
  state Delivered of type DeliveryOrder.DeliveredData is {
    handler DeliveredHandler is {
      on command CreateDelivery is {
        error "Delivery is completed"
      }
      on command AssignDriver is {
        error "Delivery is completed"
      }
      on command DispatchDriver is {
        error "Delivery is completed"
      }
      on command RecordDeliveryLocation is {
        error "Delivery is completed"
      }
      on command ConfirmDelivery is {
        error "Delivery is already confirmed"
      }
      on command RecordDeliveryPayment is {
        error "Delivery is completed"
      }
      on command ReportDeliveryIssue is {
        error "Delivery is completed"
      }
      on command FailDelivery is {
        error "Delivery is already completed successfully"
      }
    } with {
      briefly "Delivered state handler"
      described as {
        |Terminal state. All commands are rejected.
      }
    }
  } with {
    briefly "Delivered"
    described as {
      |Delivery has been confirmed complete. Terminal state.
    }
  }
  state Failed of type DeliveryOrder.FailedData is {
    handler FailedHandler is {
      on command CreateDelivery is {
        error "Delivery has failed"
      }
      on command AssignDriver is {
        error "Delivery has failed"
      }
      on command DispatchDriver is {
        error "Delivery has failed"
      }
      on command RecordDeliveryLocation is {
        error "Delivery has failed"
      }
      on command ConfirmDelivery is {
        error "Delivery has failed"
      }
      on command RecordDeliveryPayment is {
        error "Delivery has failed"
      }
      on command ReportDeliveryIssue is {
        error "Delivery has failed"
      }
      on command FailDelivery is {
        error "Delivery is already marked as failed"
      }
    } with {
      briefly "Failed state handler"
      described as {
        |Terminal state. All commands are rejected.
      }
    }
  } with {
    briefly "Delivery failed"
    described as {
      |Delivery could not be completed. Terminal state.
    }
  }
  handler DeliveryCreationHandler is {
    on command CreateDelivery is {
      tell event DeliveryCreated to entity
        Delivery.DeliveryOrder
      do "query available drivers by GeoLocation proximity to
        restaurant and select nearest with status = available"
    }
    on event DeliveryCreated is {
      morph entity Delivery.DeliveryOrder to state
        Delivery.DeliveryOrder.Pending
          with event DeliveryCreated
    }
  } with {
    briefly "Delivery creation handler"
    described as {
      |Handles the initial CreateDelivery command when
      |the entity has no state yet.
    }
  }
} with {
  briefly "Delivery entity"
  described as {
    | Manages the lifecycle of a delivery from creation
    | through driver assignment, dispatch, GPS tracking,
    | confirmation, and issue reporting. State handlers
    | ensure commands are only valid in appropriate states,
    | and events are persisted before state transitions.
    | Designed for offline resilience so drivers can cache
    | details and report issues when connectivity resumes.
  }
}
