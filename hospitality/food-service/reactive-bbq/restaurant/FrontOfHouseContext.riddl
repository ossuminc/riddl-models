// Front of House bounded context
context FrontOfHouse is {
  include "front-of-house-types.riddl"
  include "Reservation.riddl"
  include "TableOrder.riddl"
  command NotifyDrinkReady is {
    tableOrderId: TableOrderId with {
      briefly "ID"
      described as {
        |Order with ready drinks.
      }
    }
  } with {
    briefly "Notify drink ready"
    described as {
      |Notify that drinks are ready for a table order.
    }
  }
  command NotifyDrinksServed is {
    tableOrderId: TableOrderId with {
      briefly "ID"
      described as {
        |Order with served drinks.
      }
    }
  } with {
    briefly "Notify drinks served"
    described as {
      |Notify that drinks have been served.
    }
  }
  command ApplyMenuItemUpdate is {
    menuItemId: String(1,50) with {
      briefly "ID"
      described as {
        |Updated menu item.
      }
    }
  } with {
    briefly "Apply menu item update"
    described as {
      |Apply a menu item update from corporate.
    }
  }
  command ApplyMenuItemPriceChange is {
    menuItemId: String(1,50) with {
      briefly "ID"
      described as {
        |Repriced menu item.
      }
    }
  } with {
    briefly "Apply menu item price change"
    described as {
      |Apply a menu item price change from corporate.
    }
  }
  command ApplyMenuRelease is {
    releaseId: String(1,50) with {
      briefly "ID"
      described as {
        |Menu release to apply.
      }
    }
  } with {
    briefly "Apply menu release"
    described as {
      |Apply a published menu release from corporate.
    }
  }
  command RollbackMenuRelease is {
    releaseId: String(1,50) with {
      briefly "ID"
      described as {
        |Menu release to roll back.
      }
    }
  } with {
    briefly "Rollback menu release"
    described as {
      |Roll back a menu release from corporate.
    }
  }
  command RecordNotificationAck is {
    notificationId: String(1,50) with {
      briefly "ID"
      described as {
        |Notification that was acknowledged.
      }
    }
  } with {
    briefly "Record notification ack"
    described as {
      |Record a push notification delivery confirmation.
    }
  }
  repository ReservationRepository is {
    schema ReservationSchema is relational
      of reservations as type Reservation
        index on field Reservation.reservationId
        index on field Reservation.guestName
        index on field Reservation.reservationTime
      with {
      briefly "Reservation data schema"
      described as {
        |Relational schema for persisting reservation state
        |with indexes on identifier, guest name, and time.
      }
    }
    handler ReservationPersistence is {
      on command Reservation.MakeReservation is {
        tell event Reservation.ReservationMade to entity
          FrontOfHouse.Reservation
        do "insert row into ReservationSchema.reservations
          with reservationId, guestName, guestPhone,
          partySize, reservationTime"
      }
      on command Reservation.ConfirmReservation is {
        tell event Reservation.ReservationConfirmed to entity
          FrontOfHouse.Reservation
        do "update ReservationSchema.reservations set
          assignedTable = confirmedTable where reservationId
          matches"
      }
      on command Reservation.CancelReservation is {
        tell event Reservation.ReservationCancelled to entity
          FrontOfHouse.Reservation
        do "update ReservationSchema.reservations where
          reservationId matches"
      }
      on command Reservation.SeatParty is {
        tell event Reservation.PartySeated to entity
          FrontOfHouse.Reservation
        do "update ReservationSchema.reservations set
          seatedAt = seatedAt where reservationId matches"
      }
      on command Reservation.CompleteVisit is {
        tell event Reservation.VisitCompleted to entity
          FrontOfHouse.Reservation
        do "update ReservationSchema.reservations set
          completedAt = completedAt where reservationId
          matches"
      }
      on command Reservation.MarkNoShow is {
        tell event Reservation.NoShowMarked to entity
          FrontOfHouse.Reservation
        do "update ReservationSchema.reservations set
          markedNoShowAt = markedNoShowAt where
          reservationId matches"
      }
      on command Reservation.RescheduleReservation is {
        tell event Reservation.ReservationRescheduled to
          entity FrontOfHouse.Reservation
        do "update ReservationSchema.reservations set
          reservationTime = newReservationTime where
          reservationId matches"
      }
      on command RecordNotificationAck is {
        do "log notification delivery confirmation for
          audit trail"
      }
      on command ApplyMenuRelease is {
        do "apply published menu release to restaurant"
      }
      on command RollbackMenuRelease is {
        do "rollback menu release at restaurant"
      }
    } with {
      briefly "Reservation persistence"
      described as {
        |Persists reservation events to the reservations table
        |and updates the current state projection.
      }
    }
  } with {
    briefly "Reservation repository"
    described as {
      |Stores and retrieves reservation data.
    }
  }
  repository TableOrderRepository is {
    schema TableOrderSchema is relational
      of orders as type TableOrder
        index on field TableOrder.tableOrderId
        index on field TableOrder.tableNumber
      with {
      briefly "Table order data schema"
      described as {
        |Relational schema for persisting table order state
        |with indexes on order identifier and table number.
      }
    }
    handler TableOrderPersistence is {
      on command TableOrder.CreateOrder is {
        tell event TableOrder.OrderCreated to entity
          FrontOfHouse.TableOrder
        do "insert row into TableOrderSchema.orders with
          tableOrderId, tableNumber, serverId"
      }
      on command TableOrder.AddItem is {
        tell event TableOrder.ItemAdded to entity
          FrontOfHouse.TableOrder
        do "append addedItem OrderLine to orderItems array
          in TableOrderSchema.orders where tableOrderId
          matches"
      }
      on command TableOrder.RemoveItem is {
        tell event TableOrder.ItemRemoved to entity
          FrontOfHouse.TableOrder
        do "remove OrderLine with removedMenuItemId from
          orderItems array in TableOrderSchema.orders where
          tableOrderId matches"
      }
      on command TableOrder.SubmitOrder is {
        tell event TableOrder.OrderSubmitted to entity
          FrontOfHouse.TableOrder
        do "update TableOrderSchema.orders set
          actualSubmittedAt = submittedAt where tableOrderId
          matches"
      }
      on command TableOrder.MarkOrderInPreparation is {
        tell event TableOrder.OrderMarkedInPreparation to
          entity FrontOfHouse.TableOrder
        do "update TableOrderSchema.orders where
          tableOrderId matches"
      }
      on command TableOrder.MarkOrderReadyToServe is {
        tell event TableOrder.OrderMarkedReadyToServe to
          entity FrontOfHouse.TableOrder
        do "update TableOrderSchema.orders set readyAt =
          readyAt where tableOrderId matches"
      }
      on command TableOrder.PresentBill is {
        tell event TableOrder.BillPresented to entity
          FrontOfHouse.TableOrder
        do "update TableOrderSchema.orders set
          presentedBillTotal = billTotal where tableOrderId
          matches"
      }
      on command TableOrder.ProcessPayment is {
        tell event TableOrder.PaymentProcessed to entity
          FrontOfHouse.TableOrder
        do "update TableOrderSchema.orders set
          processedPayment = orderPayment where tableOrderId
          matches"
      }
      on command TableOrder.CloseOrder is {
        tell event TableOrder.OrderClosed to entity
          FrontOfHouse.TableOrder
        do "update TableOrderSchema.orders set actualClosedAt
          = closedAt where tableOrderId matches"
      }
      on command NotifyDrinkReady is {
        do "notify server that drinks are ready for table"
      }
      on command NotifyDrinksServed is {
        do "record drink readiness notification acknowledgment"
      }
      on command ApplyMenuItemUpdate is {
        do "update local menu item cache with changes"
      }
      on command ApplyMenuItemPriceChange is {
        do "update local menu pricing from corporate"
      }
    } with {
      briefly "Order persistence"
      described as {
        |Persists table order events to the orders table
        |and updates the current state projection.
      }
    }
  } with {
    briefly "Table order repository"
    described as {
      |Stores and retrieves table order data.
    }
  }
  projector ReservationBoard is {
    updates repository FrontOfHouse.ReservationRepository
    record ReservationBoardEntry is  {
      reservationId: ReservationId with {
        briefly "ID"
        described as {
          |Reservation identifier.
        }
      }
      guestName: GuestName with {
        briefly "Guest"
        described as {
          |Guest name.
        }
      }
      partySize: PartySize with {
        briefly "Party size"
        described as {
          |Number of guests.
        }
      }
      reservationTime: TimeStamp with {
        briefly "Time"
        described as {
          |Reservation time.
        }
      }
      reservationDisplayStatus: String(1,30) with {
        briefly "Status"
        described as {
          |Display status derived from entity state name.
        }
      }
      assignedTable: TableNumber? with {
        briefly "Table"
        described as {
          |Assigned table.
        }
      }
    } with {
      briefly "Board entry"
      described as {
        |A single entry on the reservation board.
      }
    }
    handler ReservationBoardHandler is {
      on event Reservation.ReservationMade is {
        set field ReservationBoardEntry.reservationDisplayStatus to "Requested"
        tell event Reservation.ReservationMade to repository
          FrontOfHouse.ReservationRepository
        do "insert ReservationBoardEntry with reservationId =
          event.reservationId, guestName = event.guestName,
          partySize = event.partySize, reservationTime =
          event.reservationTime, reservationDisplayStatus = Requested,
          assignedTable = none"
      }
      on event Reservation.ReservationConfirmed is {
        set field ReservationBoardEntry.reservationDisplayStatus to "Confirmed"
        tell event Reservation.ReservationConfirmed to repository
          FrontOfHouse.ReservationRepository
        do "update ReservationBoardEntry set
          reservationDisplayStatus = Confirmed,
          assignedTable = event.confirmedTable
          where reservationId = event.reservationId"
      }
      on event Reservation.ReservationCancelled is {
        set field ReservationBoardEntry.reservationDisplayStatus to "Cancelled"
        tell event Reservation.ReservationCancelled to repository
          FrontOfHouse.ReservationRepository
        do "delete ReservationBoardEntry where reservationId =
          event.reservationId"
      }
      on event Reservation.PartySeated is {
        set field ReservationBoardEntry.reservationDisplayStatus to "Seated"
        tell event Reservation.PartySeated to repository
          FrontOfHouse.ReservationRepository
        do "update ReservationBoardEntry set
          reservationDisplayStatus = Seated,
          assignedTable = event.seatedTable where
          reservationId = event.reservationId"
      }
    } with {
      briefly "Board event handler"
      described as {
        |Projects reservation events onto the real-time board
        |displayed at the host station, replacing the paper
        |backup system.
      }
    }
  } with {
    briefly "Reservation board projector"
    described as {
      | Real-time view of current reservations replacing
      | the host's paper backup system.
    }
  }
  source OrderEventSource is {
    outlet SubmittedOrderEvents is type OrderEvent
    handler OrderEventEmitter is {
      on event TableOrder.OrderSubmitted is {
        send event TableOrder.OrderSubmitted to outlet SubmittedOrderEvents
      }
    } with {
      briefly "Order event emitter"
      described as {
        |Emits order submission events to the streaming
        |topology when orders are submitted.
      }
    }
  } with {
    briefly "Order event source"
    described as {
      |Emits order submission events from the TableOrder entity
      |into the streaming topology for kitchen and bar routing.
    }
  }
  source ReservationEventSource is {
    outlet ReservationEvents is type ReservationEvent
    handler ReservationEventEmitter is {
      on event Reservation.ReservationMade is {
        send event Reservation.ReservationMade to outlet ReservationEvents
      }
      on event Reservation.ReservationConfirmed is {
        send event Reservation.ReservationConfirmed to outlet ReservationEvents
      }
      on event Reservation.ReservationCancelled is {
        send event Reservation.ReservationCancelled to outlet ReservationEvents
      }
      on event Reservation.PartySeated is {
        send event Reservation.PartySeated to outlet ReservationEvents
      }
      on event Reservation.VisitCompleted is {
        send event Reservation.VisitCompleted to outlet ReservationEvents
      }
      on event Reservation.NoShowMarked is {
        send event Reservation.NoShowMarked to outlet ReservationEvents
      }
      on event Reservation.ReservationRescheduled is {
        send event Reservation.ReservationRescheduled to outlet ReservationEvents
      }
    } with {
      briefly "Reservation event emitter"
      described as {
        |Emits reservation lifecycle events into the streaming
        |topology for downstream consumers.
      }
    }
  } with {
    briefly "Reservation event source"
    described as {
      |Publishes reservation entity events for external
      |consumption via the streaming topology.
    }
  }
  source TableOrderEventSource is {
    outlet TableOrderEvents is type OrderEvent
    handler TableOrderEventEmitter is {
      on event TableOrder.OrderCreated is {
        send event TableOrder.OrderCreated to outlet TableOrderEvents
      }
      on event TableOrder.ItemAdded is {
        send event TableOrder.ItemAdded to outlet TableOrderEvents
      }
      on event TableOrder.OrderSubmitted is {
        send event TableOrder.OrderSubmitted to outlet TableOrderEvents
      }
      on event TableOrder.PaymentProcessed is {
        send event TableOrder.PaymentProcessed to outlet TableOrderEvents
      }
      on event TableOrder.OrderClosed is {
        send event TableOrder.OrderClosed to outlet TableOrderEvents
      }
    } with {
      briefly "Table order event emitter"
      described as {
        |Emits table order lifecycle events into the streaming
        |topology for downstream consumers.
      }
    }
  } with {
    briefly "Table order event source"
    described as {
      |Publishes table order entity events for external
      |consumption via the streaming topology.
    }
  }
  split OrderSplitter is {
    inlet SubmittedOrders is type OrderEvent
    outlet FoodOrders is type KitchenTicketEvent
    outlet DrinkOrders is type DrinkOrderEvent
    handler OrderSplitHandler is {
      on event TableOrder.OrderSubmitted is {
        send event TableOrder.OrderSubmitted to outlet FoodOrders
        send event TableOrder.OrderSubmitted to outlet DrinkOrders
      }
    } with {
      briefly "Order split handler"
      described as {
        |Routes food items to the kitchen outlet and drink
        |items to the bar outlet.
      }
    }
  } with {
    briefly "Order splitter streamlet"
    described as {
      |Splits submitted table orders into separate food and
      |drink streams. Food items flow to the kitchen context
      |and drink items flow to the bar context, ensuring
      |ordered processing during peak hours.
    }
  }
  adaptor ToKitchen to context Restaurant.Kitchen is {
    handler KitchenRouting is {
      on command Restaurant.Kitchen.KitchenTicket.ReceiveTicket is {
        do "filter OrderSubmitted.orderItems where
          orderLineItem.itemCategory is not drink to produce
          food-only OrderLine list"
        do "map each food OrderLine to TicketItem with
          ticketMenuItemId = orderLineItem.itemCode,
          ticketItemName = orderLineItem.itemName,
          ticketItemQuantity = orderLineQuantity,
          ticketItemNotes = orderLineNotes,
          ticketItemReady = false"
        do "construct ReceiveTicket command with new
          KitchenTicketId, sourceOrderId =
          OrderSubmitted.tableOrderId, ticketSource = DineIn,
          ticketItems = mapped TicketItem list, receivedAt =
          current timestamp"
        tell command ReceiveTicket to entity
          Kitchen.KitchenTicket
      }
    } with {
      briefly "Kitchen routing"
      described as {
        |Routes food items to kitchen context, transforming
        |order lines into kitchen ticket format.
      }
    }
  } with {
    briefly "Kitchen adaptor"
    described as {
      |Sends submitted food orders to the kitchen.
    }
  }
  adaptor ToBar to context Restaurant.Bar is {
    handler BarRouting is {
      on command Restaurant.Bar.DrinkOrder.ReceiveDrinkOrder is {
        do "filter OrderSubmitted.orderItems where
          orderLineItem.itemCategory is drink to produce
          drink-only OrderLine list"
        do "map each drink OrderLine to DrinkItem with
          drinkName = orderLineItem.itemName,
          drinkQuantity = orderLineQuantity,
          drinkNotes = orderLineNotes"
        do "construct ReceiveDrinkOrder command with new
          DrinkOrderId, sourceOrderId =
          OrderSubmitted.tableOrderId, drinkTableNumber =
          OrderSubmitted.tableNumber, drinkItems = mapped
          DrinkItem list, drinkReceivedAt = current timestamp"
        tell command ReceiveDrinkOrder to entity Bar.DrinkOrder
      }
    } with {
      briefly "Bar routing"
      described as {
        |Routes drink items to bar context, transforming
        |order lines into drink order format.
      }
    }
  } with {
    briefly "Bar adaptor"
    described as {
      |Sends submitted drink orders to the bar.
    }
  }
  adaptor ToLoyalty to context Restaurant.Loyalty is {
    handler LoyaltyRouting is {
      on command Restaurant.Loyalty.LoyaltyAccount.AccruePoints is {
        let pointsEarned = "PaymentProcessed.orderPayment.paymentAmount
          truncated to integer as accrualPoints"
        do "construct AccruePoints command with loyaltyAccountId
          looked up by table association, accrualPoints =
          pointsEarned, accrualReason = dine-in purchase,
          accrualOrderRef = PaymentProcessed.tableOrderId"
        tell command AccruePoints to entity
          Loyalty.LoyaltyAccount
      }
    } with {
      briefly "Loyalty routing"
      described as {
        |Routes payment events for loyalty accrual, calculating
        |points from payment amounts.
      }
    }
  } with {
    briefly "Loyalty adaptor"
    described as {
      |Sends payment events to the loyalty context.
    }
  }
  sink PaymentResultSink is {
    inlet IncomingPaymentResults is type PaymentGatewayEvent
    handler PaymentResultHandler is {
      on event PaymentGateway.PaymentAuthorized is {
        tell command TableOrder.ProcessPayment to entity
          FrontOfHouse.TableOrder
        do "match PaymentAuthorized.paymentGatewayTransactionId
          to pending TableOrder by payment reference and
          trigger payment capture via PaymentGateway
          streaming topology"
      }
      on event PaymentGateway.PaymentCaptured is {
        tell command TableOrder.CloseOrder to entity
          FrontOfHouse.TableOrder
        do "mark payment as fully settled for the matching
          TableOrder using PaymentCaptured
          .captureTransactionId"
      }
    } with {
      briefly "Payment result handler"
      described as {
        |Processes asynchronous payment gateway responses,
        |capturing authorized payments and confirming
        |settlement back to the originating table order.
      }
    }
  } with {
    briefly "Payment result sink"
    described as {
      |Receives payment authorization and capture results
      |from the external payment gateway for two-phase
      |payment processing.
    }
  }
  sink NotificationAckSink is {
    inlet NotificationAcks is type NotificationEvent
    handler NotificationAckHandler is {
      on event NotificationService.PushNotificationSent is {
        tell command RecordNotificationAck
          to repository FrontOfHouse.ReservationRepository
        do "log notification delivery confirmation for
          PushNotificationSent.notificationRecipient at
          PushNotificationSent.sentAt for audit trail"
      }
    } with {
      briefly "Notification acknowledgment handler"
      described as {
        |Logs push notification delivery confirmations
        |for audit trail.
      }
    }
  } with {
    briefly "Notification acknowledgment sink"
    described as {
      |Receives delivery confirmation events from the
      |external push notification service.
    }
  }
  connector PaymentGatewayToFOH is {
    from outlet PaymentGateway.PaymentEventSource.PaymentResults
      to inlet FrontOfHouse.PaymentResultSink.IncomingPaymentResults
  } with {
    option is persistent
    briefly "Payment gateway connector"
    described as {
      |Wires payment gateway events to the front of house
      |for two-phase payment processing.
    }
  }
  connector NotificationToFOH is {
    from outlet
      NotificationService.NotificationEventSource.NotificationResults
      to inlet FrontOfHouse.NotificationAckSink.NotificationAcks
  } with {
    option is persistent
    briefly "Notification connector"
    described as {
      |Wires notification delivery confirmations to the
      |front of house for audit logging.
    }
  }
  connector SourceToSplitter is {
    from outlet FrontOfHouse.OrderEventSource.SubmittedOrderEvents
      to inlet FrontOfHouse.OrderSplitter.SubmittedOrders
  } with {
    briefly "Source to splitter connector"
    described as {
      |Wires order events from the source into the order
      |splitter for kitchen and bar routing.
    }
  }
  connector OrderToKitchen is {
    from outlet FrontOfHouse.OrderSplitter.FoodOrders to
      inlet Kitchen.TicketQueue.IncomingTickets
  } with {
    option is persistent
    briefly "Order to kitchen connector"
    described as {
      |Wires food items from the order splitter to the kitchen
      |ticket queue for ordered processing.
    }
  }
  connector OrderToBar is {
    from outlet FrontOfHouse.OrderSplitter.DrinkOrders to
      inlet Bar.DrinkOrderQueue.IncomingDrinks
  } with {
    option is persistent
    briefly "Order to bar connector"
    described as {
      |Wires drink items from the order splitter to the bar
      |drink order queue for ordered processing.
    }
  }
  sink DrinkOrderEventSink is {
    inlet IncomingDrinkOrderEvents is type DrinkOrderEvent
    handler DrinkOrderEventIntake is {
      on event Restaurant.Bar.DrinkOrder.DrinkMarkedReady is {
        tell command NotifyDrinkReady
          to repository FrontOfHouse.TableOrderRepository
        do "notify server that drinks are ready for table"
      }
      on event Restaurant.Bar.DrinkOrder.ServerNotifiedDrinksReady is {
        tell command NotifyDrinksServed
          to repository FrontOfHouse.TableOrderRepository
        do "record drink readiness notification acknowledgment"
      }
    } with {
      briefly "Drink order event intake"
      described as {
        |Processes incoming drink order events for order
        |readiness notification.
      }
    }
  } with {
    briefly "Drink order event sink"
    described as {
      |Receives drink order events from the bar streaming
      |topology for order readiness notification.
    }
  }
  sink MenuItemEventSink is {
    inlet IncomingMenuItemEvents is type MenuItemEvent
    handler MenuItemEventIntake is {
      on event Corporate.MenuManagement.MenuItem.MenuItemUpdated is {
        tell command ApplyMenuItemUpdate
          to repository FrontOfHouse.TableOrderRepository
        do "update local menu item cache with changes"
      }
      on event Corporate.MenuManagement.MenuItem.PriceSet is {
        tell command ApplyMenuItemPriceChange
          to repository FrontOfHouse.TableOrderRepository
        do "update local menu pricing from corporate"
      }
    } with {
      briefly "Menu item event intake"
      described as {
        |Processes incoming menu item events for local menu
        |updates.
      }
    }
  } with {
    briefly "Menu item event sink"
    described as {
      |Receives menu item events from the menu management
      |streaming topology for restaurant menu updates.
    }
  }
  sink MenuReleaseEventSink is {
    inlet IncomingMenuReleaseEvents is type MenuReleaseEvent
    handler MenuReleaseEventIntake is {
      on event Corporate.MenuManagement.MenuRelease.ReleasePublished is {
        tell command ApplyMenuRelease
          to repository FrontOfHouse.ReservationRepository
        do "apply published menu release to restaurant"
      }
      on event Corporate.MenuManagement.MenuRelease.ReleaseRolledBack is {
        tell command RollbackMenuRelease
          to repository FrontOfHouse.ReservationRepository
        do "rollback menu release at restaurant"
      }
    } with {
      briefly "Menu release event intake"
      described as {
        |Processes incoming menu release events for menu
        |distribution.
      }
    }
  } with {
    briefly "Menu release event sink"
    described as {
      |Receives menu release events from the menu management
      |streaming topology for menu release distribution.
    }
  }
  connector ReservationToReporting is {
    from outlet
      FrontOfHouse.ReservationEventSource.ReservationEvents to
      inlet Reporting.ReservationEventSink.IncomingReservationEvents
  } with {
    option is persistent
    briefly "Reservation to reporting connector"
    described as {
      |Wires reservation events to the reporting context
      |for sales and reservation reports.
    }
  }
  connector TableOrderToReporting is {
    from outlet
      FrontOfHouse.TableOrderEventSource.TableOrderEvents to
      inlet Reporting.TableOrderEventSink.IncomingTableOrderEvents
  } with {
    option is persistent
    briefly "Table order to reporting connector"
    described as {
      |Wires table order events to the reporting context
      |for sales reports.
    }
  }
} with {
  briefly "Front of house context"
  described as {
    | Manages reservations, table seating, dine-in orders,
    | billing, and payment. Communicates with kitchen, bar,
    | and loyalty contexts via adaptors.
  }
}
