// LoyaltyAccount entity for the Loyalty context
entity LoyaltyAccount is {
  // ---- Commands ----
  command EnrollCustomer is  {
    loyaltyAccountId: LoyaltyAccountId with {
      briefly "ID"
      described as {
        |Identifier for the new account.
      }
    }
    loyaltyCustomerId: LoyaltyCustomerId with {
      briefly "Customer ID"
      described as {
        |Customer to enroll.
      }
    }
    customerDisplayName: String(1,100) with {
      briefly "Name"
      described as {
        |Customer display name.
      }
    }
    customerEmail: String(5,254) with {
      briefly "Email"
      described as {
        |Customer email address.
      }
    }
  } with {
    briefly "Enroll customer"
    described as {
      |Enroll a new customer in the loyalty program.
    }
  }
  command AccruePoints is  {
    loyaltyAccountId: LoyaltyAccountId with {
      briefly "ID"
      described as {
        |Account to accrue points to.
      }
    }
    accrualPoints: Natural with {
      briefly "Points"
      described as {
        |Number of points to accrue.
      }
    }
    accrualReason: String(1,200) with {
      briefly "Reason"
      described as {
        |Reason for accrual such as purchase.
      }
    }
    accrualOrderRef: String(1,50)? with {
      briefly "Order reference"
      described as {
        |Reference to the originating order.
      }
    }
  } with {
    briefly "Accrue points"
    described as {
      |Add loyalty points to the account.
    }
  }
  command RedeemPoints is  {
    loyaltyAccountId: LoyaltyAccountId with {
      briefly "ID"
      described as {
        |Account to redeem points from.
      }
    }
    redemptionPoints: Natural with {
      briefly "Points"
      described as {
        |Number of points to redeem.
      }
    }
    redemptionReason: String(1,200) with {
      briefly "Reason"
      described as {
        |What the points are being redeemed for.
      }
    }
  } with {
    briefly "Redeem points"
    described as {
      |Redeem loyalty points from the account.
    }
  }
  command SuspendAccount is  {
    loyaltyAccountId: LoyaltyAccountId with {
      briefly "ID"
      described as {
        |Account to suspend.
      }
    }
    suspensionReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Reason for suspension.
      }
    }
  } with {
    briefly "Suspend account"
    described as {
      |Suspend a loyalty account.
    }
  }
  command ReactivateAccount is  {
    loyaltyAccountId: LoyaltyAccountId with {
      briefly "ID"
      described as {
        |Account to reactivate.
      }
    }
  } with {
    briefly "Reactivate account"
    described as {
      |Reactivate a suspended loyalty account.
    }
  }
  command CloseAccount is {
    loyaltyAccountId: LoyaltyAccountId with {
      briefly "ID"
      described as {
        |Account to close permanently.
      }
    }
    closureReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Reason for permanent closure.
      }
    }
  } with {
    briefly "Close account"
    described as {
      |Permanently close a loyalty account.
    }
  }
  // ---- Events ----
  event CustomerEnrolled is  {
    loyaltyAccountId: LoyaltyAccountId with {
      briefly "ID"
      described as {
        |Account identifier.
      }
    }
    loyaltyCustomerId: LoyaltyCustomerId with {
      briefly "Customer ID"
      described as {
        |Customer.
      }
    }
    customerDisplayName: String(1,100) with {
      briefly "Name"
      described as {
        |Customer name.
      }
    }
    customerEmail: String(5,254) with {
      briefly "Email"
      described as {
        |Customer email.
      }
    }
    enrolledAt: TimeStamp with {
      briefly "Enrolled at"
      described as {
        |When enrolled.
      }
    }
  } with {
    briefly "Customer enrolled"
    described as {
      |Emitted when a customer enrolls in loyalty.
    }
  }
  event PointsAccrued is  {
    loyaltyAccountId: LoyaltyAccountId with {
      briefly "ID"
      described as {
        |Account identifier.
      }
    }
    accrualPoints: Natural with {
      briefly "Points"
      described as {
        |Points accrued.
      }
    }
    accrualReason: String(1,200) with {
      briefly "Reason"
      described as {
        |Accrual reason.
      }
    }
    newBalance: Natural with {
      briefly "Balance"
      described as {
        |New point balance after accrual.
      }
    }
    accruedAt: TimeStamp with {
      briefly "Accrued at"
      described as {
        |When accrued.
      }
    }
  } with {
    briefly "Points accrued"
    described as {
      |Emitted when points are added to an account.
    }
  }
  event PointsRedeemed is  {
    loyaltyAccountId: LoyaltyAccountId with {
      briefly "ID"
      described as {
        |Account identifier.
      }
    }
    redemptionPoints: Natural with {
      briefly "Points"
      described as {
        |Points redeemed.
      }
    }
    redemptionReason: String(1,200) with {
      briefly "Reason"
      described as {
        |Redemption reason.
      }
    }
    remainingBalance: Natural with {
      briefly "Balance"
      described as {
        |Remaining point balance after redemption.
      }
    }
    redeemedAt: TimeStamp with {
      briefly "Redeemed at"
      described as {
        |When redeemed.
      }
    }
  } with {
    briefly "Points redeemed"
    described as {
      |Emitted when points are redeemed from an account.
    }
  }
  event AccountSuspended is  {
    loyaltyAccountId: LoyaltyAccountId with {
      briefly "ID"
      described as {
        |Account identifier.
      }
    }
    suspensionReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Suspension reason.
      }
    }
    suspendedAt: TimeStamp with {
      briefly "Suspended at"
      described as {
        |When suspended.
      }
    }
  } with {
    briefly "Account suspended"
    described as {
      |Emitted when a loyalty account is suspended.
    }
  }
  event AccountReactivated is  {
    loyaltyAccountId: LoyaltyAccountId with {
      briefly "ID"
      described as {
        |Account identifier.
      }
    }
    reactivatedAt: TimeStamp with {
      briefly "Reactivated at"
      described as {
        |When reactivated.
      }
    }
  } with {
    briefly "Account reactivated"
    described as {
      |Emitted when a suspended account is reactivated.
    }
  }
  event AccountClosed is {
    loyaltyAccountId: LoyaltyAccountId with {
      briefly "ID"
      described as {
        |Account identifier.
      }
    }
    closureReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Reason for closure.
      }
    }
    closedAt: TimeStamp with {
      briefly "Closed at"
      described as {
        |When closed.
      }
    }
  } with {
    briefly "Account closed"
    described as {
      |Emitted when a loyalty account is permanently closed.
    }
  }
  // ---- State ----
  record LoyaltyAccountData is {
    loyaltyAccountId: LoyaltyAccountId with {
      briefly "ID"
      described as {
        |Account identifier.
      }
    }
    loyaltyCustomerId: LoyaltyCustomerId with {
      briefly "Customer ID"
      described as {
        |Customer.
      }
    }
    customerDisplayName: String(1,100) with {
      briefly "Name"
      described as {
        |Customer name.
      }
    }
    customerEmail: String(5,254) with {
      briefly "Email"
      described as {
        |Customer email.
      }
    }
    pointBalance: Natural with {
      briefly "Balance"
      described as {
        |Current point balance.
      }
    }
    lifetimePoints: Natural with {
      briefly "Lifetime points"
      described as {
        |Total points earned since enrollment.
      }
    }
    recentTransactions: PointTransaction+ with {
      briefly "Transactions"
      described as {
        |Recent point transactions.
      }
    }
    enrolledAt: TimeStamp with {
      briefly "Enrolled at"
      described as {
        |When enrolled.
      }
    }
    closedAt: TimeStamp? with {
      briefly "Closed at"
      described as {
        |When the account was permanently closed.
      }
    }
  } with {
    briefly "Loyalty account state data"
    described as {
      |Full state of a loyalty account. Shared across all
      |lifecycle states as a superset record.
    }
  }
  state Active of type LoyaltyAccount.LoyaltyAccountData is {
    handler ActiveHandler is {
      on command AccruePoints is {
        tell event PointsAccrued to entity
          Loyalty.LoyaltyAccount
      }
      on event PointsAccrued is {
        set field LoyaltyAccount.Active.pointBalance to
          "LoyaltyAccountData.pointBalance +
          PointsAccrued.accrualPoints"
        set field LoyaltyAccount.Active.lifetimePoints to
          "LoyaltyAccountData.lifetimePoints +
          PointsAccrued.accrualPoints"
        do "append PointTransaction to LoyaltyAccountData
          .recentTransactions with new transactionId,
          pointsChanged = PointsAccrued.accrualPoints,
          transactionReason = PointsAccrued.accrualReason,
          sourceOrderRef = AccruePoints.accrualOrderRef,
          transactionTimestamp = current timestamp"
      }
      on command RedeemPoints is {
        when "LoyaltyAccountData.pointBalance >=
          RedeemPoints.redemptionPoints" then
          tell event PointsRedeemed to entity
            Loyalty.LoyaltyAccount
        else
          error "insufficient point balance for redemption"
        end
      }
      on event PointsRedeemed is {
        set field LoyaltyAccount.Active.pointBalance to
          "LoyaltyAccountData.pointBalance -
          PointsRedeemed.redemptionPoints"
        do "append PointTransaction to LoyaltyAccountData
          .recentTransactions with new transactionId,
          pointsChanged = negative PointsRedeemed
          .redemptionPoints, transactionReason = PointsRedeemed
          .redemptionReason, transactionTimestamp = current
          timestamp"
      }
      on command SuspendAccount is {
        tell event AccountSuspended to entity
          Loyalty.LoyaltyAccount
      }
      on event AccountSuspended is {
        morph entity Loyalty.LoyaltyAccount to state
          Loyalty.LoyaltyAccount.Suspended
            with event AccountSuspended
      }
      on command CloseAccount is {
        tell event AccountClosed to entity
          Loyalty.LoyaltyAccount
      }
      on event AccountClosed is {
        morph entity Loyalty.LoyaltyAccount to state
          Loyalty.LoyaltyAccount.Closed
            with event AccountClosed
        set field LoyaltyAccount.Closed.closedAt to
          "current timestamp"
      }
      on command EnrollCustomer is {
        error "Customer is already enrolled"
      }
      on command ReactivateAccount is {
        error "Account is already active"
      }
    } with {
      briefly "Active state handler"
      described as {
        |Handles commands valid in the Active state.
        |AccruePoints and RedeemPoints operate within
        |Active without state transition. SuspendAccount
        |and CloseAccount transition to other states.
      }
    }
  } with {
    briefly "Active account"
    described as {
      |Account is enrolled and operational. Points can be
      |accrued and redeemed.
    }
  }
  state Suspended of type LoyaltyAccount.LoyaltyAccountData is {
    handler SuspendedHandler is {
      on command ReactivateAccount is {
        tell event AccountReactivated to entity
          Loyalty.LoyaltyAccount
      }
      on event AccountReactivated is {
        morph entity Loyalty.LoyaltyAccount to state
          Loyalty.LoyaltyAccount.Active
            with event AccountReactivated
      }
      on command CloseAccount is {
        tell event AccountClosed to entity
          Loyalty.LoyaltyAccount
      }
      on event AccountClosed is {
        morph entity Loyalty.LoyaltyAccount to state
          Loyalty.LoyaltyAccount.Closed
            with event AccountClosed
        set field LoyaltyAccount.Closed.closedAt to
          "current timestamp"
      }
      on command EnrollCustomer is {
        error "Customer is already enrolled"
      }
      on command AccruePoints is {
        error "Cannot accrue points on a suspended account"
      }
      on command RedeemPoints is {
        error "Cannot redeem points on a suspended account"
      }
      on command SuspendAccount is {
        error "Account is already suspended"
      }
    } with {
      briefly "Suspended state handler"
      described as {
        |Handles commands valid in the Suspended state.
        |ReactivateAccount returns to Active. CloseAccount
        |permanently closes the account.
      }
    }
  } with {
    briefly "Suspended account"
    described as {
      |Account is temporarily suspended. Points cannot be
      |accrued or redeemed until reactivated.
    }
  }
  state Closed of type LoyaltyAccount.LoyaltyAccountData is {
    handler ClosedHandler is {
      on command EnrollCustomer is {
        error "Account is permanently closed"
      }
      on command AccruePoints is {
        error "Account is permanently closed"
      }
      on command RedeemPoints is {
        error "Account is permanently closed"
      }
      on command SuspendAccount is {
        error "Account is permanently closed"
      }
      on command ReactivateAccount is {
        error "Account is permanently closed"
      }
      on command CloseAccount is {
        error "Account is already closed"
      }
    } with {
      briefly "Closed state handler"
      described as {
        |Terminal state. All commands are rejected.
      }
    }
  } with {
    briefly "Closed account"
    described as {
      |Account is permanently closed. No further operations
      |are possible.
    }
  }
  handler LoyaltyCreationHandler is {
    on command EnrollCustomer is {
      tell event CustomerEnrolled to entity
        Loyalty.LoyaltyAccount
    }
    on event CustomerEnrolled is {
      morph entity Loyalty.LoyaltyAccount to state
        Loyalty.LoyaltyAccount.Active
          with event CustomerEnrolled
      set field LoyaltyAccount.Active.pointBalance to "0"
      set field LoyaltyAccount.Active.lifetimePoints to "0"
      do "CustomerEnrolled event triggers welcome push
        notification via NotificationService streaming
        topology"
    }
  } with {
    briefly "Loyalty creation handler"
    described as {
      |Handles the initial EnrollCustomer command when
      |the entity has no state yet.
    }
  }
} with {
  briefly "Loyalty account entity"
  described as {
    | Manages the lifecycle of a loyalty account from
    | enrollment through point accrual, redemption,
    | suspension, and reactivation. State handlers ensure
    | commands are only valid in appropriate states, and
    | events are persisted before state transitions.
  }
}
