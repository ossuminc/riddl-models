// TableOrder entity for the Front of House context
entity TableOrder is {
  // ---- Commands ----
  command CreateOrder is  {
    tableOrderId: TableOrderId with {
      briefly "ID"
      described as {
        |Identifier for the new order.
      }
    }
    tableNumber: TableNumber with {
      briefly "Table"
      described as {
        |Table this order belongs to.
      }
    }
    serverId: String(1,50) with {
      briefly "Server ID"
      described as {
        |Identifier of the assigned server.
      }
    }
  } with {
    briefly "Create order"
    described as {
      |Create a new table order.
    }
  }
  command AddItem is  {
    tableOrderId: TableOrderId with {
      briefly "ID"
      described as {
        |Order to add item to.
      }
    }
    addedItem: OrderLine with {
      briefly "Item"
      described as {
        |Line item to add.
      }
    }
  } with {
    briefly "Add item"
    described as {
      |Add a menu item to the order.
    }
  }
  command RemoveItem is  {
    tableOrderId: TableOrderId with {
      briefly "ID"
      described as {
        |Order to remove item from.
      }
    }
    removedMenuItemId: String(1,50) with {
      briefly "Menu item ID"
      described as {
        |Identifier of the menu item to remove.
      }
    }
  } with {
    briefly "Remove item"
    described as {
      |Remove a menu item from the order.
    }
  }
  command SubmitOrder is  {
    tableOrderId: TableOrderId with {
      briefly "ID"
      described as {
        |Order to submit.
      }
    }
    submittedAt: TimeStamp with {
      briefly "Submitted at"
      described as {
        |When the order was submitted.
      }
    }
  } with {
    briefly "Submit order"
    described as {
      |Submit the order to kitchen and bar.
    }
  }
  command PresentBill is  {
    tableOrderId: TableOrderId with {
      briefly "ID"
      described as {
        |Order to present bill for.
      }
    }
    billTotal: Decimal(10,2) with {
      briefly "Total"
      described as {
        |Calculated bill total.
      }
    }
  } with {
    briefly "Present bill"
    described as {
      |Present the bill to the table.
    }
  }
  command ProcessPayment is  {
    tableOrderId: TableOrderId with {
      briefly "ID"
      described as {
        |Order to process payment for.
      }
    }
    orderPayment: PaymentInfo with {
      briefly "Payment"
      described as {
        |Payment details.
      }
    }
  } with {
    briefly "Process payment"
    described as {
      |Process payment for the order.
    }
  }
  command CloseOrder is  {
    tableOrderId: TableOrderId with {
      briefly "ID"
      described as {
        |Order to close.
      }
    }
    closedAt: TimeStamp with {
      briefly "Closed at"
      described as {
        |When the order was closed.
      }
    }
  } with {
    briefly "Close order"
    described as {
      |Close the order after payment.
    }
  }
  command MarkOrderInPreparation is {
    tableOrderId: TableOrderId with {
      briefly "ID"
      described as {
        |Order being prepared.
      }
    }
  } with {
    briefly "Mark order in preparation"
    described as {
      |Mark the order as actively being prepared by
      |kitchen and bar. Triggered by adaptor from Kitchen
      |context.
    }
  }
  command MarkOrderReadyToServe is {
    tableOrderId: TableOrderId with {
      briefly "ID"
      described as {
        |Order that is ready.
      }
    }
    readyAt: TimeStamp with {
      briefly "Ready at"
      described as {
        |When all items became ready.
      }
    }
  } with {
    briefly "Mark order ready to serve"
    described as {
      |Mark the order as ready for serving. Triggered by
      |adaptor from Kitchen and Bar contexts when all items
      |are complete.
    }
  }
  // ---- Events ----
  event OrderCreated is  {
    tableOrderId: TableOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    tableNumber: TableNumber with {
      briefly "Table"
      described as {
        |Table number.
      }
    }
    serverId: String(1,50) with {
      briefly "Server ID"
      described as {
        |Assigned server.
      }
    }
    createdAt: TimeStamp with {
      briefly "Created at"
      described as {
        |When the order was created.
      }
    }
  } with {
    briefly "Order created"
    described as {
      |Emitted when a new table order is created.
    }
  }
  event ItemAdded is  {
    tableOrderId: TableOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    addedItem: OrderLine with {
      briefly "Item"
      described as {
        |Item that was added.
      }
    }
  } with {
    briefly "Item added"
    described as {
      |Emitted when an item is added to the order.
    }
  }
  event ItemRemoved is  {
    tableOrderId: TableOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    removedMenuItemId: String(1,50) with {
      briefly "Menu item ID"
      described as {
        |Identifier of the removed item.
      }
    }
  } with {
    briefly "Item removed"
    described as {
      |Emitted when an item is removed from the order.
    }
  }
  event OrderSubmitted is  {
    tableOrderId: TableOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    orderItems: OrderLine+ with {
      briefly "Items"
      described as {
        |All items in the submitted order.
      }
    }
    tableNumber: TableNumber with {
      briefly "Table"
      described as {
        |Table number.
      }
    }
    submittedAt: TimeStamp with {
      briefly "Submitted at"
      described as {
        |When the order was submitted.
      }
    }
  } with {
    briefly "Order submitted"
    described as {
      |Emitted when the order is submitted to kitchen and bar.
    }
  }
  event BillPresented is  {
    tableOrderId: TableOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    billTotal: Decimal(10,2) with {
      briefly "Total"
      described as {
        |Bill total amount.
      }
    }
    presentedAt: TimeStamp with {
      briefly "Presented at"
      described as {
        |When the bill was presented.
      }
    }
  } with {
    briefly "Bill presented"
    described as {
      |Emitted when the bill is presented to the table.
    }
  }
  event PaymentProcessed is  {
    tableOrderId: TableOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    orderPayment: PaymentInfo with {
      briefly "Payment"
      described as {
        |Payment details.
      }
    }
    processedAt: TimeStamp with {
      briefly "Processed at"
      described as {
        |When payment was processed.
      }
    }
  } with {
    briefly "Payment processed"
    described as {
      |Emitted when payment is successfully processed.
    }
  }
  event OrderClosed is  {
    tableOrderId: TableOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    closedAt: TimeStamp with {
      briefly "Closed at"
      described as {
        |When the order was closed.
      }
    }
  } with {
    briefly "Order closed"
    described as {
      |Emitted when the order is closed after payment.
    }
  }
  event OrderMarkedInPreparation is {
    tableOrderId: TableOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
  } with {
    briefly "Order in preparation"
    described as {
      |Emitted when the kitchen or bar begins preparing
      |the order.
    }
  }
  event OrderMarkedReadyToServe is {
    tableOrderId: TableOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    readyAt: TimeStamp with {
      briefly "Ready at"
      described as {
        |When all items were ready.
      }
    }
  } with {
    briefly "Order ready to serve"
    described as {
      |Emitted when all items for the order are ready
      |for serving.
    }
  }
  // ---- State ----
  record TableOrderData is {
    tableOrderId: TableOrderId with {
      briefly "ID"
      described as {
        |Order identifier.
      }
    }
    tableNumber: TableNumber with {
      briefly "Table"
      described as {
        |Table number.
      }
    }
    serverId: String(1,50) with {
      briefly "Server ID"
      described as {
        |Assigned server.
      }
    }
    orderItems: OrderLine+ with {
      briefly "Items"
      described as {
        |Items in the order.
      }
    }
    presentedBillTotal: Decimal(10,2)? with {
      briefly "Total"
      described as {
        |Bill total when presented.
      }
    }
    processedPayment: PaymentInfo? with {
      briefly "Payment"
      described as {
        |Payment info when processed.
      }
    }
    createdAt: TimeStamp with {
      briefly "Created at"
      described as {
        |When the order was created.
      }
    }
    actualSubmittedAt: TimeStamp? with {
      briefly "Submitted at"
      described as {
        |When the order was submitted.
      }
    }
    readyAt: TimeStamp? with {
      briefly "Ready at"
      described as {
        |When all items were ready to serve.
      }
    }
    actualClosedAt: TimeStamp? with {
      briefly "Closed at"
      described as {
        |When the order was closed.
      }
    }
  } with {
    briefly "Table order state data"
    described as {
      |Full state of a table order. Shared across all
      |lifecycle states as a superset record.
    }
  }
  state Draft of type TableOrder.TableOrderData is {
    handler DraftHandler is {
      on command AddItem is {
        tell event ItemAdded to entity FrontOfHouse.TableOrder
      }
      on event ItemAdded is {
        do "append ItemAdded.addedItem to
          TableOrderData.orderItems"
      }
      on command RemoveItem is {
        tell event ItemRemoved to entity FrontOfHouse.TableOrder
      }
      on event ItemRemoved is {
        do "remove OrderLine from TableOrderData.orderItems
          where orderLineItem.itemCode = ItemRemoved
          .removedMenuItemId"
      }
      on command SubmitOrder is {
        tell event OrderSubmitted to entity
          FrontOfHouse.TableOrder
      }
      on event OrderSubmitted is {
        morph entity FrontOfHouse.TableOrder to state
          FrontOfHouse.TableOrder.Submitted
            with event OrderSubmitted
        set field TableOrder.Submitted.actualSubmittedAt to
          "submittedAt from event"
        send event OrderSubmitted to outlet
          FrontOfHouse.OrderSplitter.SubmittedOrders
        when "TableOrderData.orderItems contains food
          category items" then
          tell command ReceiveTicket to entity
            Kitchen.KitchenTicket
        end
        when "TableOrderData.orderItems contains drink
          category items" then
          tell command ReceiveDrinkOrder to entity
            Bar.DrinkOrder
        end
      }
      on command CreateOrder is {
        error "Order has already been created"
      }
      on command MarkOrderInPreparation is {
        error "Cannot mark in preparation before order is submitted"
      }
      on command MarkOrderReadyToServe is {
        error "Cannot mark ready before order is submitted"
      }
      on command PresentBill is {
        error "Cannot present bill before order is prepared"
      }
      on command ProcessPayment is {
        error "Cannot process payment before bill is presented"
      }
      on command CloseOrder is {
        error "Cannot close order before payment is processed"
      }
    } with {
      briefly "Draft state handler"
      described as {
        |Handles commands valid in the Draft state.
        |AddItem and RemoveItem modify the order. SubmitOrder
        |freezes items and routes to kitchen and bar.
      }
    }
  } with {
    briefly "Draft order"
    described as {
      |Order is being composed. Items can be added or
      |removed before submission.
    }
  }
  state Submitted of type TableOrder.TableOrderData is {
    handler SubmittedHandler is {
      on command MarkOrderInPreparation is {
        tell event OrderMarkedInPreparation to entity
          FrontOfHouse.TableOrder
      }
      on event OrderMarkedInPreparation is {
        morph entity FrontOfHouse.TableOrder to state
          FrontOfHouse.TableOrder.InPreparation
            with event OrderMarkedInPreparation
      }
      on command CreateOrder is {
        error "Order has already been created"
      }
      on command AddItem is {
        error "Cannot add items after order is submitted"
      }
      on command RemoveItem is {
        error "Cannot remove items after order is submitted"
      }
      on command SubmitOrder is {
        error "Order has already been submitted"
      }
      on command MarkOrderReadyToServe is {
        error "Cannot mark ready before preparation begins"
      }
      on command PresentBill is {
        error "Cannot present bill before order is prepared"
      }
      on command ProcessPayment is {
        error "Cannot process payment before bill is presented"
      }
      on command CloseOrder is {
        error "Cannot close order before payment is processed"
      }
    } with {
      briefly "Submitted state handler"
      described as {
        |Handles commands valid in the Submitted state.
        |Only MarkOrderInPreparation advances the lifecycle.
      }
    }
  } with {
    briefly "Order submitted"
    described as {
      |Order has been submitted to kitchen and bar for
      |preparation. Items are frozen.
    }
  }
  state InPreparation of type TableOrder.TableOrderData is {
    handler InPreparationHandler is {
      on command MarkOrderReadyToServe is {
        tell event OrderMarkedReadyToServe to entity
          FrontOfHouse.TableOrder
      }
      on event OrderMarkedReadyToServe is {
        morph entity FrontOfHouse.TableOrder to state
          FrontOfHouse.TableOrder.ReadyToServe
            with event OrderMarkedReadyToServe
        set field TableOrder.ReadyToServe.readyAt to
          "readyAt from event"
      }
      on command CreateOrder is {
        error "Order has already been created"
      }
      on command AddItem is {
        error "Cannot add items after order is submitted"
      }
      on command RemoveItem is {
        error "Cannot remove items after order is submitted"
      }
      on command SubmitOrder is {
        error "Order has already been submitted"
      }
      on command MarkOrderInPreparation is {
        error "Order is already in preparation"
      }
      on command PresentBill is {
        error "Cannot present bill before order is ready"
      }
      on command ProcessPayment is {
        error "Cannot process payment before bill is presented"
      }
      on command CloseOrder is {
        error "Cannot close order before payment is processed"
      }
    } with {
      briefly "InPreparation state handler"
      described as {
        |Handles commands valid in the InPreparation state.
        |Only MarkOrderReadyToServe advances the lifecycle.
      }
    }
  } with {
    briefly "In preparation"
    described as {
      |Kitchen and bar are actively preparing the items.
    }
  }
  state ReadyToServe of type TableOrder.TableOrderData is {
    handler ReadyToServeHandler is {
      on command PresentBill is {
        tell event BillPresented to entity
          FrontOfHouse.TableOrder
      }
      on event BillPresented is {
        morph entity FrontOfHouse.TableOrder to state
          FrontOfHouse.TableOrder.BillPresentedState
            with event BillPresented
        do "sum TableOrderData.orderItems applying
          orderLineItem.itemPrice * orderLineQuantity for each
          OrderLine to compute presentedBillTotal"
        set field TableOrder.BillPresentedState.presentedBillTotal
          to "computed presentedBillTotal"
      }
      on command CreateOrder is {
        error "Order has already been created"
      }
      on command AddItem is {
        error "Cannot add items after order is submitted"
      }
      on command RemoveItem is {
        error "Cannot remove items after order is submitted"
      }
      on command SubmitOrder is {
        error "Order has already been submitted"
      }
      on command MarkOrderInPreparation is {
        error "Order preparation is already complete"
      }
      on command MarkOrderReadyToServe is {
        error "Order is already ready to serve"
      }
      on command ProcessPayment is {
        error "Cannot process payment before bill is presented"
      }
      on command CloseOrder is {
        error "Cannot close order before payment is processed"
      }
    } with {
      briefly "ReadyToServe state handler"
      described as {
        |Handles commands valid in the ReadyToServe state.
        |Only PresentBill advances the lifecycle.
      }
    }
  } with {
    briefly "Ready to serve"
    described as {
      |All items are ready and waiting for the server to
      |deliver them to the table.
    }
  }
  state BillPresentedState of type TableOrder.TableOrderData is {
    handler BillPresentedHandler is {
      on command ProcessPayment is {
        tell event PaymentProcessed to entity
          FrontOfHouse.TableOrder
      }
      on event PaymentProcessed is {
        morph entity FrontOfHouse.TableOrder to state
          FrontOfHouse.TableOrder.PaymentComplete
            with event PaymentProcessed
        set field TableOrder.PaymentComplete.processedPayment to
          "payment info from event"
        do "PaymentProcessed event triggers PaymentGateway
          authorization via streaming topology and Loyalty
          point accrual via ToLoyalty adaptor"
      }
      on command CreateOrder is {
        error "Order has already been created"
      }
      on command AddItem is {
        error "Cannot add items after order is submitted"
      }
      on command RemoveItem is {
        error "Cannot remove items after order is submitted"
      }
      on command SubmitOrder is {
        error "Order has already been submitted"
      }
      on command MarkOrderInPreparation is {
        error "Order preparation is already complete"
      }
      on command MarkOrderReadyToServe is {
        error "Order is already ready to serve"
      }
      on command PresentBill is {
        error "Bill has already been presented"
      }
      on command CloseOrder is {
        error "Cannot close order before payment is processed"
      }
    } with {
      briefly "BillPresented state handler"
      described as {
        |Handles commands valid in the BillPresented state.
        |Only ProcessPayment advances the lifecycle.
      }
    }
  } with {
    briefly "Bill presented"
    described as {
      |Bill has been calculated and presented to the table.
      |Awaiting payment.
    }
  }
  state PaymentComplete of type TableOrder.TableOrderData is {
    handler PaymentCompleteHandler is {
      on command CloseOrder is {
        tell event OrderClosed to entity
          FrontOfHouse.TableOrder
      }
      on event OrderClosed is {
        morph entity FrontOfHouse.TableOrder to state
          FrontOfHouse.TableOrder.Closed
            with event OrderClosed
        set field TableOrder.Closed.actualClosedAt to
          "closedAt from event"
        do "OrderClosed event triggers accounting transaction
          posting via streaming topology"
      }
      on command CreateOrder is {
        error "Order has already been created"
      }
      on command AddItem is {
        error "Cannot add items after order is submitted"
      }
      on command RemoveItem is {
        error "Cannot remove items after order is submitted"
      }
      on command SubmitOrder is {
        error "Order has already been submitted"
      }
      on command MarkOrderInPreparation is {
        error "Order preparation is already complete"
      }
      on command MarkOrderReadyToServe is {
        error "Order is already ready to serve"
      }
      on command PresentBill is {
        error "Bill has already been presented"
      }
      on command ProcessPayment is {
        error "Payment has already been processed"
      }
    } with {
      briefly "PaymentComplete state handler"
      described as {
        |Handles commands valid in the PaymentComplete state.
        |Only CloseOrder advances the lifecycle.
      }
    }
  } with {
    briefly "Payment complete"
    described as {
      |Payment has been processed through the payment
      |gateway. Awaiting order closure.
    }
  }
  state Closed of type TableOrder.TableOrderData is {
    handler ClosedHandler is {
      on command CreateOrder is {
        error "Order is closed"
      }
      on command AddItem is {
        error "Order is closed"
      }
      on command RemoveItem is {
        error "Order is closed"
      }
      on command SubmitOrder is {
        error "Order is closed"
      }
      on command MarkOrderInPreparation is {
        error "Order is closed"
      }
      on command MarkOrderReadyToServe is {
        error "Order is closed"
      }
      on command PresentBill is {
        error "Order is closed"
      }
      on command ProcessPayment is {
        error "Order is closed"
      }
      on command CloseOrder is {
        error "Order is already closed"
      }
    } with {
      briefly "Closed state handler"
      described as {
        |Terminal state. All commands are rejected.
      }
    }
  } with {
    briefly "Order closed"
    described as {
      |Order has been finalized after payment. Terminal
      |state.
    }
  }
  handler TableOrderCreationHandler is {
    on command CreateOrder is {
      tell event OrderCreated to entity FrontOfHouse.TableOrder
    }
    on event OrderCreated is {
      morph entity FrontOfHouse.TableOrder to state
        FrontOfHouse.TableOrder.Draft
          with event OrderCreated
    }
  } with {
    briefly "Table order creation handler"
    described as {
      |Handles the initial CreateOrder command when
      |the entity has no state yet.
    }
  }
} with {
  briefly "Table order entity"
  described as {
    | Manages the full lifecycle of a dine-in table order
    | from creation through item management, submission
    | to kitchen and bar, billing, payment, and closing.
    | State handlers ensure commands are only valid in
    | appropriate states, and events are persisted before
    | state transitions.
  }
}
