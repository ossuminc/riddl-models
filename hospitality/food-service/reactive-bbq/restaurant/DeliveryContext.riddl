// Delivery bounded context
context Delivery is {
  include "delivery-types.riddl"
  include "Delivery.riddl"
  repository DeliveryRepository is {
    schema DeliveryData is relational
      of deliveries as type DeliveryOrder
        index on field DeliveryOrder.deliveryId
        index on field DeliveryOrder.deliveryStatus
        index on field DeliveryOrder.assignedDriverId

    handler DeliveryPersistence is {
      on command DeliveryOrder.CreateDelivery is {
        tell event DeliveryOrder.DeliveryCreated to entity
          Delivery.DeliveryOrder
        do "insert row into DeliveryData.deliveries with
          deliveryId, sourceOnlineOrderId, deliveryCustomerName,
          deliveryCustomerPhone, deliveryDestination,
          deliveryStatus = DeliveryPending, createdAt"
      }
      on command DeliveryOrder.AssignDriver is {
        tell event DeliveryOrder.DriverAssigned to entity
          Delivery.DeliveryOrder
        do "update DeliveryData.deliveries set assignedDriverId
          = driverId, assignedDriverName = driverName,
          deliveryStatus = DriverAssignedStatus where
          deliveryId matches"
      }
      on command DeliveryOrder.DispatchDriver is {
        tell event DeliveryOrder.DriverDispatched to entity
          Delivery.DeliveryOrder
        do "update DeliveryData.deliveries set deliveryStatus =
          InTransit, actualDispatchedAt = dispatchedAt where
          deliveryId matches"
      }
      on command DeliveryOrder.RecordDeliveryLocation is {
        tell event DeliveryOrder.DeliveryLocationRecorded to
          entity Delivery.DeliveryOrder
        do "update DeliveryData.deliveries set lastKnownLocation
          = driverLocation where deliveryId matches"
      }
      on command DeliveryOrder.ConfirmDelivery is {
        tell event DeliveryOrder.DeliveryConfirmed to entity
          Delivery.DeliveryOrder
        do "update DeliveryData.deliveries set deliveryStatus =
          Delivered, actualConfirmedAt = confirmedAt where
          deliveryId matches"
      }
      on command DeliveryOrder.RecordDeliveryPayment is {
        tell event DeliveryOrder.DeliveryPaymentRecorded to
          entity Delivery.DeliveryOrder
        do "update DeliveryData.deliveries set deliveryTip =
          deliveryTip where deliveryId matches"
      }
      on command DeliveryOrder.ReportDeliveryIssue is {
        tell event DeliveryOrder.DeliveryIssueReported to entity
          Delivery.DeliveryOrder
        do "update DeliveryData.deliveries with issueType and
          issueDescription where deliveryId matches"
      }
    } with {
      briefly "Delivery persistence"
      described as {
        |Persists delivery events to the deliveries table
        |and updates the current state projection.
      }
    }
  } with {
    briefly "Delivery repository"
    described as {
      |Stores and retrieves delivery data.
    }
  }
  adaptor FromOnlineOrdering from context Restaurant.OnlineOrdering is {
    handler OnlineDeliveryIntake is {
      on event Restaurant.OnlineOrdering.OnlineOrder.FulfillmentSelected is {
        when "event.fulfillmentType is DeliveryFulfillment" then
          do "construct CreateDelivery with new DeliveryId,
            sourceOnlineOrderId = event.onlineOrderId,
            deliveryCustomerName from customer profile,
            deliveryCustomerPhone from customer profile,
            deliveryDestination = event.deliveryAddress,
            requestedDeliveryTime = event.requestedTime"
          tell command CreateDelivery to entity
            Delivery.DeliveryOrder
        end
      }
    } with {
      briefly "Online delivery intake"
      described as {
        |Creates deliveries from online orders when delivery
        |fulfillment is selected.
      }
    }
  } with {
    briefly "Online ordering adaptor"
    described as {
      |Receives delivery-fulfillment orders from online ordering.
    }
  }
} with {
  briefly "Delivery context"
  described as {
    | Manages delivery driver dispatch, GPS tracking, and
    | offline-resilient delivery operations. Drivers can
    | cache order details and report issues when connectivity
    | resumes. Decoupled from online ordering via adaptors.
  }
}
