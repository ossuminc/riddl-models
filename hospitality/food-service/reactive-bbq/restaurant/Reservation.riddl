// Reservation entity for the Front of House context
entity Reservation is {
  // ---- Commands ----
  command InitializeReservation is { ??? } with {
    briefly "Initialize reservation"
    described as {
      |Initialize the Reservation entity on source startup.
    }
  }
  command MakeReservation is  {
    reservationId: ReservationId with {
      briefly "ID"
      described as {
        |Identifier for the new reservation.
      }
    }
    guestName: GuestName with {
      briefly "Guest"
      described as {
        |Name of the guest.
      }
    }
    guestPhone: GuestPhone with {
      briefly "Phone"
      described as {
        |Contact phone for the guest.
      }
    }
    partySize: PartySize with {
      briefly "Party size"
      described as {
        |Number of guests.
      }
    }
    reservationTime: TimeStamp with {
      briefly "Time"
      described as {
        |Requested reservation date and time.
      }
    }
  } with {
    briefly "Make reservation"
    described as {
      |Request a new reservation.
    }
  }
  command ConfirmReservation is  {
    reservationId: ReservationId with {
      briefly "ID"
      described as {
        |Reservation to confirm.
      }
    }
    confirmedTable: TableNumber with {
      briefly "Table"
      described as {
        |Table assigned for this reservation.
      }
    }
  } with {
    briefly "Confirm reservation"
    described as {
      |Confirm a pending reservation with a table assignment.
    }
  }
  command CancelReservation is  {
    reservationId: ReservationId with {
      briefly "ID"
      described as {
        |Reservation to cancel.
      }
    }
    cancellationReason: String(1,500)? with {
      briefly "Reason"
      described as {
        |Reason for cancellation.
      }
    }
  } with {
    briefly "Cancel reservation"
    described as {
      |Cancel an existing reservation.
    }
  }
  command SeatParty is  {
    reservationId: ReservationId with {
      briefly "ID"
      described as {
        |Reservation for the party being seated.
      }
    }
    seatedTable: TableNumber with {
      briefly "Table"
      described as {
        |Table where the party is seated.
      }
    }
    seatedAt: TimeStamp with {
      briefly "Seated at"
      described as {
        |Time the party was seated.
      }
    }
  } with {
    briefly "Seat party"
    described as {
      |Mark a reservation as seated at a table.
    }
  }
  command CompleteVisit is {
    reservationId: ReservationId with {
      briefly "ID"
      described as {
        |Reservation to complete.
      }
    }
    completedAt: TimeStamp with {
      briefly "Completed at"
      described as {
        |When the visit was completed.
      }
    }
  } with {
    briefly "Complete visit"
    described as {
      |Mark the reservation as completed after the party
      |has finished dining.
    }
  }
  command MarkNoShow is {
    reservationId: ReservationId with {
      briefly "ID"
      described as {
        |Reservation to mark as no-show.
      }
    }
    markedNoShowAt: TimeStamp with {
      briefly "Marked at"
      described as {
        |When the no-show was recorded.
      }
    }
  } with {
    briefly "Mark no-show"
    described as {
      |Mark a confirmed reservation as a no-show when
      |the party does not arrive.
    }
  }
  command RescheduleReservation is {
    reservationId: ReservationId with {
      briefly "ID"
      described as {
        |Reservation to reschedule.
      }
    }
    newReservationTime: TimeStamp with {
      briefly "New time"
      described as {
        |New requested reservation date and time.
      }
    }
  } with {
    briefly "Reschedule reservation"
    described as {
      |Reschedule a confirmed reservation to a new time.
      |Returns the reservation to the Requested state
      |with the updated time.
    }
  }
  // ---- Events ----
  event ReservationMade is  {
    reservationId: ReservationId with {
      briefly "ID"
      described as {
        |Identifier of the reservation.
      }
    }
    guestName: GuestName with {
      briefly "Guest"
      described as {
        |Guest name.
      }
    }
    guestPhone: GuestPhone with {
      briefly "Phone"
      described as {
        |Guest phone.
      }
    }
    partySize: PartySize with {
      briefly "Party size"
      described as {
        |Number of guests.
      }
    }
    reservationTime: TimeStamp with {
      briefly "Time"
      described as {
        |Reservation date and time.
      }
    }
    madeAt: TimeStamp with {
      briefly "Made at"
      described as {
        |When the reservation was made.
      }
    }
  } with {
    briefly "Reservation made"
    described as {
      |Emitted when a new reservation is requested.
    }
  }
  event ReservationConfirmed is  {
    reservationId: ReservationId with {
      briefly "ID"
      described as {
        |Reservation identifier.
      }
    }
    confirmedTable: TableNumber with {
      briefly "Table"
      described as {
        |Assigned table.
      }
    }
    confirmedAt: TimeStamp with {
      briefly "Confirmed at"
      described as {
        |When the reservation was confirmed.
      }
    }
  } with {
    briefly "Reservation confirmed"
    described as {
      |Emitted when a reservation is confirmed.
    }
  }
  event ReservationCancelled is  {
    reservationId: ReservationId with {
      briefly "ID"
      described as {
        |Reservation identifier.
      }
    }
    cancellationReason: String(1,500)? with {
      briefly "Reason"
      described as {
        |Reason for cancellation.
      }
    }
    cancelledAt: TimeStamp with {
      briefly "Cancelled at"
      described as {
        |When the reservation was cancelled.
      }
    }
  } with {
    briefly "Reservation cancelled"
    described as {
      |Emitted when a reservation is cancelled.
    }
  }
  event PartySeated is  {
    reservationId: ReservationId with {
      briefly "ID"
      described as {
        |Reservation identifier.
      }
    }
    seatedTable: TableNumber with {
      briefly "Table"
      described as {
        |Table where party was seated.
      }
    }
    seatedAt: TimeStamp with {
      briefly "Seated at"
      described as {
        |When the party was seated.
      }
    }
  } with {
    briefly "Party seated"
    described as {
      |Emitted when a party is seated at their table.
    }
  }
  event VisitCompleted is {
    reservationId: ReservationId with {
      briefly "ID"
      described as {
        |Reservation identifier.
      }
    }
    completedAt: TimeStamp with {
      briefly "Completed at"
      described as {
        |When the visit was completed.
      }
    }
  } with {
    briefly "Visit completed"
    described as {
      |Emitted when the party finishes dining and the
      |reservation is complete.
    }
  }
  event NoShowMarked is {
    reservationId: ReservationId with {
      briefly "ID"
      described as {
        |Reservation identifier.
      }
    }
    markedNoShowAt: TimeStamp with {
      briefly "Marked at"
      described as {
        |When the no-show was recorded.
      }
    }
  } with {
    briefly "No-show marked"
    described as {
      |Emitted when a confirmed reservation is marked as a
      |no-show.
    }
  }
  event ReservationRescheduled is {
    reservationId: ReservationId with {
      briefly "ID"
      described as {
        |Reservation identifier.
      }
    }
    previousTime: TimeStamp with {
      briefly "Previous time"
      described as {
        |The original reservation time.
      }
    }
    newReservationTime: TimeStamp with {
      briefly "New time"
      described as {
        |The new reservation time.
      }
    }
    rescheduledAt: TimeStamp with {
      briefly "Rescheduled at"
      described as {
        |When the reschedule occurred.
      }
    }
  } with {
    briefly "Reservation rescheduled"
    described as {
      |Emitted when a reservation is rescheduled to a new
      |time. The reservation returns to the Requested state.
    }
  }
  // ---- Rejection Events ----
  event MakeReservationRejected is {
    reservationId: ReservationId with {
      briefly "ID"
      described as {
        |Reservation identifier.
      }
    }
    rejectionReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Why the command was rejected.
      }
    }
  } with {
    briefly "Make reservation rejected"
    described as {
      |Emitted when a MakeReservation command is rejected.
    }
  }
  event ConfirmReservationRejected is {
    reservationId: ReservationId with {
      briefly "ID"
      described as {
        |Reservation identifier.
      }
    }
    rejectionReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Why the command was rejected.
      }
    }
  } with {
    briefly "Confirm reservation rejected"
    described as {
      |Emitted when a ConfirmReservation command is rejected.
    }
  }
  event CancelReservationRejected is {
    reservationId: ReservationId with {
      briefly "ID"
      described as {
        |Reservation identifier.
      }
    }
    rejectionReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Why the command was rejected.
      }
    }
  } with {
    briefly "Cancel reservation rejected"
    described as {
      |Emitted when a CancelReservation command is rejected.
    }
  }
  event SeatPartyRejected is {
    reservationId: ReservationId with {
      briefly "ID"
      described as {
        |Reservation identifier.
      }
    }
    rejectionReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Why the command was rejected.
      }
    }
  } with {
    briefly "Seat party rejected"
    described as {
      |Emitted when a SeatParty command is rejected.
    }
  }
  event CompleteVisitRejected is {
    reservationId: ReservationId with {
      briefly "ID"
      described as {
        |Reservation identifier.
      }
    }
    rejectionReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Why the command was rejected.
      }
    }
  } with {
    briefly "Complete visit rejected"
    described as {
      |Emitted when a CompleteVisit command is rejected.
    }
  }
  event MarkNoShowRejected is {
    reservationId: ReservationId with {
      briefly "ID"
      described as {
        |Reservation identifier.
      }
    }
    rejectionReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Why the command was rejected.
      }
    }
  } with {
    briefly "Mark no-show rejected"
    described as {
      |Emitted when a MarkNoShow command is rejected.
    }
  }
  event RescheduleReservationRejected is {
    reservationId: ReservationId with {
      briefly "ID"
      described as {
        |Reservation identifier.
      }
    }
    rejectionReason: String(1,500) with {
      briefly "Reason"
      described as {
        |Why the command was rejected.
      }
    }
  } with {
    briefly "Reschedule reservation rejected"
    described as {
      |Emitted when a RescheduleReservation command is rejected.
    }
  }
  // ---- Query/Result ----
  query GetReservation is {
    reservationId: ReservationId with {
      briefly "ID"
      described as {
        |Reservation to retrieve.
      }
    }
  } with {
    briefly "Get reservation"
    described as {
      |Query a reservation by its identifier.
    }
  }
  result ReservationResult is {
    reservation: ReservationBase with {
      briefly "Reservation"
      described as {
        |The requested reservation data.
      }
    }
  } with {
    briefly "Reservation result"
    described as {
      |Result containing the requested reservation data.
    }
  }
  // ---- State ----
  record ReservationBase is {
    reservationId: ReservationId with {
      briefly "ID"
      described as {
        |Reservation identifier.
      }
    }
    guestName: GuestName with {
      briefly "Guest"
      described as {
        |Guest name.
      }
    }
    guestPhone: GuestPhone with {
      briefly "Phone"
      described as {
        |Guest phone.
      }
    }
    partySize: PartySize with {
      briefly "Party size"
      described as {
        |Number of guests.
      }
    }
    reservationTime: TimeStamp with {
      briefly "Time"
      described as {
        |Reservation date and time.
      }
    }
    createdAt: TimeStamp with {
      briefly "Created at"
      described as {
        |When the reservation was created.
      }
    }
  } with {
    briefly "Reservation base data"
    described as {
      |Common fields shared by all reservation states.
    }
  }
  record RequestedData is {
    base: ReservationBase with {
      briefly "Base"
      described as {
        |Common reservation fields.
      }
    }
  } with {
    briefly "Requested state data"
    described as {
      |State data for a newly requested reservation
      |awaiting confirmation.
    }
  }
  record ConfirmedData is {
    base: ReservationBase with {
      briefly "Base"
      described as {
        |Common reservation fields.
      }
    }
    assignedTable: TableNumber with {
      briefly "Table"
      described as {
        |Table assigned for this reservation.
      }
    }
    confirmedAt: TimeStamp with {
      briefly "Confirmed at"
      described as {
        |When the reservation was confirmed.
      }
    }
  } with {
    briefly "Confirmed state data"
    described as {
      |State data for a confirmed reservation with table
      |assignment, awaiting the party arrival.
    }
  }
  record SeatedData is {
    base: ReservationBase with {
      briefly "Base"
      described as {
        |Common reservation fields.
      }
    }
    assignedTable: TableNumber with {
      briefly "Table"
      described as {
        |Table where the party is seated.
      }
    }
    seatedAt: TimeStamp with {
      briefly "Seated at"
      described as {
        |When the party was seated.
      }
    }
  } with {
    briefly "Seated state data"
    described as {
      |State data for a reservation where the party has
      |been seated at their table.
    }
  }
  record CompletedData is {
    base: ReservationBase with {
      briefly "Base"
      described as {
        |Common reservation fields.
      }
    }
    assignedTable: TableNumber with {
      briefly "Table"
      described as {
        |Table where the party dined.
      }
    }
    completedAt: TimeStamp with {
      briefly "Completed at"
      described as {
        |When the visit was completed.
      }
    }
  } with {
    briefly "Completed state data"
    described as {
      |State data for a completed reservation where the
      |party has finished dining.
    }
  }
  record CancelledData is {
    base: ReservationBase with {
      briefly "Base"
      described as {
        |Common reservation fields.
      }
    }
    cancelledAt: TimeStamp with {
      briefly "Cancelled at"
      described as {
        |When the reservation was cancelled.
      }
    }
    cancellationReason: String(1,500)? with {
      briefly "Reason"
      described as {
        |Reason for cancellation.
      }
    }
  } with {
    briefly "Cancelled state data"
    described as {
      |State data for a cancelled reservation.
    }
  }
  record NoShowData is {
    base: ReservationBase with {
      briefly "Base"
      described as {
        |Common reservation fields.
      }
    }
    markedNoShowAt: TimeStamp with {
      briefly "Marked at"
      described as {
        |When the no-show was recorded.
      }
    }
  } with {
    briefly "No-show state data"
    described as {
      |State data for a reservation where the party did
      |not arrive.
    }
  }
  state Requested of type Reservation.RequestedData is {
    handler RequestedInitHandler is {
      on init is {
        set state Requested to "base = ReservationBase(ReservationMade.reservationId, ReservationMade.guestName, ReservationMade.guestPhone, ReservationMade.partySize, ReservationMade.reservationTime, ReservationMade.madeAt)"
      }
    } with {
      briefly "Requested init handler"
      described as {
        |Initializes the Requested state from the
        |ReservationMade event.
      }
    }
    handler RequestedHandler is {
      on command ConfirmReservation is {
        tell event ReservationConfirmed to entity
          FrontOfHouse.Reservation
        send event ReservationConfirmed to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
      }
      on event ReservationConfirmed is {
        morph entity FrontOfHouse.Reservation to state
          FrontOfHouse.Reservation.Confirmed
            with event ReservationConfirmed
      }
      on command CancelReservation is {
        tell event ReservationCancelled to entity
          FrontOfHouse.Reservation
        send event ReservationCancelled to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
      }
      on event ReservationCancelled is {
        morph entity FrontOfHouse.Reservation to state
          FrontOfHouse.Reservation.Cancelled
            with event ReservationCancelled
      }
      on command MakeReservation is {
        send event MakeReservationRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation has already been made"
      }
      on command SeatParty is {
        send event SeatPartyRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Cannot seat party before reservation is confirmed"
      }
      on command CompleteVisit is {
        send event CompleteVisitRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Cannot complete visit before party is seated"
      }
      on command MarkNoShow is {
        send event MarkNoShowRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Cannot mark no-show before reservation is confirmed"
      }
      on command RescheduleReservation is {
        send event RescheduleReservationRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Cannot reschedule before reservation is confirmed"
      }
    } with {
      briefly "Requested state handler"
      described as {
        |Handles commands valid in the Requested state.
        |ConfirmReservation and CancelReservation advance
        |the lifecycle.
      }
    }
  } with {
    briefly "Reservation requested"
    described as {
      |Initial state after a reservation is made.
      |Awaiting confirmation with table assignment.
    }
  }
  state Confirmed of type Reservation.ConfirmedData is {
    handler ConfirmedInitHandler is {
      on init is {
        set state Confirmed to "base from prior state, assignedTable = ReservationConfirmed.confirmedTable, confirmedAt = ReservationConfirmed.confirmedAt"
      }
    } with {
      briefly "Confirmed init handler"
      described as {
        |Initializes the Confirmed state from the
        |ReservationConfirmed event.
      }
    }
    handler ConfirmedHandler is {
      on command SeatParty is {
        tell event PartySeated to entity
          FrontOfHouse.Reservation
        send event PartySeated to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
      }
      on event PartySeated is {
        morph entity FrontOfHouse.Reservation to state
          FrontOfHouse.Reservation.Seated
            with event PartySeated
        do "construct CreateOrder with new TableOrderId,
          tableNumber = PartySeated.seatedTable, serverId from
          host assignment"
        tell command CreateOrder to entity
          FrontOfHouse.TableOrder
      }
      on command CancelReservation is {
        tell event ReservationCancelled to entity
          FrontOfHouse.Reservation
        send event ReservationCancelled to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
      }
      on event ReservationCancelled is {
        morph entity FrontOfHouse.Reservation to state
          FrontOfHouse.Reservation.Cancelled
            with event ReservationCancelled
      }
      on command MarkNoShow is {
        tell event NoShowMarked to entity
          FrontOfHouse.Reservation
        send event NoShowMarked to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
      }
      on event NoShowMarked is {
        morph entity FrontOfHouse.Reservation to state
          FrontOfHouse.Reservation.NoShow
            with event NoShowMarked
      }
      on command RescheduleReservation is {
        tell event ReservationRescheduled to entity
          FrontOfHouse.Reservation
        send event ReservationRescheduled to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
      }
      on event ReservationRescheduled is {
        morph entity FrontOfHouse.Reservation to state
          FrontOfHouse.Reservation.Requested
            with event ReservationRescheduled
        set field Reservation.Requested.base to
          "copy base with reservationTime =
          ReservationRescheduled.newReservationTime"
      }
      on command MakeReservation is {
        send event MakeReservationRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation has already been made"
      }
      on command ConfirmReservation is {
        send event ConfirmReservationRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation is already confirmed"
      }
      on command CompleteVisit is {
        send event CompleteVisitRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Cannot complete visit before party is seated"
      }
    } with {
      briefly "Confirmed state handler"
      described as {
        |Handles commands valid in the Confirmed state.
        |SeatParty, CancelReservation, MarkNoShow, and
        |RescheduleReservation are all valid transitions.
      }
    }
  } with {
    briefly "Reservation confirmed"
    described as {
      |Reservation has been confirmed with a table
      |assignment. Awaiting the party's arrival.
    }
  }
  state Seated of type Reservation.SeatedData is {
    handler SeatedInitHandler is {
      on init is {
        set state Seated to "base from prior state, assignedTable from prior state, seatedAt = PartySeated.seatedAt"
      }
    } with {
      briefly "Seated init handler"
      described as {
        |Initializes the Seated state from the
        |PartySeated event.
      }
    }
    handler SeatedHandler is {
      on command CompleteVisit is {
        tell event VisitCompleted to entity
          FrontOfHouse.Reservation
        send event VisitCompleted to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
      }
      on event VisitCompleted is {
        morph entity FrontOfHouse.Reservation to state
          FrontOfHouse.Reservation.Completed
            with event VisitCompleted
      }
      on command MakeReservation is {
        send event MakeReservationRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation has already been made"
      }
      on command ConfirmReservation is {
        send event ConfirmReservationRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation is already confirmed and seated"
      }
      on command CancelReservation is {
        send event CancelReservationRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Cannot cancel reservation after party is seated"
      }
      on command SeatParty is {
        send event SeatPartyRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Party is already seated"
      }
      on command MarkNoShow is {
        send event MarkNoShowRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Cannot mark no-show after party is seated"
      }
      on command RescheduleReservation is {
        send event RescheduleReservationRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Cannot reschedule after party is seated"
      }
    } with {
      briefly "Seated state handler"
      described as {
        |Handles commands valid in the Seated state.
        |Only CompleteVisit advances the lifecycle.
      }
    }
  } with {
    briefly "Party seated"
    described as {
      |Party has arrived and been seated at their table.
      |A table order has been created.
    }
  }
  state Completed of type Reservation.CompletedData is {
    handler CompletedInitHandler is {
      on init is {
        set state Reservation.Completed to "base from prior state, assignedTable from prior state, completedAt = VisitCompleted.completedAt"
      }
    } with {
      briefly "Completed init handler"
      described as {
        |Initializes the Completed state from the
        |VisitCompleted event.
      }
    }
    handler CompletedHandler is {
      on command MakeReservation is {
        send event MakeReservationRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation is completed"
      }
      on command ConfirmReservation is {
        send event ConfirmReservationRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation is completed"
      }
      on command CancelReservation is {
        send event CancelReservationRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation is completed"
      }
      on command SeatParty is {
        send event SeatPartyRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation is completed"
      }
      on command CompleteVisit is {
        send event CompleteVisitRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation is already completed"
      }
      on command MarkNoShow is {
        send event MarkNoShowRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation is completed"
      }
      on command RescheduleReservation is {
        send event RescheduleReservationRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation is completed"
      }
    } with {
      briefly "Completed state handler"
      described as {
        |Terminal state. All commands are rejected.
      }
    }
  } with {
    briefly "Visit completed"
    described as {
      |Party has finished dining. Terminal state.
    }
  }
  state Cancelled of type Reservation.CancelledData is {
    handler CancelledInitHandler is {
      on init is {
        set state Reservation.Cancelled to "base from prior state, cancelledAt = ReservationCancelled.cancelledAt, cancellationReason = ReservationCancelled.cancellationReason"
      }
    } with {
      briefly "Cancelled init handler"
      described as {
        |Initializes the Cancelled state from the
        |ReservationCancelled event.
      }
    }
    handler CancelledHandler is {
      on command MakeReservation is {
        send event MakeReservationRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation is cancelled"
      }
      on command ConfirmReservation is {
        send event ConfirmReservationRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation is cancelled"
      }
      on command CancelReservation is {
        send event CancelReservationRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation is already cancelled"
      }
      on command SeatParty is {
        send event SeatPartyRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation is cancelled"
      }
      on command CompleteVisit is {
        send event CompleteVisitRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation is cancelled"
      }
      on command MarkNoShow is {
        send event MarkNoShowRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation is cancelled"
      }
      on command RescheduleReservation is {
        send event RescheduleReservationRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation is cancelled"
      }
    } with {
      briefly "Cancelled state handler"
      described as {
        |Terminal state. All commands are rejected.
      }
    }
  } with {
    briefly "Reservation cancelled"
    described as {
      |Reservation has been cancelled. Terminal state.
    }
  }
  state NoShow of type Reservation.NoShowData is {
    handler NoShowInitHandler is {
      on init is {
        set state NoShow to "base from prior state, markedNoShowAt = NoShowMarked.markedNoShowAt"
      }
    } with {
      briefly "NoShow init handler"
      described as {
        |Initializes the NoShow state from the
        |NoShowMarked event.
      }
    }
    handler NoShowHandler is {
      on command MakeReservation is {
        send event MakeReservationRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation is marked as no-show"
      }
      on command ConfirmReservation is {
        send event ConfirmReservationRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation is marked as no-show"
      }
      on command CancelReservation is {
        send event CancelReservationRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation is marked as no-show"
      }
      on command SeatParty is {
        send event SeatPartyRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation is marked as no-show"
      }
      on command CompleteVisit is {
        send event CompleteVisitRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation is marked as no-show"
      }
      on command MarkNoShow is {
        send event MarkNoShowRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation is already marked as no-show"
      }
      on command RescheduleReservation is {
        send event RescheduleReservationRejected to outlet
          FrontOfHouse.ReservationEventSource.ReservationEvents
        error "Reservation is marked as no-show"
      }
    } with {
      briefly "NoShow state handler"
      described as {
        |Terminal state. All commands are rejected.
      }
    }
  } with {
    briefly "No-show"
    described as {
      |Party did not arrive for their confirmed
      |reservation. Terminal state.
    }
  }
  handler ReservationCreationHandler is {
    on command MakeReservation is {
      do "validate MakeReservation.partySize is between 1 and 20"
      do "validate MakeReservation.reservationTime is in the
        future and within the 30-day booking window"
      do "query ReservationRepository for conflicting
        reservations at MakeReservation.reservationTime with
        sufficient table capacity for MakeReservation.partySize"
      tell event ReservationMade to entity
        FrontOfHouse.Reservation
      send event ReservationMade to outlet
        FrontOfHouse.ReservationEventSource.ReservationEvents
    }
    on event ReservationMade is {
      morph entity FrontOfHouse.Reservation to state
        FrontOfHouse.Reservation.Requested
          with event ReservationMade
    }
    on query GetReservation is {
      do "look up Reservation by GetReservation.reservationId"
      tell result ReservationResult to entity
        FrontOfHouse.Reservation
    }
  } with {
    briefly "Reservation creation handler"
    described as {
      |Handles the initial MakeReservation command when
      |the entity has no state yet. Validates party size,
      |reservation time, and table availability.
    }
  }
} with {
  briefly "Reservation entity"
  described as {
    | Manages the lifecycle of a restaurant reservation
    | from request through confirmation, seating, or
    | cancellation. State handlers ensure commands are
    | only valid in appropriate states, and events are
    | persisted before state transitions.
  }
}
