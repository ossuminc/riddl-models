// KitchenTicket entity for the Kitchen context
entity KitchenTicket is {
  // ---- Commands ----
  command ReceiveTicket is  {
    kitchenTicketId: KitchenTicketId with {
      briefly "ID"
      described as {
        |Identifier for the new ticket.
      }
    }
    sourceOrderId: String(1,50) with {
      briefly "Source order ID"
      described as {
        |Identifier of the originating order.
      }
    }
    ticketSource: TicketSource with {
      briefly "Source"
      described as {
        |Whether from dine-in or online.
      }
    }
    ticketItems: TicketItem+ with {
      briefly "Items"
      described as {
        |Food items to prepare.
      }
    }
    receivedAt: TimeStamp with {
      briefly "Received at"
      described as {
        |When the ticket was received.
      }
    }
  } with {
    briefly "Receive ticket"
    described as {
      |Receive a new kitchen ticket from an order.
    }
  }
  command AssignStation is  {
    kitchenTicketId: KitchenTicketId with {
      briefly "ID"
      described as {
        |Ticket to assign.
      }
    }
    assignedStation: StationName with {
      briefly "Station"
      described as {
        |Station to assign this ticket to.
      }
    }
  } with {
    briefly "Assign station"
    described as {
      |Assign the ticket to a kitchen station.
    }
  }
  command StartPreparation is  {
    kitchenTicketId: KitchenTicketId with {
      briefly "ID"
      described as {
        |Ticket to start preparing.
      }
    }
    startedAt: TimeStamp with {
      briefly "Started at"
      described as {
        |When preparation began.
      }
    }
  } with {
    briefly "Start preparation"
    described as {
      |Mark the ticket as being prepared.
    }
  }
  command MarkItemReady is  {
    kitchenTicketId: KitchenTicketId with {
      briefly "ID"
      described as {
        |Ticket containing the item.
      }
    }
    readyMenuItemId: String(1,50) with {
      briefly "Menu item ID"
      described as {
        |The item that is ready.
      }
    }
    markedReadyAt: TimeStamp with {
      briefly "Marked at"
      described as {
        |When the item was marked ready.
      }
    }
  } with {
    briefly "Mark item ready"
    described as {
      |Mark an individual item on the ticket as ready.
    }
  }
  command ApproveTicket is  {
    kitchenTicketId: KitchenTicketId with {
      briefly "ID"
      described as {
        |Ticket to approve.
      }
    }
    approvedAt: TimeStamp with {
      briefly "Approved at"
      described as {
        |When the ticket was approved.
      }
    }
  } with {
    briefly "Approve ticket"
    described as {
      |Chef approves the completed ticket for serving.
    }
  }
  command NotifyServer is  {
    kitchenTicketId: KitchenTicketId with {
      briefly "ID"
      described as {
        |Ticket that is ready.
      }
    }
    notifiedAt: TimeStamp with {
      briefly "Notified at"
      described as {
        |When the server was notified.
      }
    }
  } with {
    briefly "Notify server"
    described as {
      |Notify the server that the order is ready.
    }
  }
  // ---- Events ----
  event TicketReceived is  {
    kitchenTicketId: KitchenTicketId with {
      briefly "ID"
      described as {
        |Ticket identifier.
      }
    }
    sourceOrderId: String(1,50) with {
      briefly "Source order ID"
      described as {
        |Originating order.
      }
    }
    ticketSource: TicketSource with {
      briefly "Source"
      described as {
        |Dine-in or online.
      }
    }
    ticketItems: TicketItem+ with {
      briefly "Items"
      described as {
        |Items to prepare.
      }
    }
    receivedAt: TimeStamp with {
      briefly "Received at"
      described as {
        |When received.
      }
    }
  } with {
    briefly "Ticket received"
    described as {
      |Emitted when a new kitchen ticket arrives.
    }
  }
  event StationAssigned is  {
    kitchenTicketId: KitchenTicketId with {
      briefly "ID"
      described as {
        |Ticket identifier.
      }
    }
    assignedStation: StationName with {
      briefly "Station"
      described as {
        |Assigned station.
      }
    }
    assignedAt: TimeStamp with {
      briefly "Assigned at"
      described as {
        |When the station was assigned.
      }
    }
  } with {
    briefly "Station assigned"
    described as {
      |Emitted when a ticket is assigned to a station.
    }
  }
  event PreparationStarted is  {
    kitchenTicketId: KitchenTicketId with {
      briefly "ID"
      described as {
        |Ticket identifier.
      }
    }
    startedAt: TimeStamp with {
      briefly "Started at"
      described as {
        |When preparation began.
      }
    }
  } with {
    briefly "Preparation started"
    described as {
      |Emitted when preparation begins on a ticket.
    }
  }
  event ItemMarkedReady is  {
    kitchenTicketId: KitchenTicketId with {
      briefly "ID"
      described as {
        |Ticket identifier.
      }
    }
    readyMenuItemId: String(1,50) with {
      briefly "Menu item ID"
      described as {
        |The ready item.
      }
    }
    markedReadyAt: TimeStamp with {
      briefly "Marked at"
      described as {
        |When marked ready.
      }
    }
  } with {
    briefly "Item marked ready"
    described as {
      |Emitted when an item on a ticket is ready.
    }
  }
  event TicketApproved is  {
    kitchenTicketId: KitchenTicketId with {
      briefly "ID"
      described as {
        |Ticket identifier.
      }
    }
    approvedAt: TimeStamp with {
      briefly "Approved at"
      described as {
        |When approved.
      }
    }
  } with {
    briefly "Ticket approved"
    described as {
      |Emitted when the chef approves a completed ticket.
    }
  }
  event ServerNotified is  {
    kitchenTicketId: KitchenTicketId with {
      briefly "ID"
      described as {
        |Ticket identifier.
      }
    }
    notifiedAt: TimeStamp with {
      briefly "Notified at"
      described as {
        |When server was notified.
      }
    }
  } with {
    briefly "Server notified"
    described as {
      |Emitted when the server is notified food is ready.
    }
  }
  // ---- State ----
  record KitchenTicketData is {
    kitchenTicketId: KitchenTicketId with {
      briefly "ID"
      described as {
        |Ticket identifier.
      }
    }
    sourceOrderId: String(1,50) with {
      briefly "Source order ID"
      described as {
        |Originating order.
      }
    }
    ticketSource: TicketSource with {
      briefly "Source"
      described as {
        |Dine-in or online.
      }
    }
    ticketItems: TicketItem+ with {
      briefly "Items"
      described as {
        |Items on the ticket.
      }
    }
    currentStation: StationName? with {
      briefly "Station"
      described as {
        |Assigned station.
      }
    }
    receivedAt: TimeStamp with {
      briefly "Received at"
      described as {
        |When the ticket was received.
      }
    }
    actualPreparationStartedAt: TimeStamp? with {
      briefly "Started at"
      described as {
        |When preparation began.
      }
    }
    ticketApprovedAt: TimeStamp? with {
      briefly "Approved at"
      described as {
        |When the ticket was approved.
      }
    }
  } with {
    briefly "Kitchen ticket state data"
    described as {
      |Full state of a kitchen ticket. Shared across all
      |lifecycle states as a superset record.
    }
  }
  state Received of type KitchenTicket.KitchenTicketData is {
    handler ReceivedHandler is {
      on command AssignStation is {
        tell event StationAssigned to entity
          Kitchen.KitchenTicket
      }
      on event StationAssigned is {
        morph entity Kitchen.KitchenTicket to state
          Kitchen.KitchenTicket.Assigned
            with event StationAssigned
        set field KitchenTicket.Assigned.currentStation to
          "assignedStation from event"
      }
      on command ReceiveTicket is {
        error "Ticket has already been received"
      }
      on command StartPreparation is {
        error "Cannot start preparation before station assignment"
      }
      on command MarkItemReady is {
        error "Cannot mark item ready before preparation begins"
      }
      on command ApproveTicket is {
        error "Cannot approve ticket before preparation"
      }
      on command NotifyServer is {
        error "Cannot notify server before ticket is approved"
      }
    } with {
      briefly "Received state handler"
      described as {
        |Handles commands valid in the Received state.
        |Only AssignStation advances the lifecycle.
      }
    }
  } with {
    briefly "Ticket received"
    described as {
      |Initial state when a ticket arrives from an order.
      |Awaiting station assignment.
    }
  }
  state Assigned of type KitchenTicket.KitchenTicketData is {
    handler AssignedHandler is {
      on command StartPreparation is {
        tell event PreparationStarted to entity
          Kitchen.KitchenTicket
      }
      on event PreparationStarted is {
        morph entity Kitchen.KitchenTicket to state
          Kitchen.KitchenTicket.InPreparation
            with event PreparationStarted
        set field
          KitchenTicket.InPreparation.actualPreparationStartedAt
          to "startedAt from event"
      }
      on command ReceiveTicket is {
        error "Ticket has already been received"
      }
      on command AssignStation is {
        error "Ticket has already been assigned to a station"
      }
      on command MarkItemReady is {
        error "Cannot mark item ready before preparation begins"
      }
      on command ApproveTicket is {
        error "Cannot approve ticket before preparation"
      }
      on command NotifyServer is {
        error "Cannot notify server before ticket is approved"
      }
    } with {
      briefly "Assigned state handler"
      described as {
        |Handles commands valid in the Assigned state.
        |Only StartPreparation advances the lifecycle.
      }
    }
  } with {
    briefly "Station assigned"
    described as {
      |Ticket has been assigned to a kitchen station.
      |Awaiting start of preparation.
    }
  }
  state InPreparation of type KitchenTicket.KitchenTicketData is {
    handler InPreparationHandler is {
      on command MarkItemReady is {
        tell event ItemMarkedReady to entity
          Kitchen.KitchenTicket
      }
      on event ItemMarkedReady is {
        do "set KitchenTicketData.ticketItems[
          ItemMarkedReady.readyMenuItemId].ticketItemReady
          = true"
        when "all KitchenTicketData.ticketItems have
          ticketItemReady = true" then
          morph entity Kitchen.KitchenTicket to state
            Kitchen.KitchenTicket.ItemsReady
              with event ItemMarkedReady
        end
      }
      on command ReceiveTicket is {
        error "Ticket has already been received"
      }
      on command AssignStation is {
        error "Ticket has already been assigned to a station"
      }
      on command StartPreparation is {
        error "Preparation has already started"
      }
      on command ApproveTicket is {
        error "Cannot approve ticket before all items are ready"
      }
      on command NotifyServer is {
        error "Cannot notify server before ticket is approved"
      }
    } with {
      briefly "InPreparation state handler"
      described as {
        |Handles commands valid in the InPreparation state.
        |MarkItemReady updates individual items and conditionally
        |transitions to ItemsReady when all items are complete.
      }
    }
  } with {
    briefly "In preparation"
    described as {
      |Station is actively preparing the items on this
      |ticket. Individual items are marked ready as they
      |are completed.
    }
  }
  state ItemsReady of type KitchenTicket.KitchenTicketData is {
    handler ItemsReadyHandler is {
      on command ApproveTicket is {
        tell event TicketApproved to entity
          Kitchen.KitchenTicket
      }
      on event TicketApproved is {
        morph entity Kitchen.KitchenTicket to state
          Kitchen.KitchenTicket.Approved
            with event TicketApproved
        set field KitchenTicket.Approved.ticketApprovedAt to
          "approvedAt from event"
        tell command NotifyServer to entity
          Kitchen.KitchenTicket
      }
      on command ReceiveTicket is {
        error "Ticket has already been received"
      }
      on command AssignStation is {
        error "Ticket has already been assigned to a station"
      }
      on command StartPreparation is {
        error "Preparation has already completed"
      }
      on command MarkItemReady is {
        error "All items are already ready"
      }
      on command NotifyServer is {
        error "Cannot notify server before ticket is approved"
      }
    } with {
      briefly "ItemsReady state handler"
      described as {
        |Handles commands valid in the ItemsReady state.
        |ApproveTicket advances the lifecycle and auto-triggers
        |server notification.
      }
    }
  } with {
    briefly "All items ready"
    described as {
      |All items on the ticket have been prepared.
      |Awaiting chef quality approval.
    }
  }
  state Approved of type KitchenTicket.KitchenTicketData is {
    handler ApprovedHandler is {
      on command NotifyServer is {
        tell event ServerNotified to entity
          Kitchen.KitchenTicket
      }
      on event ServerNotified is {
        morph entity Kitchen.KitchenTicket to state
          Kitchen.KitchenTicket.ServerNotifiedState
            with event ServerNotified
        do "ServerNotified event triggers push notification to
          server via NotificationService streaming topology"
      }
      on command ReceiveTicket is {
        error "Ticket has already been received"
      }
      on command AssignStation is {
        error "Ticket has already been assigned to a station"
      }
      on command StartPreparation is {
        error "Preparation has already completed"
      }
      on command MarkItemReady is {
        error "All items are already ready"
      }
      on command ApproveTicket is {
        error "Ticket has already been approved"
      }
    } with {
      briefly "Approved state handler"
      described as {
        |Handles commands valid in the Approved state.
        |NotifyServer advances to the terminal state.
      }
    }
  } with {
    briefly "Chef approved"
    described as {
      |Chef has approved the completed ticket for serving.
      |Server notification is being sent.
    }
  }
  state ServerNotifiedState of type KitchenTicket.KitchenTicketData
    is {
    handler ServerNotifiedHandler is {
      on command ReceiveTicket is {
        error "Ticket lifecycle is complete"
      }
      on command AssignStation is {
        error "Ticket lifecycle is complete"
      }
      on command StartPreparation is {
        error "Ticket lifecycle is complete"
      }
      on command MarkItemReady is {
        error "Ticket lifecycle is complete"
      }
      on command ApproveTicket is {
        error "Ticket lifecycle is complete"
      }
      on command NotifyServer is {
        error "Server has already been notified"
      }
    } with {
      briefly "ServerNotified state handler"
      described as {
        |Terminal state. All commands are rejected.
      }
    }
  } with {
    briefly "Server notified"
    described as {
      |Server has been notified that the order is ready
      |for pickup. Terminal state.
    }
  }
  handler KitchenTicketCreationHandler is {
    on command ReceiveTicket is {
      tell event TicketReceived to entity Kitchen.KitchenTicket
    }
    on event TicketReceived is {
      morph entity Kitchen.KitchenTicket to state
        Kitchen.KitchenTicket.Received
          with event TicketReceived
    }
  } with {
    briefly "Kitchen ticket creation handler"
    described as {
      |Handles the initial ReceiveTicket command when
      |the entity has no state yet.
    }
  }
} with {
  briefly "Kitchen ticket entity"
  described as {
    | Manages the lifecycle of a kitchen ticket from
    | receipt through station assignment, preparation,
    | quality approval, and server notification. State
    | handlers ensure commands are only valid in appropriate
    | states, and events are persisted before state
    | transitions for crash recovery safety.
  }
}
