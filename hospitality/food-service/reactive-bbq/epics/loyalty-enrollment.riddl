// OnlineCustomer is shared and defined in users.riddl
epic LoyaltyEnrollment is {
  user OnlineCustomer wants "to earn points on purchases"
    so that "I get rewarded for being a loyal customer"
  case Enrollment is {
    user OnlineCustomer wants "to join the loyalty program"
      so that "I start earning points on purchases"
    step from user OnlineCustomer
      "provides name and email to enroll in loyalty program"
      to context Restaurant.Loyalty
    step from context Restaurant.Loyalty
      "creates loyalty account with zero balance and sends
      welcome notification" to user OnlineCustomer
  } with {
    briefly "Loyalty enrollment"
    described as {
      |Customer signs up for loyalty and receives a welcome
      |notification.
    }
  }
  case PointAccrual is {
    user OnlineCustomer wants "to earn points on a purchase"
      so that "rewards accumulate over time"
    step from user OnlineCustomer
      "completes a purchase through dine-in or online" to
      context Restaurant.FrontOfHouse
    step from context Restaurant.FrontOfHouse
      "sends payment event to loyalty context" to context
      Restaurant.Loyalty
    step from context Restaurant.Loyalty
      "calculates points at 1 point per dollar and adds to
      account balance" to user OnlineCustomer
  } with {
    briefly "Point accrual"
    described as {
      |Automatic point accrual from both dine-in and online
      |purchases.
    }
  }
  case PointRedemption is {
    user OnlineCustomer wants "to redeem loyalty points" so
      that "I get a discount on my order"
    step from user OnlineCustomer
      "requests point redemption with desired amount" to
      context Restaurant.Loyalty
    step from context Restaurant.Loyalty
      "validates sufficient balance and deducts points" to
      user OnlineCustomer
    step from context Restaurant.Loyalty
      "applies discount to current order" to context
      Restaurant.FrontOfHouse
  } with {
    briefly "Point redemption"
    described as {
      |Customer redeems accumulated points for a discount.
    }
  }
} with {
  briefly "Loyalty program enrollment"
  described as {
    | Loyalty program enrollment, automatic point accrual
    | on dine-in and online purchases, and point redemption
    | for discounts.
  }
}
