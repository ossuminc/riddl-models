// Menu Management bounded context
context MenuManagement is {
  include "menu-types.riddl"
  include "MenuItem.riddl"
  include "MenuRelease.riddl"
  repository MenuItemRepository is {
    schema MenuItemData is relational
      of menuItems as type MenuItem
        index on field MenuItem.menuItemId
        index on field MenuItem.menuItemCategory
        index on field MenuItem.menuItemLifecycle
      with {
      briefly "Menu item data schema"
      described as {
        |Relational schema for persisting menu item state
        |with indexes on item, category, and lifecycle.
      }
    }
    handler MenuItemPersistence is {
      on command MenuItem.CreateMenuItem is {
        tell event MenuItem.MenuItemCreated to entity
          MenuManagement.MenuItem
        do "insert row into MenuItemData.menuItems with
          menuItemId, menuItemName, menuItemCategory,
          menuItemDescription, recipe, pricing, and
          menuItemLifecycle = Draft"
      }
      on command MenuItem.UpdateMenuItem is {
        tell event MenuItem.MenuItemUpdated to entity
          MenuManagement.MenuItem
        do "update MenuItemData.menuItems set updatedName,
          updatedDescription, updatedRecipe where menuItemId
          matches"
      }
      on command MenuItem.SetPrice is {
        tell event MenuItem.PriceSet to entity
          MenuManagement.MenuItem
        do "update MenuItemData.menuItems set pricing =
          updatedPricing where menuItemId matches"
      }
      on command MenuItem.RetireMenuItem is {
        tell event MenuItem.MenuItemRetired to entity
          MenuManagement.MenuItem
        do "update MenuItemData.menuItems set menuItemLifecycle
          = Retired where menuItemId matches"
      }
    } with {
      briefly "Menu item persistence"
      described as {
        |Persists menu item commands.
      }
    }
  } with {
    briefly "Menu item repository"
    described as {
      |Stores and retrieves menu item data.
    }
  }
  repository MenuReleaseRepository is {
    schema MenuReleaseData is relational
      of releases as type MenuRelease
        index on field MenuRelease.menuReleaseId
        index on field MenuRelease.menuReleaseStatus
      with {
      briefly "Menu release data schema"
      described as {
        |Relational schema for persisting menu release state
        |with indexes on release identifier and status.
      }
    }
    handler MenuReleasePersistence is {
      on command MenuRelease.CreateMenuRelease is {
        tell event MenuRelease.MenuReleaseCreated to entity
          MenuManagement.MenuRelease
        do "insert row into MenuReleaseData.releases with
          menuReleaseId, releaseName, releaseDescription,
          effectiveDate, and menuReleaseStatus = Draft"
      }
      on command MenuRelease.AddItemToRelease is {
        tell event MenuRelease.ItemAddedToRelease to entity
          MenuManagement.MenuRelease
        do "append releaseMenuItemId to releaseItems in
          MenuReleaseData.releases where menuReleaseId matches"
      }
      on command MenuRelease.FinalizeRelease is {
        tell event MenuRelease.ReleaseFinalized to entity
          MenuManagement.MenuRelease
        do "update MenuReleaseData.releases set
          menuReleaseStatus = Finalized where menuReleaseId
          matches"
      }
      on command MenuRelease.PublishRelease is {
        tell event MenuRelease.ReleasePublished to entity
          MenuManagement.MenuRelease
        do "update MenuReleaseData.releases set
          menuReleaseStatus = Published, actualPublishedAt =
          publishedAt where menuReleaseId matches"
      }
      on command MenuRelease.RollbackRelease is {
        tell event MenuRelease.ReleaseRolledBack to entity
          MenuManagement.MenuRelease
        do "update MenuReleaseData.releases set
          menuReleaseStatus = RolledBack where menuReleaseId
          matches"
      }
    } with {
      briefly "Menu release persistence"
      described as {
        |Persists menu release commands.
      }
    }
  } with {
    briefly "Menu release repository"
    described as {
      |Stores and retrieves menu release data.
    }
  }
  sink PrintConfirmSink is {
    inlet IncomingPrintResults is type PrintingEvent
    handler PrintConfirmHandler is {
      on event PrintingService.MenusPrinted is {
        do "log print job completion for
          MenusPrinted.printJobId completed at
          MenusPrinted.printedAt"
      }
    } with {
      briefly "Print confirmation handler"
      described as {
        |Processes print job completion confirmations.
      }
    }
  } with {
    briefly "Print confirmation sink"
    described as {
      |Receives print completion events from the external
      |printing service.
    }
  }
  sink PhotoConfirmSink is {
    inlet IncomingShootResults is type PhotographyEvent
    handler PhotoConfirmHandler is {
      on event PhotographyService.PhotoShootCompleted is {
        do "update menu item images from completed photo
          shoot PhotoShootCompleted.shootId completed at
          PhotoShootCompleted.completedAt"
      }
    } with {
      briefly "Photo confirmation handler"
      described as {
        |Processes photo shoot completions and updates
        |menu item images.
      }
    }
  } with {
    briefly "Photo confirmation sink"
    described as {
      |Receives photo shoot completion events from the
      |external photography service.
    }
  }
  connector PrintingToMenu is {
    from outlet PrintingService.PrintingEventSource.PrintResults
      to inlet MenuManagement.PrintConfirmSink.IncomingPrintResults
  } with {
    option is persistent
    briefly "Printing to menu connector"
    described as {
      |Wires printing completion events to menu management.
    }
  }
  connector PhotographyToMenu is {
    from outlet
      PhotographyService.PhotographyEventSource.ShootResults to
      inlet MenuManagement.PhotoConfirmSink.IncomingShootResults
  } with {
    option is persistent
    briefly "Photography to menu connector"
    described as {
      |Wires photo shoot completions to menu management.
    }
  }
  adaptor ToRestaurants to context Restaurant.FrontOfHouse is {
    handler MenuDistribution is {
      on command Restaurant.FrontOfHouse.TableOrder.CreateOrder is {
        do "distribute published menu updates to restaurant
          locations"
      }
    } with {
      briefly "Menu distribution"
      described as {
        |Distributes menu updates to restaurants.
      }
    }
  } with {
    briefly "Restaurant menu adaptor"
    described as {
      | Distributes published menu releases atomically
      | to all restaurant locations.
    }
  }
} with {
  briefly "Menu management context"
  described as {
    | Manages the corporate menu lifecycle including recipe
    | development, pricing, and atomic menu distribution
    | to all 500+ locations via the MenuRelease entity.
    | Addresses the Head Chef's monthly coordination
    | bottleneck by enabling versioned, atomic menu updates.
  }
}
