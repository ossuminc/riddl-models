// Reporting bounded context - CQRS projectors only
context Reporting is {
  type SalesReportRecord is {
    reportDate: Date with {
      briefly "Date"
      described as {
        |Report date.
      }
    }
    totalRevenue: Decimal(12,2) with {
      briefly "Revenue"
      described as {
        |Total revenue.
      }
    }
  } with {
    briefly "Sales report record type"
    described as {
      |Aggregate type for sales report persistence.
    }
  }
  type LaborReportRecord is {
    laborReportDate: Date with {
      briefly "Date"
      described as {
        |Report date.
      }
    }
    totalHoursWorked: Decimal(8,2) with {
      briefly "Hours"
      described as {
        |Total hours worked.
      }
    }
  } with {
    briefly "Labor report record type"
    described as {
      |Aggregate type for labor report persistence.
    }
  }
  type InventoryReportRecord is {
    inventoryReportDate: Date with {
      briefly "Date"
      described as {
        |Report date.
      }
    }
    totalStockValue: Decimal(14,2) with {
      briefly "Stock value"
      described as {
        |Total stock value.
      }
    }
  } with {
    briefly "Inventory report record type"
    described as {
      |Aggregate type for inventory report persistence.
    }
  }
  command RecordDineInPayment is {
    paymentAmount: Decimal(10,2) with {
      briefly "Amount"
      described as {
        |Payment amount from dine-in order.
      }
    }
    tableOrderId: String(1,50) with {
      briefly "Order ID"
      described as {
        |Originating table order.
      }
    }
  } with {
    briefly "Record dine-in payment"
    described as {
      |Record a dine-in payment for sales reporting.
    }
  }
  command RecordOnlinePayment is {
    paymentAmount: Decimal(10,2) with {
      briefly "Amount"
      described as {
        |Payment amount from online order.
      }
    }
    onlineOrderId: String(1,50) with {
      briefly "Order ID"
      described as {
        |Originating online order.
      }
    }
  } with {
    briefly "Record online payment"
    described as {
      |Record an online payment for sales reporting.
    }
  }
  command RecordClockIn is {
    shiftId: String(1,50) with {
      briefly "Shift ID"
      described as {
        |Shift being clocked into.
      }
    }
    clockedInAt: TimeStamp with {
      briefly "Time"
      described as {
        |Clock-in time.
      }
    }
  } with {
    briefly "Record clock-in"
    described as {
      |Record an employee clock-in for labor reporting.
    }
  }
  command RecordClockOut is {
    shiftId: String(1,50) with {
      briefly "Shift ID"
      described as {
        |Shift being clocked out of.
      }
    }
    clockedOutAt: TimeStamp with {
      briefly "Time"
      described as {
        |Clock-out time.
      }
    }
  } with {
    briefly "Record clock-out"
    described as {
      |Record an employee clock-out for labor reporting.
    }
  }
  command RecordShiftCancellation is {
    shiftId: String(1,50) with {
      briefly "Shift ID"
      described as {
        |Cancelled shift.
      }
    }
  } with {
    briefly "Record shift cancellation"
    described as {
      |Record a shift cancellation for labor reporting.
    }
  }
  command RecordStockReceived is {
    inventoryItemId: String(1,50) with {
      briefly "ID"
      described as {
        |Item.
      }
    }
    quantity: Decimal(10,2) with {
      briefly "Qty"
      described as {
        |Quantity received.
      }
    }
  } with {
    briefly "Record stock received"
    described as {
      |Record stock receipt for inventory reporting.
    }
  }
  command RecordStockConsumed is {
    inventoryItemId: String(1,50) with {
      briefly "ID"
      described as {
        |Item.
      }
    }
    quantity: Decimal(10,2) with {
      briefly "Qty"
      described as {
        |Quantity consumed.
      }
    }
  } with {
    briefly "Record stock consumed"
    described as {
      |Record stock consumption for inventory reporting.
    }
  }
  command RecordStockAdjusted is {
    inventoryItemId: String(1,50) with {
      briefly "ID"
      described as {
        |Item.
      }
    }
    quantity: Decimal(10,2) with {
      briefly "Qty"
      described as {
        |Quantity adjusted.
      }
    }
  } with {
    briefly "Record stock adjusted"
    described as {
      |Record stock adjustment for inventory reporting.
    }
  }
  command RecordAccountingPosting is {
    transactionId: String(1,50) with {
      briefly "Transaction ID"
      described as {
        |Accounting transaction.
      }
    }
  } with {
    briefly "Record accounting posting"
    described as {
      |Record an accounting posting confirmation.
    }
  }
  command RecordReservationEvent is {
    reservationId: String(1,50) with {
      briefly "Reservation ID"
      described as {
        |Reservation identifier.
      }
    }
    eventType: String(1,30) with {
      briefly "Event type"
      described as {
        |Type of reservation event: made or cancelled.
      }
    }
  } with {
    briefly "Record reservation event"
    described as {
      |Record a reservation event for reporting.
    }
  }
  command RecordTableOrderEvent is {
    tableOrderId: String(1,50) with {
      briefly "Order ID"
      described as {
        |Table order identifier.
      }
    }
    eventType: String(1,30) with {
      briefly "Event type"
      described as {
        |Type of order event: payment or closed.
      }
    }
    paymentAmount: Decimal(10,2)? with {
      briefly "Amount"
      described as {
        |Payment amount if applicable.
      }
    }
  } with {
    briefly "Record table order event"
    described as {
      |Record a table order event for reporting.
    }
  }
  command RecordShiftEvent is {
    shiftId: String(1,50) with {
      briefly "Shift ID"
      described as {
        |Shift identifier.
      }
    }
    eventType: String(1,30) with {
      briefly "Event type"
      described as {
        |Type: clock-in, clock-out, or cancelled.
      }
    }
    eventTime: TimeStamp? with {
      briefly "Time"
      described as {
        |Event timestamp.
      }
    }
  } with {
    briefly "Record shift event"
    described as {
      |Record a shift event for reporting.
    }
  }
  command RecordInventoryEvent is {
    inventoryItemId: String(1,50) with {
      briefly "Item ID"
      described as {
        |Inventory item.
      }
    }
    eventType: String(1,30) with {
      briefly "Event type"
      described as {
        |Type: received, consumed, or adjusted.
      }
    }
    quantity: Decimal(10,2)? with {
      briefly "Quantity"
      described as {
        |Quantity affected.
      }
    }
  } with {
    briefly "Record inventory event"
    described as {
      |Record an inventory event for reporting.
    }
  }
  repository SalesReportRepository is {
    schema SalesReportData is relational
      of salesReports as type SalesReportRecord
        index on field SalesReportRecord.reportDate
      with {
      briefly "Sales report schema"
      described as {
        |Relational schema for persisting sales reports.
      }
    }
    handler SalesReportPersistence is {
      on command RecordDineInPayment is {
        set field SalesReportRecord.totalRevenue to
          "totalRevenue + payment amount"
        do "upsert sales report record"
      }
      on command RecordOnlinePayment is {
        set field SalesReportRecord.totalRevenue to
          "totalRevenue + online payment amount"
        do "upsert online sales report record"
      }
      on command RecordAccountingPosting is {
        do "log accounting confirmation for reconciliation"
      }
      on command RecordReservationEvent is {
        do "record reservation event for sales reporting"
      }
      on command RecordTableOrderEvent is {
        do "record table order event for sales reporting"
      }
    } with {
      briefly "Sales report persistence"
      described as {
        |Persists sales report projections.
      }
    }
  } with {
    briefly "Sales report repository"
    described as {
      |Stores sales report data.
    }
  }
  repository LaborReportRepository is {
    schema LaborReportData is relational
      of laborReports as type LaborReportRecord
        index on field LaborReportRecord.laborReportDate
      with {
      briefly "Labor report schema"
      described as {
        |Relational schema for persisting labor reports.
      }
    }
    handler LaborReportPersistence is {
      on command RecordClockIn is {
        set field LaborReportRecord.totalHoursWorked to
          "updated hours from clock-in"
        do "upsert labor report record for clock-in"
      }
      on command RecordClockOut is {
        set field LaborReportRecord.totalHoursWorked to
          "updated hours from clock-out"
        do "upsert labor report record for clock-out"
      }
      on command RecordShiftCancellation is {
        set field LaborReportRecord.totalHoursWorked to
          "adjusted hours from cancellation"
        do "upsert labor report record for cancellation"
      }
      on command RecordShiftEvent is {
        do "record shift event for labor reporting"
      }
    } with {
      briefly "Labor report persistence"
      described as {
        |Persists labor report projections.
      }
    }
  } with {
    briefly "Labor report repository"
    described as {
      |Stores labor report data.
    }
  }
  repository InventoryReportRepository is {
    schema InventoryReportData is relational
      of inventoryReports as type InventoryReportRecord
        index on field InventoryReportRecord.inventoryReportDate
      with {
      briefly "Inventory report schema"
      described as {
        |Relational schema for persisting inventory reports.
      }
    }
    handler InventoryReportPersistence is {
      on command RecordStockReceived is {
        set field InventoryReportRecord.totalStockValue to
          "recalculated from stock received"
        do "upsert inventory report record for stock received"
      }
      on command RecordStockConsumed is {
        set field InventoryReportRecord.totalStockValue to
          "recalculated from stock consumed"
        do "upsert inventory report record for stock consumed"
      }
      on command RecordStockAdjusted is {
        set field InventoryReportRecord.totalStockValue to
          "recalculated from stock adjusted"
        do "upsert inventory report record for stock adjusted"
      }
      on command RecordInventoryEvent is {
        do "record inventory event for reporting"
      }
    } with {
      briefly "Inventory report persistence"
      described as {
        |Persists inventory report projections.
      }
    }
  } with {
    briefly "Inventory report repository"
    described as {
      |Stores inventory report data.
    }
  }
  projector SalesReport is {
    updates repository Reporting.SalesReportRepository
    record SalesReportEntry is  {
      reportDate: Date with {
        briefly "Date"
        described as {
          |Report date.
        }
      }
      totalRevenue: Decimal(12,2) with {
        briefly "Revenue"
        described as {
          |Total revenue for the period.
        }
      }
      dineInRevenue: Decimal(12,2) with {
        briefly "Dine-in revenue"
        described as {
          |Revenue from dine-in orders.
        }
      }
      onlineRevenue: Decimal(12,2) with {
        briefly "Online revenue"
        described as {
          |Revenue from online orders.
        }
      }
      orderCount: Natural with {
        briefly "Orders"
        described as {
          |Total number of orders.
        }
      }
      averageOrderValue: Decimal(10,2) with {
        briefly "Average order"
        described as {
          |Average order value.
        }
      }
    } with {
      briefly "Sales report entry"
      described as {
        |A single sales report data point.
      }
    }
    handler SalesReportHandler is {
      on event Restaurant.FrontOfHouse.TableOrder.PaymentProcessed is {
        let entry: SalesReportEntry = "new SalesReportEntry from event"
        tell command RecordDineInPayment
          to repository Reporting.SalesReportRepository
        do "upsert SalesReportEntry for current reportDate:
          increment orderCount, add PaymentProcessed
          .orderPayment amount to totalRevenue and
          dineInRevenue, recalculate averageOrderValue"
        set field SalesReportEntry.totalRevenue to "totalRevenue + payment amount"
      }
      on event Restaurant.OnlineOrdering.OnlineOrder.OnlinePaymentProcessed is {
        tell command RecordOnlinePayment
          to repository Reporting.SalesReportRepository
        do "upsert SalesReportEntry for current reportDate:
          increment orderCount, add OnlinePaymentProcessed
          .onlinePayment amount to totalRevenue and
          onlineRevenue, recalculate averageOrderValue"
        set field SalesReportEntry.onlineRevenue to "onlineRevenue + payment amount"
      }
    } with {
      briefly "Sales report handler"
      described as {
        |Projects payment events into sales reports.
      }
    }
  } with {
    briefly "Sales report projector"
    described as {
      | Builds sales reports from payment events across
      | dine-in and online channels. Isolated from production
      | so report generation never impacts peak-hour performance.
    }
  }
  projector LaborReport is {
    updates repository Reporting.LaborReportRepository
    record LaborReportEntry is  {
      laborReportDate: Date with {
        briefly "Date"
        described as {
          |Report date.
        }
      }
      totalHoursWorked: Decimal(8,2) with {
        briefly "Hours"
        described as {
          |Total hours worked.
        }
      }
      shiftsCompleted: Natural with {
        briefly "Shifts"
        described as {
          |Number of completed shifts.
        }
      }
      shiftsCancelled: Natural with {
        briefly "Cancelled"
        described as {
          |Number of cancelled shifts.
        }
      }
      averageShiftDuration: Decimal(6,2) with {
        briefly "Average duration"
        described as {
          |Average shift duration in hours.
        }
      }
    } with {
      briefly "Labor report entry"
      described as {
        |A single labor report data point.
      }
    }
    handler LaborReportHandler is {
      on event BackOffice.Scheduling.Shift.ClockedIn is {
        let entry: LaborReportEntry = "new LaborReportEntry from event"
        tell command RecordClockIn to
          repository Reporting.LaborReportRepository
        do "upsert LaborReportEntry for current
          laborReportDate: record shift start from
          ClockedIn.clockedInAt"
        set field LaborReportEntry.totalHoursWorked to "updated hours"
      }
      on event BackOffice.Scheduling.Shift.ClockedOut is {
        tell command RecordClockOut to
          repository Reporting.LaborReportRepository
        do "upsert LaborReportEntry for current
          laborReportDate: increment shiftsCompleted, add
          hours between ClockedIn and ClockedOut
          .clockedOutAt to totalHoursWorked, recalculate
          averageShiftDuration"
        set field LaborReportEntry.shiftsCompleted to "shiftsCompleted + 1"
      }
      on event BackOffice.Scheduling.Shift.ShiftCancelled is {
        tell command RecordShiftCancellation to
          repository Reporting.LaborReportRepository
        do "upsert LaborReportEntry for current
          laborReportDate: increment shiftsCancelled"
        set field LaborReportEntry.shiftsCancelled to "shiftsCancelled + 1"
      }
    } with {
      briefly "Labor report handler"
      described as {
        |Projects scheduling events into labor reports.
      }
    }
  } with {
    briefly "Labor report projector"
    described as {
      |Builds labor reports from scheduling clock events.
    }
  }
  projector InventoryReport is {
    updates repository Reporting.InventoryReportRepository
    record InventoryReportEntry is  {
      inventoryReportDate: Date with {
        briefly "Date"
        described as {
          |Report date.
        }
      }
      totalItemsTracked: Natural with {
        briefly "Items tracked"
        described as {
          |Total inventory items being tracked.
        }
      }
      lowStockItems: Natural with {
        briefly "Low stock"
        described as {
          |Number of items below reorder threshold.
        }
      }
      outOfStockItems: Natural with {
        briefly "Out of stock"
        described as {
          |Number of out-of-stock items.
        }
      }
      totalStockValue: Decimal(14,2) with {
        briefly "Stock value"
        described as {
          |Estimated total stock value.
        }
      }
    } with {
      briefly "Inventory report entry"
      described as {
        |A single inventory report data point.
      }
    }
    handler InventoryReportHandler is {
      on event BackOffice.Inventory.InventoryItem.StockReceived is {
        let entry: InventoryReportEntry = "new InventoryReportEntry from event"
        tell command RecordStockReceived
          to repository Reporting.InventoryReportRepository
        do "upsert InventoryReportEntry for current
          inventoryReportDate: update totalItemsTracked,
          recalculate totalStockValue from
          StockReceived.newStockLevel, update lowStockItems
          and outOfStockItems counts"
        set field InventoryReportEntry.totalStockValue to "recalculated from newStockLevel"
      }
      on event BackOffice.Inventory.InventoryItem.StockConsumed is {
        tell command RecordStockConsumed
          to repository Reporting.InventoryReportRepository
        do "upsert InventoryReportEntry for current
          inventoryReportDate: recalculate totalStockValue
          from StockConsumed.remainingStockLevel, update
          lowStockItems and outOfStockItems counts"
        set field InventoryReportEntry.totalStockValue to "recalculated from remainingStockLevel"
      }
      on event BackOffice.Inventory.InventoryItem.StockAdjusted is {
        tell command RecordStockAdjusted
          to repository Reporting.InventoryReportRepository
        do "upsert InventoryReportEntry for current
          inventoryReportDate: recalculate totalStockValue
          from StockAdjusted.adjustedStockLevel, update
          lowStockItems and outOfStockItems counts"
        set field InventoryReportEntry.totalStockValue to "recalculated from adjustedStockLevel"
      }
    } with {
      briefly "Inventory report handler"
      described as {
        |Projects inventory events into reports.
      }
    }
  } with {
    briefly "Inventory report projector"
    described as {
      |Builds inventory reports from stock events.
    }
  }
  sink AccountingConfirmSink is {
    inlet IncomingPostingResults is type AccountingEvent
    handler AccountingConfirmHandler is {
      on event AccountingSystem.TransactionPosted is {
        tell command RecordAccountingPosting to
          repository Reporting.SalesReportRepository
        do "log accounting confirmation for
          TransactionPosted.accountingTransactionId posted
          at TransactionPosted.postedAt for reconciliation"
      }
    } with {
      briefly "Accounting confirmation handler"
      described as {
        |Processes transaction posting confirmations from
        |the accounting system for reconciliation.
      }
    }
  } with {
    briefly "Accounting confirmation sink"
    described as {
      |Receives transaction posting confirmations from the
      |external accounting system.
    }
  }
  sink ReservationEventSink is {
    inlet IncomingReservationEvents is type ReservationEvent
    handler ReservationEventIntake is {
      on event Restaurant.FrontOfHouse.Reservation.ReservationMade is {
        tell command RecordReservationEvent
          to repository Reporting.SalesReportRepository
        do "record reservation creation for sales reporting"
      }
      on event Restaurant.FrontOfHouse.Reservation.ReservationCancelled is {
        tell command RecordReservationEvent
          to repository Reporting.SalesReportRepository
        do "record reservation cancellation for sales reporting"
      }
    } with {
      briefly "Reservation event intake"
      described as {
        |Processes incoming reservation events for sales
        |reporting.
      }
    }
  } with {
    briefly "Reservation event sink"
    described as {
      |Receives reservation events from the streaming
      |topology for sales and reservation reports.
    }
  }
  sink TableOrderEventSink is {
    inlet IncomingTableOrderEvents is type OrderEvent
    handler TableOrderEventIntake is {
      on event Restaurant.FrontOfHouse.TableOrder.PaymentProcessed is {
        tell command RecordTableOrderEvent
          to repository Reporting.SalesReportRepository
        do "record payment for sales reporting"
      }
      on event Restaurant.FrontOfHouse.TableOrder.OrderClosed is {
        tell command RecordTableOrderEvent
          to repository Reporting.SalesReportRepository
        do "record order closure for sales reporting"
      }
    } with {
      briefly "Table order event intake"
      described as {
        |Processes incoming table order events for sales
        |reporting.
      }
    }
  } with {
    briefly "Table order event sink"
    described as {
      |Receives table order events from the streaming
      |topology for sales reports.
    }
  }
  sink ShiftEventSink is {
    inlet IncomingShiftEvents is type ShiftEvent
    handler ShiftEventIntake is {
      on event BackOffice.Scheduling.Shift.ClockedIn is {
        tell command RecordShiftEvent
          to repository Reporting.LaborReportRepository
        do "record clock-in for labor reporting"
      }
      on event BackOffice.Scheduling.Shift.ClockedOut is {
        tell command RecordShiftEvent
          to repository Reporting.LaborReportRepository
        do "record clock-out for labor reporting"
      }
      on event BackOffice.Scheduling.Shift.ShiftCancelled is {
        tell command RecordShiftEvent
          to repository Reporting.LaborReportRepository
        do "record cancellation for labor reporting"
      }
    } with {
      briefly "Shift event intake"
      described as {
        |Processes incoming shift events for labor reporting.
      }
    }
  } with {
    briefly "Shift event sink"
    described as {
      |Receives shift events from the streaming topology
      |for labor reports.
    }
  }
  sink InventoryEventSink is {
    inlet IncomingInventoryEvents is type InventoryEvent
    handler InventoryEventIntake is {
      on event BackOffice.Inventory.InventoryItem.StockReceived is {
        tell command RecordInventoryEvent
          to repository Reporting.InventoryReportRepository
        do "record stock received for inventory reporting"
      }
      on event BackOffice.Inventory.InventoryItem.StockConsumed is {
        tell command RecordInventoryEvent
          to repository Reporting.InventoryReportRepository
        do "record stock consumed for inventory reporting"
      }
      on event BackOffice.Inventory.InventoryItem.StockAdjusted is {
        tell command RecordInventoryEvent
          to repository Reporting.InventoryReportRepository
        do "record stock adjusted for inventory reporting"
      }
    } with {
      briefly "Inventory event intake"
      described as {
        |Processes incoming inventory events for inventory
        |reporting.
      }
    }
  } with {
    briefly "Inventory event sink"
    described as {
      |Receives inventory events from the streaming topology
      |for inventory reports.
    }
  }
  connector AccountingToReporting is {
    from outlet
      AccountingSystem.AccountingEventSource.PostingResults to
      inlet Reporting.AccountingConfirmSink.IncomingPostingResults
  } with {
    option is persistent
    briefly "Accounting to reporting connector"
    described as {
      |Wires accounting posting confirmations to reporting.
    }
  }
} with {
  briefly "Reporting context"
  described as {
    | CQRS read-model context containing projectors for
    | sales, labor, and inventory reports. Completely
    | isolated from production contexts so that report
    | generation never degrades peak-hour restaurant
    | performance. Addresses the CEO's concern about
    | reports slowing down operations.
  }
}
