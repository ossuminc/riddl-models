// Inventory bounded context
context Inventory is {
  include "inventory-types.riddl"
  include "InventoryItem.riddl"
  repository InventoryItemRepository is {
    schema InventoryItemData is relational
      of items as type InventoryItem
        index on field InventoryItem.inventoryItemId
        index on field InventoryItem.inventoryItemStatus
      with {
      briefly "Inventory item data schema"
      described as {
        |Relational schema for persisting inventory item
        |state with indexes on item identifier and status.
      }
    }
    handler InventoryItemPersistence is {
      on command InventoryItem.ReceiveStock is {
        tell event InventoryItem.StockReceived to entity
          Inventory.InventoryItem
        do "update InventoryItemData.items set currentStockLevel =
          currentStockLevel + receivedQuantity, lastReceivedAt =
          stockReceivedAt where inventoryItemId matches"
      }
      on command InventoryItem.ConsumeStock is {
        tell event InventoryItem.StockConsumed to entity
          Inventory.InventoryItem
        do "update InventoryItemData.items set currentStockLevel =
          currentStockLevel - consumedQuantity where
          inventoryItemId matches"
      }
      on command InventoryItem.AdjustStock is {
        tell event InventoryItem.StockAdjusted to entity
          Inventory.InventoryItem
        do "update InventoryItemData.items set currentStockLevel =
          currentStockLevel + adjustmentQuantity where
          inventoryItemId matches"
      }
      on command InventoryItem.SetReorderThreshold is {
        tell event InventoryItem.ReorderThresholdSet to entity
          Inventory.InventoryItem
        do "update InventoryItemData.items set
          configuredReorderThreshold = reorderThreshold where
          inventoryItemId matches"
      }
      on command InventoryItem.CreatePurchaseOrder is {
        tell event InventoryItem.PurchaseOrderCreated to entity
          Inventory.InventoryItem
        do "insert purchase order record with inventoryItemId,
          orderQuantity, orderUnit, preferredSupplier"
      }
    } with {
      briefly "Inventory item persistence"
      described as {
        |Persists inventory item commands.
      }
    }
  } with {
    briefly "Inventory item repository"
    described as {
      |Stores and retrieves inventory item data.
    }
  }
  adaptor FromKitchen from context Restaurant.Kitchen is { 
    handler KitchenConsumptionIntake is {
      on event Restaurant.Kitchen.KitchenTicket.PreparationStarted is {
        prompt "Consume stock for items being prepared"
      }
    } with {
      briefly "Kitchen consumption intake"
      described as {
        |Consumes stock as kitchen prepares items.
      }
    }
  } with {
    briefly "Kitchen adaptor"
    described as {
      | Receives preparation events from the kitchen to
      | automatically track stock consumption.
    }
  }
} with {
  briefly "Inventory context"
  described as {
    | Manages stock levels, receiving, consumption tracking,
    | manual adjustments, and reorder thresholds. Integrates
    | with kitchen context to automatically track consumption
    | as items are prepared.
  }
}
