// Scheduling bounded context
context Scheduling is {
  include "scheduling-types.riddl"
  include "Shift.riddl"
  repository ShiftRepository is {
    schema ShiftData is relational
      of shifts as type Shift
        index on field Shift.shiftId
        index on field Shift.shiftDate
        index on field Shift.employeeId
      with {
      briefly "Shift data schema"
      described as {
        |Relational schema for persisting shift state with
        |indexes on shift identifier, date, and employee.
      }
    }
    handler ShiftPersistence is {
      on command Shift.CreateShift is {
        tell event Shift.ShiftCreated to entity Scheduling.Shift
        do "insert row into ShiftData.shifts with shiftId,
          shiftDate, shiftStart, shiftEnd, shiftRole, and
          shiftStatus = Open"
      }
      on command Shift.AssignEmployee is {
        tell event Shift.EmployeeAssigned to entity Scheduling.Shift
        do "update ShiftData.shifts set assignedEmployeeId =
          employeeId, assignedEmployeeName = employeeName where
          shiftId matches"
      }
      on command Shift.SwapShift is {
        tell event Shift.ShiftSwapped to entity Scheduling.Shift
        do "update ShiftData.shifts set assignedEmployeeId =
          replacementEmployeeId, assignedEmployeeName =
          replacementName where shiftId matches"
      }
      on command Shift.ClockIn is {
        tell event Shift.ClockedIn to entity Scheduling.Shift
        do "update ShiftData.shifts set actualClockedInAt =
          clockedInAt where shiftId matches"
      }
      on command Shift.ClockOut is {
        tell event Shift.ClockedOut to entity Scheduling.Shift
        do "update ShiftData.shifts set actualClockedOutAt =
          clockedOutAt where shiftId matches"
      }
      on command Shift.CancelShift is {
        tell event Shift.ShiftCancelled to entity Scheduling.Shift
        do "update ShiftData.shifts set shiftStatus = Cancelled
          where shiftId matches"
      }
    } with {
      briefly "Shift persistence"
      described as {
        |Persists shift commands.
      }
    }
  } with {
    briefly "Shift repository"
    described as {
      |Stores and retrieves shift data.
    }
  }
  source ShiftEventSource is {
    outlet ShiftEvents is type ShiftEvent
    handler ShiftEventEmitter is {
      on event Shift.ShiftCreated is {
        send event Shift.ShiftCreated to outlet ShiftEvents
      }
      on event Shift.EmployeeAssigned is {
        send event Shift.EmployeeAssigned to outlet ShiftEvents
      }
      on event Shift.ShiftSwapped is {
        send event Shift.ShiftSwapped to outlet ShiftEvents
      }
      on event Shift.ClockedIn is {
        send event Shift.ClockedIn to outlet ShiftEvents
      }
      on event Shift.ClockedOut is {
        send event Shift.ClockedOut to outlet ShiftEvents
      }
      on event Shift.ShiftCancelled is {
        send event Shift.ShiftCancelled to outlet ShiftEvents
      }
    } with {
      briefly "Shift event emitter"
      described as {
        |Emits shift lifecycle events.
      }
    }
  } with {
    briefly "Shift event source"
    described as {
      |Publishes shift entity events.
    }
  }
  sink EmployeeUpdateSink is {
    inlet IncomingEmployeeUpdates is type HREvent
    handler EmployeeUpdateHandler is {
      on event HRSystem.EmployeeDataSynced is {
        tell command Shift.AssignEmployee to entity
          Scheduling.Shift
        do "update local employee roster with synced data
          from EmployeeDataSynced.hrEmployeeId for shift
          assignment validation"
      }
    } with {
      briefly "Employee update handler"
      described as {
        |Processes employee data sync events to keep the
        |scheduling roster current.
      }
    }
  } with {
    briefly "Employee update sink"
    described as {
      |Receives employee data updates from the external HR
      |system for shift assignment validation.
    }
  }
  connector ShiftToReporting is {
    from outlet Scheduling.ShiftEventSource.ShiftEvents to
      inlet Reporting.ShiftEventSink.IncomingShiftEvents
  } with {
    option is persistent
    briefly "Shift to reporting connector"
    described as {
      |Wires shift events to the reporting context for
      |labor reports.
    }
  }
  connector HRToScheduling is {
    from outlet HRSystem.HREventSource.EmployeeUpdates to
      inlet Scheduling.EmployeeUpdateSink.IncomingEmployeeUpdates
  } with {
    option is persistent
    briefly "HR to scheduling connector"
    described as {
      |Wires HR employee updates to the scheduling context.
    }
  }
} with {
  briefly "Scheduling context"
  described as {
    | Manages staff shift planning, assignment, time
    | tracking, and coverage. Provides the foundation
    | for labor reporting in the Reporting context.
  }
}
